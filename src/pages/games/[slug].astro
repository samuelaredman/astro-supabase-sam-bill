---
export const prerender = false;

import { getSupabase } from '../../utils/database'
const supabase = getSupabase();

import { igdbFetch } from '../../utils/igdb'

const { slug } = Astro.params;

const { data: game } = await (supabase as any)
  .from('games')
  .select(`
    id, title, slug, game_description, cover_img_url,
    date_released, igdb_id,
    game_genres(genres(id, name, slug)),
    game_platforms(platforms(id, name, slug)),
    game_companies(role, developers(id, name, slug))
  `)
  .eq('slug', slug)
  .single()

if (!game) return Astro.redirect('/404')

const { data: reviews } = await (supabase as any)
  .from('reviews')
  .select(`
    id, score, title, body, published_at, created_at,
    contains_spoilers, play_time_hours,
    played_on:platform_played_on ( id, name, slug ),
    profiles ( id, username, avatar_url ),
    review_votes ( vote )
  `)
  .eq('game_id', game.id)
  .eq('status', 'published')
  .order('published_at', { ascending: false })

const reviewList = reviews ?? []

let igdbData: any = null
if (game.igdb_id) {
  console.log('game.igdb_id value:', game.igdb_id, typeof game.igdb_id)
  const result = await igdbFetch('games',
    `fields summary, rating,
            artworks.url,
            screenshots.url,
            videos.video_id,
            game_modes.name,
            themes.name,
            franchises.name,
            game_engines.name,
            alternative_names.name,
            keywords.name,
            similar_games.id,
            similar_games.name,
            similar_games.slug,
            similar_games.cover.url;
     where id = ${game.igdb_id};`)
  console.log('IGDB result:', JSON.stringify(result))
  igdbData = result?.[0] ?? null
}

const heroImageRaw = igdbData?.artworks?.[0]?.url
  ?? igdbData?.screenshots?.[0]?.url
  ?? game.cover_img_url

const avgScore = reviewList.length > 0
  ? (reviewList.reduce((sum: number, r: any) => sum + r.score, 0) / reviewList.length).toFixed(1)
  : null

const scoreDistribution = Array.from({ length: 10 }, (_, i) =>
  reviewList.filter((r: any) => r.score === i + 1).length
)

const avgHours = reviewList.length > 0
  ? Math.round(reviewList.reduce((sum: number, r: any) => sum + (r.play_time_hours ?? 0), 0) / reviewList.length)
  : null

const developers = (game.game_companies ?? [])
  .filter((c: any) => c.role === 'developer')
  .map((c: any) => c.developers).filter(Boolean)

const publishers = (game.game_companies ?? [])
  .filter((c: any) => c.role === 'publisher')
  .map((c: any) => c.developers).filter(Boolean)

const genres = (game.game_genres ?? [])
  .map((gg: any) => gg.genres).filter(Boolean)

const platforms = (game.game_platforms ?? [])
  .map((gp: any) => gp.platforms).filter(Boolean)

const similarGames = (igdbData?.similar_games ?? []).slice(0, 8)

const releaseYear = game.date_released
  ? new Date(game.date_released).getFullYear()
  : null

const releaseDate = game.date_released
  ? new Date(game.date_released).toLocaleDateString('en-US', {
      year: 'numeric', month: 'long', day: 'numeric'
    })
  : null

const trailerVideoId = igdbData?.videos?.[0]?.video_id ?? null

function igdbImage(url: string | null, size = 't_cover_big') {
  if (!url) return null
  return `https:${url.replace(/t_[a-z_]+/, size)}`
}

function scoreClass(score: number): string {
  if (score >= 9) return 'score-great'
  if (score >= 7) return 'score-good'
  if (score >= 5) return 'score-mid'
  return 'score-low'
}

function timeAgo(dateStr: string): string {
  const diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000)
  if (diff < 60) return `${diff}s`
  if (diff < 3600) return `${Math.floor(diff / 60)}m`
  if (diff < 86400) return `${Math.floor(diff / 3600)}h`
  if (diff < 604800) return `${Math.floor(diff / 86400)}d`
  return `${Math.floor(diff / 604800)}w`
}

function getInitials(username: string): string {
  return username.slice(0, 2).toUpperCase()
}

const distJson = JSON.stringify(scoreDistribution)
const heroImageUrl = igdbImage(heroImageRaw, 't_1080p') ?? ''
const coverBlurUrl = igdbImage(game.cover_img_url) ?? ''
const trailerSrc = trailerVideoId
  ? `https://www.youtube.com/embed/${trailerVideoId}?autoplay=1&rel=0`
  : ''

function getVoteCounts(votes: any[]) {
  const up = (votes ?? []).filter((v: any) => v.vote === 1).length;
  const down = (votes ?? []).filter((v: any) => v.vote === -1).length;
  return { up, down };
}
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{game.title} — Cartridge</title>
  <meta name="description" content={game.game_description?.slice(0, 160)} />
  <meta property="og:title" content={`${game.title} — Cartridge`} />
  <meta property="og:description" content={game.game_description?.slice(0, 160)} />
  {game.cover_img_url && <meta property="og:image" content={igdbImage(game.cover_img_url, 't_cover_big') ?? ''} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    :root[data-theme="light"] {
      --bg: #f5f4f2; --bg-card: #ffffff; --bg-hover: #f4f3f0;
      --border: #e8e6e1; --border-subtle: #f0ede8;
      --text-primary: #141412; --text-secondary: #6b6860; --text-tertiary: #a09d98;
      --accent: #141412; --accent-text: #ffffff;
      --tag-bg: #f0ede8; --tag-text: #6b6860;
      --shadow: 0 1px 3px rgba(0,0,0,0.06); --shadow-md: 0 4px 16px rgba(0,0,0,0.1);
      --score-great: #1a6b3c; --score-great-bg: #eaf5ee;
      --score-good: #1a4a6b; --score-good-bg: #eaf0f5;
      --score-mid: #6b5a1a; --score-mid-bg: #f5f0ea;
      --score-low: #6b1a1a; --score-low-bg: #f5eaea;
      --game-accent: #4a3a8a; --game-accent-subtle: rgba(74,58,138,0.06);
      --hero-overlay: linear-gradient(to bottom, rgba(245,244,242,0.05) 0%, rgba(245,244,242,0.2) 40%, rgba(245,244,242,0.8) 75%, rgba(245,244,242,1) 100%);
      --hero-side: linear-gradient(to right, rgba(245,244,242,0.4) 0%, transparent 40%);
    }
    :root[data-theme="dark"] {
      --bg: #09090a; --bg-card: #131314; --bg-hover: #1c1c1e;
      --border: #222224; --border-subtle: #191919;
      --text-primary: #f0ede8; --text-secondary: #908d87; --text-tertiary: #484644;
      --accent: #f0ede8; --accent-text: #141412;
      --tag-bg: #1c1c1e; --tag-text: #6a6866;
      --shadow: 0 1px 3px rgba(0,0,0,0.5); --shadow-md: 0 4px 16px rgba(0,0,0,0.7);
      --score-great: #4ade80; --score-great-bg: #0b2016;
      --score-good: #60a5fa; --score-good-bg: #0b1828;
      --score-mid: #fbbf24; --score-mid-bg: #201808;
      --score-low: #f87171; --score-low-bg: #200808;
      --game-accent: #6050c8; --game-accent-subtle: rgba(96,80,200,0.09);
      --hero-overlay: linear-gradient(to bottom, rgba(9,9,10,0.05) 0%, rgba(9,9,10,0.2) 40%, rgba(9,9,10,0.75) 75%, rgba(9,9,10,1) 100%);
      --hero-side: linear-gradient(to right, rgba(9,9,10,0.5) 0%, transparent 40%);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text-primary); min-height: 100vh; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }

    .topnav { position: sticky; top: 0; z-index: 30; background: rgba(9,9,10,0.82); border-bottom: 1px solid var(--border); padding: 13px 28px; display: flex; align-items: center; gap: 16px; backdrop-filter: blur(20px); }
    [data-theme="light"] .topnav { background: rgba(245,244,242,0.82); }
    .back-btn { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--text-tertiary); transition: color 0.15s; }
    .back-btn:hover { color: var(--text-primary); }
    .logo { font-family: 'DM Serif Display', serif; font-size: 19px; letter-spacing: -0.3px; display: flex; align-items: center; gap: 7px; margin-left: auto; }
    .logo-dot { width: 6px; height: 6px; background: var(--game-accent); border-radius: 50%; box-shadow: 0 0 10px var(--game-accent); }
    .theme-btn { background: none; border: none; cursor: pointer; color: var(--text-tertiary); padding: 6px; display: flex; align-items: center; transition: color 0.15s; margin-left: 8px; }
    .theme-btn:hover { color: var(--text-primary); }

    .jump-nav { position: sticky; top: 53px; z-index: 20; background: rgba(9,9,10,0.72); border-bottom: 1px solid var(--border); backdrop-filter: blur(16px); display: flex; overflow-x: auto; scrollbar-width: none; }
    .jump-nav::-webkit-scrollbar { display: none; }
    [data-theme="light"] .jump-nav { background: rgba(245,244,242,0.82); }
    .jump-link { font-size: 11px; font-weight: 500; color: var(--text-tertiary); padding: 10px 20px; letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.15s, border-color 0.15s; border-bottom: 2px solid transparent; white-space: nowrap; flex-shrink: 0; }
    .jump-link:hover { color: var(--text-primary); }
    .jump-link.active { color: var(--text-primary); border-color: var(--game-accent); }

    .hero { position: relative; width: 100%; height: 400px; overflow: hidden; background: #04040a; }
    .hero-artwork { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }
    .hero-cover-blur { position: absolute; inset: -40px; background-size: cover; background-position: center 20%; filter: blur(28px) saturate(1.6) brightness(0.5); transform: scale(1.15); display: none; }
    .hero-cover-blur.visible { display: block; }
    .hero-side-fade { position: absolute; inset: 0; background: var(--hero-side); }
    .hero-overlay { position: absolute; inset: 0; background: var(--hero-overlay); }

    .page { max-width: 900px; margin: 0 auto; padding: 0 28px 100px; }

    .game-header { display: flex; gap: 28px; align-items: flex-end; margin-top: -100px; margin-bottom: 32px; position: relative; z-index: 2; }
    .cover-img { width: 140px; height: 187px; border-radius: 14px; object-fit: cover; border: 1px solid rgba(96,80,200,0.4); box-shadow: 0 14px 44px rgba(0,0,0,0.8), 0 0 36px rgba(96,80,200,0.2); display: block; flex-shrink: 0; }
    .cover-placeholder { width: 140px; height: 187px; border-radius: 14px; background: var(--bg-card); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 48px; flex-shrink: 0; }
    .game-info { flex: 1; min-width: 0; padding-bottom: 6px; }
    .game-title { font-family: 'Cinzel', serif; font-size: 36px; line-height: 1.1; letter-spacing: 0.05em; margin-bottom: 10px; font-weight: 600; text-shadow: 0 2px 24px rgba(0,0,0,0.6); }
    .meta-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
    .meta-tag { font-size: 13px; color: var(--text-secondary); }
    .meta-sep { color: var(--text-tertiary); font-size: 10px; }
    .meta-link { font-size: 13px; color: var(--text-secondary); transition: color 0.15s; }
    .meta-link:hover { color: var(--text-primary); text-decoration: underline; text-underline-offset: 3px; }
    .platform-list { display: flex; flex-wrap: wrap; gap: 5px; }
    .platform-tag { background: var(--tag-bg); color: var(--tag-text); font-size: 11px; font-weight: 500; padding: 3px 10px; border-radius: 6px; border: 1px solid var(--border); }

    .score-hero { display: flex; align-items: center; gap: 24px; padding: 24px 28px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; margin-bottom: 28px; position: relative; overflow: hidden; }
    .score-hero::before { content: ''; position: absolute; inset: 0; background: var(--game-accent-subtle); pointer-events: none; }
    .score-hero::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(to right, transparent, var(--game-accent), transparent); opacity: 0.6; }
    .avg-score-num { font-family: 'Century Schoolbook', 'New Century Schoolbook', Georgia, serif; font-size: 78px; line-height: 1; font-weight: 700; color: var(--score-great); text-shadow: 0 0 48px rgba(74,222,128,0.28); position: relative; z-index: 1; letter-spacing: -3px; }
    .score-great-color { color: var(--score-great); }
    .score-good-color  { color: var(--score-good); }
    .score-mid-color   { color: var(--score-mid); }
    .score-low-color   { color: var(--score-low); }
    .score-divider { width: 1px; height: 60px; background: var(--border); flex-shrink: 0; }
    .score-meta { flex: 1; position: relative; z-index: 1; }
    .score-label { font-size: 11px; font-weight: 500; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 3px; }
    .review-count-label { font-size: 13px; color: var(--text-secondary); margin-bottom: 14px; }
    .score-dist { display: flex; gap: 4px; align-items: flex-end; height: 48px; }
    .dist-bar-wrap { display: flex; flex-direction: column; align-items: center; gap: 3px; flex: 1; cursor: pointer; }
    .dist-bar { width: 100%; border-radius: 4px 4px 0 0; min-height: 4px; transition: opacity 0.15s, transform 0.15s; }
    .dist-bar-wrap:hover .dist-bar { opacity: 1 !important; transform: scaleY(1.06); transform-origin: bottom; }
    .dist-label { font-size: 9px; color: var(--text-tertiary); font-weight: 500; }
    .write-review-btn { background: var(--game-accent); color: white; border: none; border-radius: 22px; padding: 11px 22px; font-size: 13px; font-weight: 500; font-family: inherit; cursor: pointer; transition: opacity 0.15s, transform 0.15s; white-space: nowrap; box-shadow: 0 4px 24px rgba(96,80,200,0.4); position: relative; z-index: 1; }
    .write-review-btn:hover { opacity: 0.9; transform: translateY(-1px); }

    .content-grid { display: grid; grid-template-columns: 1fr 260px; gap: 24px; margin-bottom: 40px; }
    @media (max-width: 720px) { .content-grid { grid-template-columns: 1fr; } }
    .description { font-size: 14px; line-height: 1.8; color: var(--text-secondary); }
    .description.collapsed { display: -webkit-box; -webkit-line-clamp: 5; -webkit-box-orient: vertical; overflow: hidden; }
    .read-more-btn { background: none; border: none; font-family: inherit; font-size: 12px; color: var(--game-accent); cursor: pointer; padding: 8px 0 0; transition: opacity 0.15s; display: block; }
    .read-more-btn:hover { opacity: 0.7; }
    .details-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 4px 18px; height: fit-content; }
    .detail-row { display: flex; gap: 12px; padding: 11px 0; border-bottom: 1px solid var(--border-subtle); font-size: 12px; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { flex-shrink: 0; width: 80px; color: var(--text-tertiary); padding-top: 2px; text-transform: uppercase; letter-spacing: 0.06em; font-size: 10px; font-weight: 500; }
    .detail-value { color: var(--text-secondary); line-height: 1.5; }
    .tag-list { display: flex; flex-wrap: wrap; gap: 4px; }
    .tag { background: var(--tag-bg); color: var(--tag-text); font-size: 11px; padding: 2px 8px; border-radius: 5px; border: 1px solid var(--border); }

    .section { margin-bottom: 40px; }
    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .section-title { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-tertiary); }
    .section-count { font-size: 12px; color: var(--text-tertiary); }

    .trailer-thumb { position: relative; width: 100%; aspect-ratio: 16/9; border-radius: 14px; overflow: hidden; border: 1px solid var(--border); cursor: pointer; background: #000; }
    .trailer-bg { width: 100%; height: 100%; background: var(--bg-card); display: flex; align-items: center; justify-content: center; font-size: 80px; opacity: 0.15; transition: opacity 0.2s; }
    .trailer-thumb:hover .trailer-bg { opacity: 0.25; }
    .trailer-play { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 12px; }
    .play-circle { width: 76px; height: 76px; background: rgba(96,80,200,0.18); backdrop-filter: blur(8px); border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(96,80,200,0.5); transition: all 0.2s; box-shadow: 0 0 32px rgba(96,80,200,0.22); }
    .trailer-thumb:hover .play-circle { background: rgba(96,80,200,0.32); transform: scale(1.08); }
    .play-icon { width: 0; height: 0; border-top: 13px solid transparent; border-bottom: 13px solid transparent; border-left: 20px solid white; margin-left: 4px; }
    .trailer-label { font-size: 13px; color: rgba(255,255,255,0.65); }
    .trailer-iframe-wrap { display: none; width: 100%; aspect-ratio: 16/9; border-radius: 14px; overflow: hidden; border: 1px solid var(--border); }
    .trailer-iframe-wrap iframe { width: 100%; height: 100%; border: none; }

    .screenshots-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
    .screenshot { aspect-ratio: 16/9; border-radius: 10px; overflow: hidden; border: 1px solid var(--border); cursor: pointer; transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s; }
    .screenshot:hover { transform: scale(1.03); box-shadow: 0 8px 32px rgba(0,0,0,0.5); border-color: rgba(96,80,200,0.4); }
    .screenshot img { width: 100%; height: 100%; object-fit: cover; }

    .similar-scroll { display: flex; gap: 12px; overflow-x: auto; padding-bottom: 8px; scrollbar-width: thin; scrollbar-color: var(--border) transparent; }
    .similar-scroll::-webkit-scrollbar { height: 4px; }
    .similar-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
    .similar-card { flex-shrink: 0; width: 120px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s; display: block; }
    .similar-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: rgba(96,80,200,0.3); }
    .similar-cover { aspect-ratio: 3/4; background: var(--tag-bg); overflow: hidden; }
    .similar-cover img { width: 100%; height: 100%; object-fit: cover; }
    .similar-cover-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 28px; }
    .similar-info { padding: 8px 10px 10px; }
    .similar-title { font-size: 11px; font-weight: 500; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; color: var(--text-secondary); }
    .similar-year { font-size: 10px; color: var(--text-tertiary); margin-top: 2px; }

    .reviews-toolbar { display: flex; align-items: center; gap: 6px; margin-bottom: 20px; }
    .sort-tab { background: var(--tag-bg); color: var(--text-tertiary); border: 1px solid var(--border); border-radius: 20px; padding: 5px 14px; font-size: 11px; font-weight: 500; font-family: inherit; cursor: pointer; transition: all 0.15s; letter-spacing: 0.04em; text-transform: uppercase; }
    .sort-tab.active { background: var(--game-accent); color: white; border-color: transparent; }
    .review-card { padding: 22px 0; border-bottom: 1px solid var(--border-subtle); }
    .review-card:last-child { border-bottom: none; }
    .review-top { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
    .avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--bg-hover); border: 1px solid var(--border); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: var(--text-tertiary); overflow: hidden; }
    .avatar img { width: 100%; height: 100%; object-fit: cover; }
    .reviewer-info { flex: 1; min-width: 0; }
    .reviewer-name { font-size: 13px; font-weight: 500; transition: color 0.15s; }
    .reviewer-name:hover { color: var(--text-secondary); }
    .reviewer-meta { font-size: 11px; color: var(--text-tertiary); display: flex; gap: 6px; align-items: center; flex-wrap: wrap; margin-top: 2px; }
    .score-badge { flex-shrink: 0; width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; font-family: 'Century Schoolbook', Georgia, serif; }
    .score-great { color: var(--score-great); background: var(--score-great-bg); border: 1px solid rgba(74,222,128,0.25); }
    .score-good  { color: var(--score-good);  background: var(--score-good-bg);  border: 1px solid rgba(96,165,250,0.25); }
    .score-mid   { color: var(--score-mid);   background: var(--score-mid-bg);   border: 1px solid rgba(251,191,36,0.25); }
    .score-low   { color: var(--score-low);   background: var(--score-low-bg);   border: 1px solid rgba(248,113,113,0.25); }
    .review-title { font-family: 'DM Serif Display', serif; font-size: 18px; line-height: 1.3; margin-bottom: 8px; letter-spacing: -0.2px; }
    .review-body { font-size: 14px; line-height: 1.6; color: var(--text-secondary); display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .spoiler-pill { display: inline-flex; align-items: center; gap: 4px; background: var(--tag-bg); color: var(--tag-text); font-size: 11px; font-weight: 500; padding: 2px 8px; border-radius: 20px; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.3px; }
    .review-body.spoiler-hidden {filter: blur(4px); user-select: none; cursor: pointer; transition: filter 0.2s;}
    .review-body.spoiler-hidden:hover {filter: blur(3px);}
    .review-footer { display: flex; align-items: center; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
    .footer-tag { background: var(--tag-bg); color: var(--tag-text); font-size: 10px; font-weight: 500; padding: 2px 8px; border-radius: 4px; letter-spacing: 0.04em; text-transform: uppercase; border: 1px solid var(--border); }
    .expand-btn { font-size: 11px; color: var(--game-accent); margin-left: auto; cursor: pointer; background: none; border: none; font-family: inherit; transition: opacity 0.15s; padding: 0; font-weight: 500; }
    .expand-btn:hover { opacity: 0.7; }
    .vote-row { display: flex; align-items: center; gap: 6px; margin-top: 10px; }
    .vote-btn { display: flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 20px; border: 1px solid var(--border); background: none; font-size: 12px; font-family: inherit; color: var(--text-tertiary); cursor: pointer; transition: all 0.15s; }
    .vote-btn:hover { border-color: var(--text-secondary); color: var(--text-primary); }
    .vote-btn.active-up { background: var(--score-great-bg); color: var(--score-great); border-color: var(--score-great); }
    .vote-btn.active-down { background: var(--score-low-bg); color: var(--score-low); border-color: var(--score-low); }

    .empty-state { padding: 60px 0; text-align: center; color: var(--text-tertiary); }
    .empty-title { font-family: 'DM Serif Display', serif; font-size: 20px; color: var(--text-secondary); margin-bottom: 8px; }
    .empty-sub { font-size: 14px; }
    .write-btn-empty { display: inline-block; margin-top: 16px; background: var(--game-accent); color: white; border-radius: 20px; padding: 9px 20px; font-size: 14px; font-weight: 500; transition: opacity 0.15s; }
    .write-btn-empty:hover { opacity: 0.85; }

    .lightbox { display: none; position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,0.94); align-items: center; justify-content: center; backdrop-filter: blur(12px); cursor: pointer; }
    .lightbox.open { display: flex; }
    .lightbox-inner { max-width: 90vw; max-height: 90vh; border-radius: 12px; overflow: hidden; box-shadow: 0 24px 80px rgba(0,0,0,0.9); cursor: default; }
    .lightbox-inner img { width: 100%; height: 100%; object-fit: contain; }

    @media (max-width: 600px) {
      .game-header { flex-direction: column; align-items: flex-start; margin-top: -60px; }
      .game-title { font-size: 26px; }
      .hero { height: 260px; }
      .screenshots-grid { grid-template-columns: repeat(2, 1fr); }
      .score-hero { flex-wrap: wrap; gap: 16px; }
      .avg-score-num { font-size: 60px; }
      .write-review-btn { width: 100%; text-align: center; }
      .jump-nav { display: none; }
    }
  </style>
</head>

<body>

  <nav class="topnav">
    <a href="/" class="back-btn">
      <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8L10 4"/></svg>
      Back
    </a>
    <a href="/" class="logo"><span class="logo-dot"></span>Cartridge</a>
    <button class="theme-btn" onclick="toggleTheme()">
      <svg id="themeIcon" width="17" height="17" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="9" r="3.5"/>
        <path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>
      </svg>
    </button>
  </nav>

  <nav class="jump-nav">
    <a href="#overview" class="jump-link active">Overview</a>
    {trailerVideoId && <a href="#trailer" class="jump-link">Trailer</a>}
    {igdbData?.screenshots?.length > 0 && <a href="#screenshots" class="jump-link">Screenshots</a>}
    {similarGames.length > 0 && <a href="#similar" class="jump-link">Similar</a>}
    <a href="#reviews" class="jump-link">Reviews</a>
  </nav>

  <div class="hero">
    {heroImageUrl
      ? <img
          class="hero-artwork"
          src={heroImageUrl}
          alt=""
          loading="eager"
          onerror="this.style.display='none'; document.getElementById('heroCoverBlur').classList.add('visible')"
        />
      : null
    }
    <div
      class="hero-cover-blur"
      id="heroCoverBlur"
      style={heroImageUrl ? '' : 'display:block'}
    ></div>
    <div class="hero-side-fade"></div>
    <div class="hero-overlay"></div>
  </div>

  <div class="page">

    <div class="game-header" id="overview">
      {game.cover_img_url
        ? <img class="cover-img" src={igdbImage(game.cover_img_url) ?? ''} alt={game.title} loading="eager" />
        : <div class="cover-placeholder">🎮</div>
      }
      <div class="game-info">
        <h1 class="game-title">{game.title}</h1>
        <div class="meta-row">
          {releaseYear && <span class="meta-tag">{releaseYear}</span>}
          {developers.length > 0 && (
            <>
              <span class="meta-sep">•</span>
              {developers.map((d: any) => (
                <a href={`/studios/${d.slug}`} class="meta-link">{d.name}</a>
              ))}
            </>
          )}
          {genres.length > 0 && (
            <>
              <span class="meta-sep">•</span>
              <span class="meta-tag" style="color:var(--game-accent)">{genres[0].name}</span>
            </>
          )}
        </div>
        <div class="platform-list">
          {platforms.map((p: any) => (
            <span class="platform-tag">{p.name}</span>
          ))}
        </div>
      </div>
    </div>

    {avgScore ? (
      <div class="score-hero">
        <div class={`avg-score-num ${scoreClass(parseFloat(avgScore))}-color`}>
          {avgScore}
        </div>
        <div class="score-divider"></div>
        <div class="score-meta">
          <div class="score-label">Cartridge Score</div>
          <div class="review-count-label">
            from {reviewList.length} {reviewList.length === 1 ? 'review' : 'reviews'}
            {avgHours ? ` · avg ${avgHours}h played` : ''}
          </div>
          <div class="score-dist" id="scoreDist"></div>
        </div>
        <a href="/" class="write-review-btn">+ Write a review</a>
      </div>
    ) : (
      <div class="score-hero">
        <div class="score-meta">
          <div class="score-label">No reviews yet</div>
          <div class="review-count-label">Be the first to review {game.title}</div>
        </div>
        <a href="/" class="write-review-btn">+ Write a review</a>
      </div>
    )}

    <div class="content-grid">
      <div>
        {game.game_description && (
          <>
            <p class="description collapsed" id="desc">{game.game_description}</p>
            <button class="read-more-btn" id="readMoreBtn" onclick="toggleDesc()">Read more →</button>
          </>
        )}
      </div>
      <div class="details-card">
        {releaseDate && (
          <div class="detail-row">
            <span class="detail-label">Released</span>
            <span class="detail-value">{releaseDate}</span>
          </div>
        )}
        {developers.length > 0 && (
          <div class="detail-row">
            <span class="detail-label">Developer</span>
            <span class="detail-value">{developers.map((d: any) => d.name).join(', ')}</span>
          </div>
        )}
        {publishers.length > 0 && (
          <div class="detail-row">
            <span class="detail-label">Publisher</span>
            <span class="detail-value">{publishers.map((p: any) => p.name).join(', ')}</span>
          </div>
        )}
        {genres.length > 0 && (
          <div class="detail-row">
            <span class="detail-label">Genres</span>
            <div class="tag-list">
              {genres.map((g: any) => <span class="tag">{g.name}</span>)}
            </div>
          </div>
        )}
        {igdbData?.themes?.length > 0 && (
          <div class="detail-row">
            <span class="detail-label">Themes</span>
            <div class="tag-list">
              {igdbData.themes.map((t: any) => <span class="tag">{t.name}</span>)}
            </div>
          </div>
        )}
        {igdbData?.game_modes?.length > 0 && (
          <div class="detail-row">
            <span class="detail-label">Modes</span>
            <div class="tag-list">
              {igdbData.game_modes.map((m: any) => <span class="tag">{m.name}</span>)}
            </div>
          </div>
        )}
        {igdbData?.game_engines?.length > 0 && (
          <div class="detail-row">
            <span class="detail-label">Engine</span>
            <span class="detail-value">{igdbData.game_engines.map((e: any) => e.name).join(', ')}</span>
          </div>
        )}
        {igdbData?.franchises?.length > 0 && (
          <div class="detail-row">
            <span class="detail-label">Franchise</span>
            <span class="detail-value">{igdbData.franchises.map((f: any) => f.name).join(', ')}</span>
          </div>
        )}
        {igdbData?.alternative_names?.length > 0 && (
          <div class="detail-row">
            <span class="detail-label">Also known as</span>
            <span class="detail-value">{igdbData.alternative_names.slice(0, 3).map((a: any) => a.name).join(', ')}</span>
          </div>
        )}
      </div>
    </div>

    {trailerVideoId && (
      <div class="section" id="trailer">
        <div class="section-header">
          <span class="section-title">Trailer</span>
        </div>
        <div class="trailer-thumb" id="trailerThumb" onclick="loadTrailer()">
          <div class="trailer-bg">🎮</div>
          <div class="trailer-play">
            <div class="play-circle"><div class="play-icon"></div></div>
            <div class="trailer-label">{game.title} — Official Trailer</div>
          </div>
        </div>
        <div class="trailer-iframe-wrap" id="trailerIframe">
          <iframe id="trailerPlayer" src="" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
      </div>
    )}

    {igdbData?.screenshots?.length > 0 && (
      <div class="section" id="screenshots">
        <div class="section-header">
          <span class="section-title">Screenshots</span>
          <span class="section-count">{igdbData.screenshots.length} screenshots</span>
        </div>
        <div class="screenshots-grid">
          {igdbData.screenshots.slice(0, 6).map((s: any, i: number) => (
            <div
              class="screenshot"
              onclick={`openLightbox('${igdbImage(s.url, 't_1080p')}')`}
            >
              <img
                src={igdbImage(s.url, 't_screenshot_big') ?? ''}
                alt={`${game.title} screenshot ${i + 1}`}
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    )}

    {similarGames.length > 0 && (
      <div class="section" id="similar">
        <div class="section-header">
          <span class="section-title">Similar games</span>
        </div>
        <div class="similar-scroll">
          {similarGames.map((g: any) => (
            <a href={g.slug ? `/games/${g.slug}` : '#'} class="similar-card">
              <div class="similar-cover">
                {g.cover?.url
                  ? <img src={igdbImage(g.cover.url) ?? ''} alt={g.name} loading="lazy" />
                  : <div class="similar-cover-placeholder">🎮</div>
                }
              </div>
              <div class="similar-info">
                <div class="similar-title">{g.name}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="section" id="reviews">
      <div class="section-header">
        <span class="section-title">Reviews</span>
        <span class="section-count">{reviewList.length} {reviewList.length === 1 ? 'review' : 'reviews'}</span>
      </div>

      {reviewList.length === 0 ? (
        <div class="empty-state">
          <div class="empty-title">No reviews yet</div>
          <p class="empty-sub">Be the first to review {game.title}.</p>
          <a href="/" class="write-btn-empty">+ Write a review</a>
        </div>
      ) : (
        <>
          <div class="reviews-toolbar">
            <button class="sort-tab active" onclick="sortReviews('recent', this)">Recent</button>
            <button class="sort-tab" onclick="sortReviews('highest', this)">Highest</button>
            <button class="sort-tab" onclick="sortReviews('lowest', this)">Lowest</button>
          </div>
          <div class="reviews-list" id="reviewsList">
            {reviewList.map((review: any) => (
              <div
                class="review-card"
                data-score={review.score}
                data-date={review.published_at ?? review.created_at}
              >
                <div class="review-top">
                  <div class="avatar">
                    {review.profiles?.avatar_url
                      ? <img src={review.profiles.avatar_url} alt={review.profiles.username} />
                      : getInitials(review.profiles?.username ?? '??')
                    }
                  </div>
                  <div class="reviewer-info">
                    <a href={`/reviewers/${review.profiles?.username}`} class="reviewer-name">
                      @{review.profiles?.username ?? 'unknown'}
                    </a>
                    <div class="reviewer-meta">
                      <span>{timeAgo(review.published_at ?? review.created_at)}</span>
                      {review.played_on && <><span>·</span><span>{review.played_on.name}</span></>}
                      {review.play_time_hours && <><span>·</span><span>{review.play_time_hours}h</span></>}
                    </div>
                  </div>
                  <div class={`score-badge ${scoreClass(review.score)}`}>{review.score}</div>
                </div>
                {review.contains_spoilers && <div class="spoiler-pill">⚠ spoilers</div>}
                {review.title && <div class="review-title">{review.title}</div>}
                <div class={`review-body ${review.contains_spoilers ? 'spoiler-hidden' : ''}`}
                   data-spoiler={review.contains_spoilers ? 'true' : 'false'}>
                  {review.body}
                </div>
                <div class="review-footer">
                  {review.played_on && <span class="footer-tag">{review.played_on.name}</span>}
                  {review.play_time_hours && <span class="footer-tag">{review.play_time_hours}h played</span>}
                  {(() => {
                    const { up, down } = getVoteCounts(review.review_votes);
                    return (
                      <div class="vote-row">
                        <button
                          class="vote-btn"
                          data-review-id={review.id}
                          data-vote="1"
                        >
                          ▲ {up}
                        </button>
                        <button
                          class="vote-btn"
                          data-review-id={review.id}
                          data-vote="-1"
                        >
                          ▼ {down}
                        </button>
                      </div>
                    );
                  })()}
                  <button class="expand-btn" onclick={`toggleReview('${review.id}', this)`}>Read more →</button>
                </div>
              </div>
            ))}
          </div>
        </>
      )}
    </div>

  </div>

  <div class="lightbox" id="lightbox" onclick="closeLightbox()">
    <div class="lightbox-inner" onclick="event.stopPropagation()">
      <img id="lightboxImg" src="" alt="Screenshot" />
    </div>
  </div>

  <script is:inline define:vars={{ distJson, heroImageUrl, coverBlurUrl, trailerSrc }}>

    document.getElementById('heroCoverBlur').style.backgroundImage = 'url(' + coverBlurUrl + ')'

    var dist = JSON.parse(distJson)
    var maxVal = Math.max.apply(null, dist.concat([1]))
    var colors = ['#f87171','#f87171','#fb923c','#fbbf24','#fbbf24','#60a5fa','#60a5fa','#4ade80','#4ade80','#4ade80']
    var container = document.getElementById('scoreDist')
    if (container) {
      dist.forEach(function(count, i) {
        var wrap = document.createElement('div')
        wrap.className = 'dist-bar-wrap'
        wrap.title = 'Score ' + (i + 1) + ': ' + count + ' reviews'
        var bar = document.createElement('div')
        bar.className = 'dist-bar'
        bar.style.height = Math.max(4, (count / maxVal) * 42) + 'px'
        bar.style.background = colors[i]
        bar.style.opacity = '0.65'
        var label = document.createElement('div')
        label.className = 'dist-label'
        label.textContent = String(i + 1)
        wrap.appendChild(bar)
        wrap.appendChild(label)
        container.appendChild(wrap)
      })
    }

    function loadTrailer() {
      var thumb = document.getElementById('trailerThumb')
      var wrap = document.getElementById('trailerIframe')
      var player = document.getElementById('trailerPlayer')
      if (thumb) thumb.style.display = 'none'
      if (wrap) wrap.style.display = 'block'
      if (player) player.src = trailerSrc
    }
    window.loadTrailer = loadTrailer

    function openLightbox(src) {
      var lb = document.getElementById('lightbox')
      var img = document.getElementById('lightboxImg')
      if (lb && img) { img.src = src; lb.classList.add('open') }
    }
    function closeLightbox() {
      var lb = document.getElementById('lightbox')
      if (lb) lb.classList.remove('open')
    }
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeLightbox() })
    window.openLightbox = openLightbox
    window.closeLightbox = closeLightbox

    function toggleReview(id, btn) {
      var body = document.getElementById('body-' + id)
      if (!body) return
      body.classList.toggle('collapsed')
      btn.textContent = body.classList.contains('collapsed') ? 'Read more →' : 'Read less ↑'
    }
    window.toggleReview = toggleReview

    function toggleDesc() {
      var desc = document.getElementById('desc')
      var btn = document.getElementById('readMoreBtn')
      if (!desc || !btn) return
      desc.classList.toggle('collapsed')
      btn.textContent = desc.classList.contains('collapsed') ? 'Read more →' : 'Read less ↑'
    }
    window.toggleDesc = toggleDesc

    function sortReviews(type, btn) {
      document.querySelectorAll('.sort-tab').forEach(function(b) { b.classList.remove('active') })
      btn.classList.add('active')
      var list = document.getElementById('reviewsList')
      if (!list) return
      var cards = Array.from(list.querySelectorAll('.review-card'))
      cards.sort(function(a, b) {
        if (type === 'highest') return parseInt(b.dataset.score) - parseInt(a.dataset.score)
        if (type === 'lowest') return parseInt(a.dataset.score) - parseInt(b.dataset.score)
        return new Date(b.dataset.date).getTime() - new Date(a.dataset.date).getTime()
      })
      cards.forEach(function(card) { list.appendChild(card) })
    }
    window.sortReviews = sortReviews

    var sections = ['overview', 'trailer', 'screenshots', 'similar', 'reviews']
    var jumpLinks = document.querySelectorAll('.jump-link')
    window.addEventListener('scroll', function() {
      var current = 'overview'
      sections.forEach(function(id) {
        var el = document.getElementById(id)
        if (el && window.scrollY >= el.offsetTop - 120) current = id
      })
      jumpLinks.forEach(function(link) {
        link.classList.toggle('active', link.getAttribute('href') === '#' + current)
      })
    })

    function toggleTheme() {
      var html = document.documentElement
      var next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light'
      html.setAttribute('data-theme', next)
      localStorage.setItem('theme', next)
      updateIcon(next)
    }
    function updateIcon(theme) {
      var icon = document.getElementById('themeIcon')
      if (!icon) return
      icon.innerHTML = theme === 'dark'
        ? '<path d="M15 10.5A7 7 0 016.5 3a7 7 0 100 12 7 7 0 008.5-4.5z"/>'
        : '<circle cx="9" cy="9" r="3.5"/><path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>'
    }
    window.toggleTheme = toggleTheme

    var saved = localStorage.getItem('theme') ||
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
    document.documentElement.setAttribute('data-theme', saved)
    updateIcon(saved)

    document.querySelectorAll('.review-body[data-spoiler="true"]').forEach(el => {
      el.addEventListener('click', () => {
        el.classList.remove('spoiler-hidden');
      });
    });

    document.querySelectorAll('.vote-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const reviewId = btn.dataset.reviewId;
    const vote = parseInt(btn.dataset.vote);

    const res = await fetch('/api/reviews/vote', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ review_id: reviewId, vote }),
    });

    if (res.status === 401) { window.location.href = '/signin'; return; }
    if (!res.ok) return;

    const data = await res.json();

    // Update both buttons for this review
    const pair = document.querySelectorAll(`.vote-btn[data-review-id="${reviewId}"]`);
    pair.forEach(b => {
      const bVote = parseInt(b.dataset.vote);
      const countEl = b.childNodes[b.childNodes.length - 1];
      const currentCount = parseInt(b.textContent.trim().split(' ').pop());

      if (data.vote === null) {
        // Vote removed
        b.classList.remove('active-up', 'active-down');
        if (bVote === vote) b.textContent = b.textContent.replace(/\d+/, currentCount - 1);
      } else if (data.vote === bVote) {
        // This button is now active
        b.classList.add(bVote === 1 ? 'active-up' : 'active-down');
        b.classList.remove(bVote === 1 ? 'active-down' : 'active-up');
        b.textContent = (bVote === 1 ? '▲ ' : '▼ ') + (currentCount + 1);
      } else {
        // This button lost its vote
        b.classList.remove('active-up', 'active-down');
        b.textContent = (bVote === 1 ? '▲ ' : '▼ ') + Math.max(0, currentCount - 1);
      }
    });
  });
});

  </script>
</body>
</html>
