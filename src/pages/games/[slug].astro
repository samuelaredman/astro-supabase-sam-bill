---
export const prerender = false;

import { getSupabase } from '../../utils/database'
const supabase = getSupabase();
import { igdbFetch } from '../../utils/igdb'

const { slug } = Astro.params;
const activeTab = Astro.url.searchParams.get('tab') || 'overview'

const { data: game } = await (supabase as any)
  .from('games')
  .select(`
    id, title, slug, game_description, cover_img_url,
    date_released, igdb_id,
    game_genres(genres(id, name, slug)),
    game_platforms(platforms(id, name, slug)),
    game_companies(role, developers(id, name, slug))
  `)
  .eq('slug', slug)
  .single()

if (!game) return Astro.redirect('/404')

const { data: reviews } = await (supabase as any)
  .from('reviews')
  .select(`
    id, score, title, body, published_at, created_at,
    contains_spoilers, play_time_hours,
    played_on:platform_played_on ( id, name, slug ),
    profiles ( id, username, avatar_url )
  `)
  .eq('game_id', game.id)
  .eq('status', 'published')
  .order('published_at', { ascending: false })

const reviewList = reviews ?? []

let igdbData: any = null
if (game.igdb_id) {
  const result = await igdbFetch('games',
    `fields summary, rating,
            artworks.url,
            screenshots.url,
            videos.video_id,
            game_modes.name,
            themes.name,
            franchises.name,
            game_engines.name,
            alternative_names.name,
            similar_games.id,
            similar_games.name,
            similar_games.slug,
            similar_games.cover.url;
     where id = ${game.igdb_id};`)
  igdbData = result?.[0] ?? null
}

const heroArtwork = igdbData?.artworks?.[0]?.url ?? null
const heroScreenshot = igdbData?.screenshots?.[0]?.url ?? null
const showCoverBlur = !heroArtwork && !heroScreenshot

function igdbImage(url: string | null, size = 't_cover_big') {
  if (!url) return null
  const clean = url.startsWith('//') ? `https:${url}` : url
  return clean.replace(/t_[a-z0-9_]+/, size)
}

const heroImageUrl = heroArtwork
  ? igdbImage(heroArtwork, 't_1080p_2x') ?? ''
  : heroScreenshot ? igdbImage(heroScreenshot, 't_1080p_2x') ?? '' : ''

const heroImageUrl1x = heroArtwork
  ? igdbImage(heroArtwork, 't_1080p') ?? ''
  : heroScreenshot ? igdbImage(heroScreenshot, 't_1080p') ?? '' : ''

const avgScore = reviewList.length > 0
  ? (reviewList.reduce((sum: number, r: any) => sum + r.score, 0) / reviewList.length).toFixed(1)
  : null

const scoreDistribution = Array.from({ length: 10 }, (_, i) =>
  reviewList.filter((r: any) => r.score === i + 1).length
)

const totalHours = reviewList.reduce((sum: number, r: any) => sum + (r.play_time_hours ?? 0), 0)
const avgHours = reviewList.length > 0 ? Math.round(totalHours / reviewList.length) : null

const developers = (game.game_companies ?? []).filter((c: any) => c.role === 'developer').map((c: any) => c.developers).filter(Boolean)
const publishers = (game.game_companies ?? []).filter((c: any) => c.role === 'publisher').map((c: any) => c.developers).filter(Boolean)
const genres = (game.game_genres ?? []).map((gg: any) => gg.genres).filter(Boolean)
const platforms = (game.game_platforms ?? []).map((gp: any) => gp.platforms).filter(Boolean)
const similarGames = (igdbData?.similar_games ?? []).slice(0, 8)

const releaseYear = game.date_released ? new Date(game.date_released).getFullYear() : null
const releaseDate = game.date_released
  ? new Date(game.date_released).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null
const trailerVideoId = igdbData?.videos?.[0]?.video_id ?? null

// ── STATS ──
const releaseYearStr = releaseYear ? String(releaseYear) : null
const primaryGenreId = genres[0]?.id ?? null

const { data: allScoreRows } = await (supabase as any)
  .from('reviews').select('game_id, score').eq('status', 'published')

const gameScoreMap: Record<string, number[]> = {}
for (const r of allScoreRows ?? []) {
  if (!gameScoreMap[r.game_id]) gameScoreMap[r.game_id] = []
  gameScoreMap[r.game_id].push(r.score)
}
const gameAvgs: Record<string, number> = {}
for (const [gid, scores] of Object.entries(gameScoreMap)) {
  gameAvgs[gid] = scores.reduce((a: number, b: number) => a + b, 0) / scores.length
}

const thisAvg = avgScore ? parseFloat(avgScore) : 0
const allAvgs = Object.values(gameAvgs).sort((a, b) => b - a)
const allTimeRank = allAvgs.findIndex(v => v <= thisAvg) + 1
const allTimeTotal = allAvgs.length
const allTimePct = allTimeTotal > 0 ? Math.round(((allTimeTotal - allTimeRank) / allTimeTotal) * 100) : 0

let genreRank = 0, genreTotal = 0, genrePct = 0
if (primaryGenreId) {
  const { data: genreGameRows } = await (supabase as any).from('game_genres').select('game_id').eq('genre_id', primaryGenreId)
  const genreGameIds = new Set((genreGameRows ?? []).map((r: any) => r.game_id))
  const genreAvgsList = allAvgs.filter((_, i) => {
    const gid = Object.keys(gameAvgs).find(k => gameAvgs[k] === allAvgs[i])
    return gid && genreGameIds.has(gid)
  })
  genreTotal = genreAvgsList.length
  genreRank = genreAvgsList.filter(v => v > thisAvg).length + 1
  genrePct = genreTotal > 0 ? Math.round(((genreTotal - genreRank) / genreTotal) * 100) : 0
}

let yearRank = 0, yearTotal = 0, yearPct = 0
if (releaseYearStr) {
  const { data: yearGameRows } = await (supabase as any).from('games').select('id')
    .gte('date_released', `${releaseYearStr}-01-01`).lte('date_released', `${releaseYearStr}-12-31`)
  const yearGameIds = new Set((yearGameRows ?? []).map((r: any) => r.id))
  const yearAvgsArr = Object.entries(gameAvgs).filter(([gid]) => yearGameIds.has(gid)).map(([, avg]) => avg).sort((a, b) => b - a)
  yearTotal = yearAvgsArr.length
  yearRank = yearAvgsArr.filter(v => v > thisAvg).length + 1
  yearPct = yearTotal > 0 ? Math.round(((yearTotal - yearRank) / yearTotal) * 100) : 0
}

const platformCounts: Record<string, number> = {}
for (const r of reviewList) {
  const name = (r as any).played_on?.name ?? 'Unknown'
  platformCounts[name] = (platformCounts[name] ?? 0) + 1
}
const platformBreakdown = Object.entries(platformCounts)
  .sort((a, b) => b[1] - a[1]).slice(0, 5)
  .map(([name, count]) => ({ name, count, pct: Math.round((count / reviewList.length) * 100) }))

const recommendedCount = reviewList.filter((r: any) => r.score >= 7).length
const recommendedRate = reviewList.length > 0 ? Math.round((recommendedCount / reviewList.length) * 100) : 0

let genreAvgScore = 0
if (primaryGenreId) {
  const { data: genreGameRows2 } = await (supabase as any).from('game_genres').select('game_id').eq('genre_id', primaryGenreId)
  const genreGameIds2 = new Set((genreGameRows2 ?? []).map((r: any) => r.game_id))
  const genreScores: number[] = []
  for (const [gid, scores] of Object.entries(gameScoreMap)) {
    if (genreGameIds2.has(gid)) genreScores.push(...scores)
  }
  genreAvgScore = genreScores.length > 0
    ? Math.round((genreScores.reduce((a, b) => a + b, 0) / genreScores.length) * 10) / 10 : 0
}

// monthly reviews + avg scores — last 6 months
const monthlyReviews: Record<string, number> = {}
const monthlyScores: Record<string, number[]> = {}
for (const r of reviewList) {
  const d = new Date((r as any).published_at ?? (r as any).created_at)
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`
  monthlyReviews[key] = (monthlyReviews[key] ?? 0) + 1
  if (!monthlyScores[key]) monthlyScores[key] = []
  monthlyScores[key].push((r as any).score)
}
const monthLabels: string[] = []
const monthCounts: number[] = []
const monthAvgScores: (number | null)[] = []
for (let i = 5; i >= 0; i--) {
  const d = new Date()
  d.setMonth(d.getMonth() - i)
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`
  monthLabels.push(d.toLocaleDateString('en-US', { month: 'short' }))
  const cnt = monthlyReviews[key] ?? 0
  monthCounts.push(cnt)
  if (cnt > 0 && monthlyScores[key]) {
    const avg = monthlyScores[key].reduce((a, b) => a + b, 0) / monthlyScores[key].length
    monthAvgScores.push(Math.round(avg * 10) / 10)
  } else {
    monthAvgScores.push(null)
  }
}

// hours played distribution
const hoursBuckets = [
  { label: '0-10h', min: 0, max: 10 },
  { label: '10-25h', min: 10, max: 25 },
  { label: '25-50h', min: 25, max: 50 },
  { label: '50-100h', min: 50, max: 100 },
  { label: '100h+', min: 100, max: Infinity },
]
const hoursDistribution = hoursBuckets.map(b => ({
  label: b.label,
  count: reviewList.filter((r: any) =>
    r.play_time_hours != null && r.play_time_hours >= b.min && r.play_time_hours < b.max
  ).length
}))

// score by platform
const platScoreMap: Record<string, number[]> = {}
for (const r of reviewList) {
  const name = (r as any).played_on?.name ?? null
  if (!name) continue
  if (!platScoreMap[name]) platScoreMap[name] = []
  platScoreMap[name].push((r as any).score)
}
const platformScores = Object.entries(platScoreMap)
  .map(([name, scores]) => ({
    name,
    avg: Math.round((scores.reduce((a, b) => a + b, 0) / scores.length) * 10) / 10,
    count: scores.length
  }))
  .sort((a, b) => b.count - a.count)

function scoreClass(score: number): string {
  if (score >= 9) return 'score-great'
  if (score >= 7) return 'score-good'
  if (score >= 5) return 'score-mid'
  return 'score-low'
}
function timeAgo(dateStr: string): string {
  const diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000)
  if (diff < 60) return `${diff}s`
  if (diff < 3600) return `${Math.floor(diff / 60)}m`
  if (diff < 86400) return `${Math.floor(diff / 3600)}h`
  if (diff < 604800) return `${Math.floor(diff / 86400)}d`
  return `${Math.floor(diff / 604800)}w`
}
function getInitials(username: string): string {
  return username.slice(0, 2).toUpperCase()
}

const distJson = JSON.stringify(scoreDistribution)
const coverBlurUrl = igdbImage(game.cover_img_url, 't_cover_big') ?? ''
const trailerSrc = trailerVideoId ? `https://www.youtube.com/embed/${trailerVideoId}?autoplay=1&rel=0` : ''
const statsJson = JSON.stringify({
  allTimeRank, allTimeTotal, allTimePct,
  genreRank, genreTotal, genrePct,
  yearRank, yearTotal, yearPct,
  platformBreakdown, recommendedRate,
  totalHours, avgHours,
  genreAvgScore,
  genreName: genres[0]?.name ?? 'Genre',
  releaseYear, reviewCount: reviewList.length,
  scoreDistribution, monthLabels, monthCounts, monthAvgScores,
  hoursDistribution, platformScores,
})
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{game.title} — Cartridge</title>
  <meta name="description" content={game.game_description?.slice(0, 160)} />
  <meta property="og:title" content={`${game.title} — Cartridge`} />
  <meta property="og:description" content={game.game_description?.slice(0, 160)} />
  {game.cover_img_url && <meta property="og:image" content={igdbImage(game.cover_img_url, 't_cover_big') ?? ''} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    :root[data-theme="light"] {
      --bg:#f5f4f2;--bg-card:#ffffff;--bg-hover:#f4f3f0;
      --border:#e8e6e1;--border-subtle:#f0ede8;
      --text-primary:#141412;--text-secondary:#6b6860;--text-tertiary:#a09d98;
      --tag-bg:#f0ede8;--tag-text:#6b6860;
      --shadow:0 1px 3px rgba(0,0,0,.06);--shadow-md:0 4px 16px rgba(0,0,0,.1);
      --score-great:#1a6b3c;--score-great-bg:#eaf5ee;
      --score-good:#1a4a6b;--score-good-bg:#eaf0f5;
      --score-mid:#6b5a1a;--score-mid-bg:#f5f0ea;
      --score-low:#6b1a1a;--score-low-bg:#f5eaea;
      --game-accent:#4a3a8a;--game-accent-subtle:rgba(74,58,138,.06);
      --hero-overlay:linear-gradient(to bottom,rgba(245,244,242,.05)0%,rgba(245,244,242,.2)40%,rgba(245,244,242,.85)75%,rgba(245,244,242,1)100%);
      --hero-side:linear-gradient(to right,rgba(245,244,242,.4)0%,transparent 40%);
    }
    :root[data-theme="dark"] {
      --bg:#09090a;--bg-card:#131314;--bg-hover:#1c1c1e;
      --border:#222224;--border-subtle:#191919;
      --text-primary:#f0ede8;--text-secondary:#908d87;--text-tertiary:#484644;
      --tag-bg:#1c1c1e;--tag-text:#6a6866;
      --shadow:0 1px 3px rgba(0,0,0,.5);--shadow-md:0 4px 16px rgba(0,0,0,.7);
      --score-great:#4ade80;--score-great-bg:#0b2016;
      --score-good:#60a5fa;--score-good-bg:#0b1828;
      --score-mid:#fbbf24;--score-mid-bg:#201808;
      --score-low:#f87171;--score-low-bg:#200808;
      --game-accent:#6050c8;--game-accent-subtle:rgba(96,80,200,.09);
      --hero-overlay:linear-gradient(to bottom,rgba(9,9,10,.05)0%,rgba(9,9,10,.2)40%,rgba(9,9,10,.8)75%,rgba(9,9,10,1)100%);
      --hero-side:linear-gradient(to right,rgba(9,9,10,.5)0%,transparent 40%);
    }

    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text-primary);min-height:100vh;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}

    .topnav{position:sticky;top:0;z-index:30;background:rgba(9,9,10,.82);border-bottom:1px solid var(--border);padding:13px 28px;display:flex;align-items:center;gap:16px;backdrop-filter:blur(20px)}
    [data-theme="light"] .topnav{background:rgba(245,244,242,.82)}
    .back-btn{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-tertiary);transition:color .15s}
    .back-btn:hover{color:var(--text-primary)}
    .logo{font-family:'DM Serif Display',serif;font-size:19px;letter-spacing:-.3px;display:flex;align-items:center;gap:7px;margin-left:auto}
    .logo-dot{width:6px;height:6px;background:var(--game-accent);border-radius:50%;box-shadow:0 0 10px var(--game-accent)}
    .theme-btn{background:none;border:none;cursor:pointer;color:var(--text-tertiary);padding:6px;display:flex;align-items:center;transition:color .15s;margin-left:8px}
    .theme-btn:hover{color:var(--text-primary)}

    /* CARD BUTTON TAB NAV */
    .tab-nav{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:28px}
    .tab-link{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:16px 12px;background:var(--bg-card);border:1px solid var(--border);border-radius:14px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden;text-decoration:none}
    .tab-link::before{content:'';position:absolute;inset:0;background:var(--game-accent-subtle);opacity:0;transition:opacity .2s}
    .tab-link:hover::before{opacity:1}
    .tab-link:hover{border-color:rgba(96,80,200,.35);transform:translateY(-2px);box-shadow:var(--shadow-md)}
    .tab-link.active{border-color:var(--game-accent);box-shadow:0 0 0 1px var(--game-accent),0 4px 20px rgba(96,80,200,.15)}
    .tab-link.active::before{opacity:1}
    .tab-link.active::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--game-accent)}
    .tab-icon{width:30px;height:30px;border-radius:8px;background:var(--tag-bg);display:flex;align-items:center;justify-content:center;transition:background .2s;flex-shrink:0}
    .tab-link.active .tab-icon,.tab-link:hover .tab-icon{background:var(--game-accent-subtle)}
    .tab-link.active .tab-icon svg,.tab-link:hover .tab-icon svg{stroke:var(--game-accent)}
    .tab-label{font-size:13px;font-weight:600;color:var(--text-secondary);transition:color .2s;position:relative;z-index:1}
    .tab-link.active .tab-label,.tab-link:hover .tab-label{color:var(--text-primary)}
    .tab-meta{font-size:11px;color:var(--text-tertiary);position:relative;z-index:1}
    .tab-link.active .tab-meta{color:var(--game-accent)}
    .tab-count-badge{background:var(--game-accent);color:white;font-size:10px;font-weight:700;padding:1px 7px;border-radius:10px;position:absolute;top:8px;right:8px;z-index:2}

    .hero{position:relative;width:100%;height:400px;overflow:hidden;background:#04040a}
    .hero-artwork{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 30%}
    .hero-cover-blur{position:absolute;inset:-40px;background-size:cover;background-position:center 20%;filter:blur(28px) saturate(1.6) brightness(.5);transform:scale(1.15);display:none}
    .hero-cover-blur.visible{display:block}
    .hero-side-fade{position:absolute;inset:0;background:var(--hero-side)}
    .hero-overlay{position:absolute;inset:0;background:var(--hero-overlay)}

    .page{max-width:980px;margin:0 auto;padding:0 28px 100px}

    .game-header{display:flex;gap:24px;align-items:flex-end;margin-top:-100px;margin-bottom:28px;position:relative;z-index:2}
    .cover-img{width:130px;height:173px;border-radius:12px;object-fit:cover;border:1px solid rgba(96,80,200,.4);box-shadow:0 12px 40px rgba(0,0,0,.8),0 0 32px rgba(96,80,200,.2);display:block;flex-shrink:0}
    .cover-placeholder{width:130px;height:173px;border-radius:12px;background:var(--bg-card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:48px;flex-shrink:0}
    .game-info{flex:1;min-width:0;padding-bottom:4px}
    .game-title{font-family:'Cinzel',serif;font-size:32px;line-height:1.1;letter-spacing:.04em;margin-bottom:8px;font-weight:600;text-shadow:0 2px 20px rgba(0,0,0,.6)}
    .meta-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:10px}
    .meta-tag{font-size:13px;color:var(--text-secondary)}
    .meta-sep{color:var(--text-tertiary);font-size:10px}
    .meta-link{font-size:13px;color:var(--text-secondary);transition:color .15s}
    .meta-link:hover{color:var(--text-primary);text-decoration:underline;text-underline-offset:3px}
    .platform-list{display:flex;flex-wrap:wrap;gap:5px}
    .platform-tag{background:var(--tag-bg);color:var(--tag-text);font-size:11px;font-weight:500;padding:3px 10px;border-radius:6px;border:1px solid var(--border)}

    .score-hero{display:flex;align-items:center;gap:24px;padding:20px 24px;background:var(--bg-card);border:1px solid var(--border);border-radius:16px;margin-bottom:28px;position:relative;overflow:hidden}
    .score-hero::before{content:'';position:absolute;inset:0;background:var(--game-accent-subtle);pointer-events:none}
    .score-hero::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--game-accent),transparent);opacity:.6}
    .avg-score-num{font-family:'Century Schoolbook','New Century Schoolbook',Georgia,serif;font-size:72px;line-height:1;font-weight:700;position:relative;z-index:1;letter-spacing:-3px}
    .score-great-color{color:var(--score-great)}
    .score-good-color{color:var(--score-good)}
    .score-mid-color{color:var(--score-mid)}
    .score-low-color{color:var(--score-low)}
    .score-divider{width:1px;height:56px;background:var(--border);flex-shrink:0}
    .score-meta{flex:1;position:relative;z-index:1}
    .score-label{font-size:11px;font-weight:500;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.1em;margin-bottom:3px}
    .review-count-label{font-size:13px;color:var(--text-secondary);margin-bottom:12px}
    .score-dist{display:flex;gap:4px;align-items:flex-end;height:44px}
    .dist-bar-wrap{display:flex;flex-direction:column;align-items:center;gap:3px;flex:1;cursor:pointer}
    .dist-bar{width:100%;border-radius:4px 4px 0 0;min-height:4px;transition:opacity .15s,transform .15s}
    .dist-bar-wrap:hover .dist-bar{opacity:1!important;transform:scaleY(1.06);transform-origin:bottom}
    .dist-label{font-size:9px;color:var(--text-tertiary);font-weight:500}
    .write-review-btn{background:var(--game-accent);color:white;border:none;border-radius:22px;padding:10px 20px;font-size:13px;font-weight:500;font-family:inherit;cursor:pointer;transition:opacity .15s,transform .15s;white-space:nowrap;box-shadow:0 4px 24px rgba(96,80,200,.4);position:relative;z-index:1}
    .write-review-btn:hover{opacity:.9;transform:translateY(-1px)}

    .tab-panel{display:none}
    .tab-panel.active{display:block}

    /* TWO COLUMN — OVERVIEW */
    .two-col{display:grid;grid-template-columns:1fr 300px;gap:24px;align-items:start}
    @media(max-width:720px){.two-col{grid-template-columns:1fr}}
    .main-col{min-width:0}
    .sidebar-col{position:sticky;top:20px;display:flex;flex-direction:column;gap:14px}
    .section{margin-bottom:32px}
    .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
    .section-title{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--text-tertiary)}
    .section-count{font-size:12px;color:var(--text-tertiary)}

    .trailer-thumb{position:relative;width:100%;aspect-ratio:16/9;border-radius:14px;overflow:hidden;border:1px solid var(--border);cursor:pointer;background:#000}
    .trailer-bg{width:100%;height:100%;background:var(--bg-card);display:flex;align-items:center;justify-content:center;font-size:80px;opacity:.15}
    .trailer-play{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px}
    .play-circle{width:72px;height:72px;background:rgba(96,80,200,.18);backdrop-filter:blur(8px);border-radius:50%;display:flex;align-items:center;justify-content:center;border:1px solid rgba(96,80,200,.5);transition:all .2s}
    .trailer-thumb:hover .play-circle{background:rgba(96,80,200,.32);transform:scale(1.08)}
    .play-icon{width:0;height:0;border-top:12px solid transparent;border-bottom:12px solid transparent;border-left:18px solid white;margin-left:3px}
    .trailer-label{font-size:13px;color:rgba(255,255,255,.65)}
    .trailer-iframe-wrap{display:none;width:100%;aspect-ratio:16/9;border-radius:14px;overflow:hidden;border:1px solid var(--border)}
    .trailer-iframe-wrap iframe{width:100%;height:100%;border:none}
    .screenshots-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
    .screenshot{aspect-ratio:16/9;border-radius:10px;overflow:hidden;border:1px solid var(--border);cursor:pointer;transition:transform .2s,border-color .2s}
    .screenshot:hover{transform:scale(1.03);border-color:rgba(96,80,200,.4)}
    .screenshot img{width:100%;height:100%;object-fit:cover}
    .similar-scroll{display:flex;gap:10px;overflow-x:auto;padding-bottom:4px;scrollbar-width:thin}
    .similar-card{flex-shrink:0;width:100px;background:var(--bg-card);border:1px solid var(--border);border-radius:10px;overflow:hidden;transition:transform .15s;display:block}
    .similar-card:hover{transform:translateY(-3px)}
    .similar-cover{aspect-ratio:3/4;background:var(--tag-bg);overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:24px}
    .similar-cover img{width:100%;height:100%;object-fit:cover}
    .similar-info{padding:6px 8px 8px}
    .similar-title{font-size:10px;font-weight:500;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;color:var(--text-secondary)}

    /* SIDEBAR */
    .desc-card{background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:16px}
    .desc-text{font-size:13px;line-height:1.75;color:var(--text-secondary);display:-webkit-box;-webkit-line-clamp:6;-webkit-box-orient:vertical;overflow:hidden}
    .desc-text.expanded{display:block}
    .read-more-btn{background:none;border:none;font-family:inherit;font-size:12px;color:var(--game-accent);cursor:pointer;padding:8px 0 0;display:block;font-weight:500}
    .details-card{background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:4px 16px}
    .detail-row{display:flex;gap:10px;padding:10px 0;border-bottom:1px solid var(--border-subtle);font-size:12px}
    .detail-row:last-child{border-bottom:none}
    .detail-label{flex-shrink:0;width:76px;color:var(--text-tertiary);padding-top:1px;text-transform:uppercase;letter-spacing:.06em;font-size:10px;font-weight:500}
    .detail-value{color:var(--text-secondary);line-height:1.5;flex:1}
    .tag-list{display:flex;flex-wrap:wrap;gap:4px}
    .tag{background:var(--tag-bg);color:var(--tag-text);font-size:11px;padding:2px 7px;border-radius:4px;border:1px solid var(--border)}

    /* REVIEWS */
    .reviews-toolbar{display:flex;gap:6px;margin-bottom:20px}
    .sort-tab{background:var(--tag-bg);color:var(--text-tertiary);border:1px solid var(--border);border-radius:20px;padding:5px 14px;font-size:11px;font-weight:500;font-family:inherit;cursor:pointer;transition:all .15s;text-transform:uppercase;letter-spacing:.04em}
    .sort-tab.active{background:var(--game-accent);color:white;border-color:transparent}
    .review-card{padding:22px 0;border-bottom:1px solid var(--border-subtle)}
    .review-card:last-child{border-bottom:none}
    .review-top{display:flex;align-items:center;gap:10px;margin-bottom:12px}
    .avatar{width:34px;height:34px;border-radius:50%;background:var(--bg-hover);border:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:var(--text-tertiary);overflow:hidden}
    .avatar img{width:100%;height:100%;object-fit:cover}
    .reviewer-info{flex:1;min-width:0}
    .reviewer-name{font-size:13px;font-weight:500;transition:color .15s}
    .reviewer-name:hover{color:var(--text-secondary)}
    .reviewer-meta{font-size:11px;color:var(--text-tertiary);display:flex;gap:6px;align-items:center;flex-wrap:wrap;margin-top:2px}
    .score-badge{flex-shrink:0;width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;font-family:'Century Schoolbook',Georgia,serif}
    .score-great{color:var(--score-great);background:var(--score-great-bg);border:1px solid rgba(74,222,128,.25)}
    .score-good{color:var(--score-good);background:var(--score-good-bg);border:1px solid rgba(96,165,250,.25)}
    .score-mid{color:var(--score-mid);background:var(--score-mid-bg);border:1px solid rgba(251,191,36,.25)}
    .score-low{color:var(--score-low);background:var(--score-low-bg);border:1px solid rgba(248,113,113,.25)}
    .review-title{font-family:'DM Serif Display',serif;font-size:18px;line-height:1.3;margin-bottom:8px;letter-spacing:-.2px}
    .review-body{font-size:14px;line-height:1.75;color:var(--text-secondary);display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
    .review-body.expanded{display:block}
    .review-footer{display:flex;align-items:center;gap:8px;margin-top:12px;flex-wrap:wrap}
    .footer-tag{background:var(--tag-bg);color:var(--tag-text);font-size:10px;font-weight:500;padding:2px 8px;border-radius:4px;text-transform:uppercase;letter-spacing:.04em;border:1px solid var(--border)}
    .expand-btn{font-size:11px;color:var(--game-accent);margin-left:auto;cursor:pointer;background:none;border:none;font-family:inherit;padding:0;font-weight:500}
    .spoiler-pill{display:inline-flex;align-items:center;gap:4px;background:rgba(251,191,36,.08);color:#fbbf24;font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px;margin-bottom:8px;text-transform:uppercase;letter-spacing:.06em;border:1px solid rgba(251,191,36,.2)}
    .empty-state{padding:60px 0;text-align:center;color:var(--text-tertiary)}
    .empty-title{font-family:'DM Serif Display',serif;font-size:20px;color:var(--text-secondary);margin-bottom:8px}
    .write-btn-empty{display:inline-block;margin-top:16px;background:var(--game-accent);color:white;border-radius:20px;padding:9px 20px;font-size:14px;font-weight:500}

    .lightbox{display:none;position:fixed;inset:0;z-index:100;background:rgba(0,0,0,.94);align-items:center;justify-content:center;backdrop-filter:blur(12px);cursor:pointer}
    .lightbox.open{display:flex}
    .lightbox-inner{max-width:90vw;max-height:90vh;border-radius:12px;overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,.9);cursor:default}
    .lightbox-inner img{width:100%;height:100%;object-fit:contain}

    @media(max-width:600px){
      .game-header{flex-direction:column;align-items:flex-start;margin-top:-60px}
      .game-title{font-size:26px}
      .hero{height:260px}
      .screenshots-grid{grid-template-columns:repeat(2,1fr)}
      .score-hero{flex-wrap:wrap;gap:16px}
      .avg-score-num{font-size:56px}
      .write-review-btn{width:100%;text-align:center}
      .tab-nav{grid-template-columns:1fr}
    }
  </style>
</head>
<body>

  <nav class="topnav">
    <a href="/" class="back-btn">
      <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8L10 4"/></svg>
      Back
    </a>
    <a href="/" class="logo"><span class="logo-dot"></span>Cartridge</a>
    <button class="theme-btn" onclick="toggleTheme()">
      <svg id="themeIcon" width="17" height="17" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="9" r="3.5"/>
        <path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>
      </svg>
    </button>
  </nav>

  <div class="hero">
    {!showCoverBlur && heroImageUrl ? (
      <img class="hero-artwork" src={heroImageUrl1x}
        srcset={`${heroImageUrl1x} 1920w, ${heroImageUrl} 3840w`} sizes="100vw"
        alt="" loading="eager"
        onerror="this.style.display='none';document.getElementById('heroCoverBlur').classList.add('visible')" />
    ) : null}
    <div class="hero-cover-blur" id="heroCoverBlur" style={showCoverBlur ? 'display:block' : ''}></div>
    <div class="hero-side-fade"></div>
    <div class="hero-overlay"></div>
  </div>

  <div class="page">

    <div class="game-header">
      {game.cover_img_url
        ? <img class="cover-img" src={igdbImage(game.cover_img_url, 't_cover_big') ?? ''} alt={game.title} loading="eager" />
        : <div class="cover-placeholder">🎮</div>
      }
      <div class="game-info">
        <h1 class="game-title">{game.title}</h1>
        <div class="meta-row">
          {releaseYear && <span class="meta-tag">{releaseYear}</span>}
          {developers.length > 0 && (<><span class="meta-sep">•</span>{developers.map((d: any) => (<a href={`/studios/${d.slug}`} class="meta-link">{d.name}</a>))}</>)}
          {genres.length > 0 && (<><span class="meta-sep">•</span><span class="meta-tag" style="color:var(--game-accent)">{genres[0].name}</span></>)}
        </div>
        <div class="platform-list">
          {platforms.map((p: any) => <span class="platform-tag">{p.name}</span>)}
        </div>
      </div>
    </div>

    {avgScore ? (
      <div class="score-hero">
        <div class={`avg-score-num ${scoreClass(parseFloat(avgScore))}-color`}>{avgScore}</div>
        <div class="score-divider"></div>
        <div class="score-meta">
          <div class="score-label">Cartridge Score</div>
          <div class="review-count-label">from {reviewList.length} {reviewList.length === 1 ? 'review' : 'reviews'}{avgHours ? ` · avg ${avgHours}h played` : ''}</div>
          <div class="score-dist" id="scoreDist"></div>
        </div>
        <a href={`/games/${game.slug}?tab=reviews`} class="write-review-btn">+ Write a review</a>
      </div>
    ) : (
      <div class="score-hero">
        <div class="score-meta">
          <div class="score-label">No reviews yet</div>
          <div class="review-count-label">Be the first to review {game.title}</div>
        </div>
        <a href={`/games/${game.slug}?tab=reviews`} class="write-review-btn">+ Write a review</a>
      </div>
    )}

    <!-- TAB BUTTONS -->
    <nav class="tab-nav">
      <a href={`/games/${game.slug}?tab=overview`} class={`tab-link ${activeTab === 'overview' ? 'active' : ''}`}>
        <div class="tab-icon">
          <svg width="15" height="15" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="6" height="6" rx="1.5"/><rect x="10" y="2" width="6" height="6" rx="1.5"/>
            <rect x="2" y="10" width="6" height="6" rx="1.5"/><rect x="10" y="10" width="6" height="6" rx="1.5"/>
          </svg>
        </div>
        <div class="tab-label">Overview</div>
        <div class="tab-meta">Info, trailer, screenshots</div>
      </a>
      <a href={`/games/${game.slug}?tab=reviews`} class={`tab-link ${activeTab === 'reviews' ? 'active' : ''}`}>
        {reviewList.length > 0 && <span class="tab-count-badge">{reviewList.length}</span>}
        <div class="tab-icon">
          <svg width="15" height="15" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 4h12M3 8h8M3 12h5"/>
          </svg>
        </div>
        <div class="tab-label">Reviews</div>
        <div class="tab-meta">{reviewList.length > 0 ? `${reviewList.length} reviews · avg ${avgScore ?? '—'}` : 'No reviews yet'}</div>
      </a>
      <a href={`/games/${game.slug}?tab=stats`} class={`tab-link ${activeTab === 'stats' ? 'active' : ''}`}>
        <div class="tab-icon">
          <svg width="15" height="15" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 14l4-5 3 3 3-4 4 6"/>
          </svg>
        </div>
        <div class="tab-label">Stats</div>
        <div class="tab-meta">Rankings &amp; comparisons</div>
      </a>
    </nav>

    <!-- ── OVERVIEW TAB ── -->
    <div class={`tab-panel ${activeTab === 'overview' ? 'active' : ''}`}>
      <div class="two-col">
        <div class="main-col">
          {trailerVideoId && (
            <div class="section">
              <div class="section-header"><span class="section-title">Trailer</span></div>
              <div class="trailer-thumb" id="trailerThumb" onclick="loadTrailer()">
                <div class="trailer-bg">🎮</div>
                <div class="trailer-play">
                  <div class="play-circle"><div class="play-icon"></div></div>
                  <div class="trailer-label">{game.title} — Official Trailer</div>
                </div>
              </div>
              <div class="trailer-iframe-wrap" id="trailerIframe">
                <iframe id="trailerPlayer" src="" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
              </div>
            </div>
          )}
          {igdbData?.screenshots?.length > 0 && (
            <div class="section">
              <div class="section-header">
                <span class="section-title">Screenshots</span>
                <span class="section-count">{igdbData.screenshots.length} screenshots</span>
              </div>
              <div class="screenshots-grid">
                {igdbData.screenshots.slice(0, 6).map((s: any, i: number) => (
                  <div class="screenshot" onclick={`openLightbox('${igdbImage(s.url, 't_1080p_2x')}')`}>
                    <img src={igdbImage(s.url, 't_screenshot_big') ?? ''}
                      srcset={`${igdbImage(s.url, 't_screenshot_big')} 889w, ${igdbImage(s.url, 't_screenshot_huge')} 1280w`}
                      sizes="(max-width:600px) 50vw, 33vw"
                      alt={`${game.title} screenshot ${i + 1}`} loading="lazy" />
                  </div>
                ))}
              </div>
            </div>
          )}
          {similarGames.length > 0 && (
            <div class="section">
              <div class="section-header"><span class="section-title">Similar games</span></div>
              <div class="similar-scroll">
                {similarGames.map((g: any) => (
                  <a href={g.slug ? `/games/${g.slug}` : '#'} class="similar-card">
                    <div class="similar-cover">
                      {g.cover?.url ? <img src={igdbImage(g.cover.url, 't_cover_big') ?? ''} alt={g.name} loading="lazy" /> : '🎮'}
                    </div>
                    <div class="similar-info"><div class="similar-title">{g.name}</div></div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

        <div class="sidebar-col">
          {game.game_description && (
            <div class="desc-card">
              <p class="desc-text" id="desc">{game.game_description}</p>
              <button class="read-more-btn" id="readMoreBtn" onclick="toggleDesc()">Read more →</button>
            </div>
          )}
          <div class="details-card">
            {releaseDate && (<div class="detail-row"><span class="detail-label">Released</span><span class="detail-value">{releaseDate}</span></div>)}
            {developers.length > 0 && (<div class="detail-row"><span class="detail-label">Developer</span><span class="detail-value">{developers.map((d: any) => d.name).join(', ')}</span></div>)}
            {publishers.length > 0 && (<div class="detail-row"><span class="detail-label">Publisher</span><span class="detail-value">{publishers.map((p: any) => p.name).join(', ')}</span></div>)}
            {genres.length > 0 && (<div class="detail-row"><span class="detail-label">Genres</span><div class="tag-list">{genres.map((g: any) => <span class="tag">{g.name}</span>)}</div></div>)}
            {igdbData?.themes?.length > 0 && (<div class="detail-row"><span class="detail-label">Themes</span><div class="tag-list">{igdbData.themes.map((t: any) => <span class="tag">{t.name}</span>)}</div></div>)}
            {igdbData?.game_modes?.length > 0 && (<div class="detail-row"><span class="detail-label">Modes</span><div class="tag-list">{igdbData.game_modes.map((m: any) => <span class="tag">{m.name}</span>)}</div></div>)}
            {igdbData?.game_engines?.length > 0 && (<div class="detail-row"><span class="detail-label">Engine</span><span class="detail-value">{igdbData.game_engines.map((e: any) => e.name).join(', ')}</span></div>)}
            {igdbData?.franchises?.length > 0 && (<div class="detail-row"><span class="detail-label">Franchise</span><span class="detail-value">{igdbData.franchises.map((f: any) => f.name).join(', ')}</span></div>)}
            {igdbData?.alternative_names?.length > 0 && (<div class="detail-row"><span class="detail-label">Also known as</span><span class="detail-value">{igdbData.alternative_names.slice(0, 3).map((a: any) => a.name).join(', ')}</span></div>)}
          </div>
        </div>
      </div>
    </div>

    <!-- ── REVIEWS TAB ── -->
    <div class={`tab-panel ${activeTab === 'reviews' ? 'active' : ''}`}>
      {reviewList.length === 0 ? (
        <div class="empty-state">
          <div class="empty-title">No reviews yet</div>
          <p style="font-size:14px;color:var(--text-tertiary)">Be the first to review {game.title}.</p>
          <a href="/" class="write-btn-empty">+ Write a review</a>
        </div>
      ) : (
        <>
          <div class="reviews-toolbar">
            <button class="sort-tab active" onclick="sortReviews('recent',this)">Recent</button>
            <button class="sort-tab" onclick="sortReviews('highest',this)">Highest</button>
            <button class="sort-tab" onclick="sortReviews('lowest',this)">Lowest</button>
          </div>
          <div id="reviewsList">
            {reviewList.map((review: any) => (
              <div class="review-card" data-score={review.score} data-date={review.published_at ?? review.created_at}>
                <div class="review-top">
                  <div class="avatar">
                    {review.profiles?.avatar_url ? <img src={review.profiles.avatar_url} alt={review.profiles.username} /> : getInitials(review.profiles?.username ?? '??')}
                  </div>
                  <div class="reviewer-info">
                    <a href={`/reviewers/${review.profiles?.username}`} class="reviewer-name">@{review.profiles?.username ?? 'unknown'}</a>
                    <div class="reviewer-meta">
                      <span>{timeAgo(review.published_at ?? review.created_at)}</span>
                      {review.played_on && <><span>·</span><span>{review.played_on.name}</span></>}
                      {review.play_time_hours && <><span>·</span><span>{review.play_time_hours}h</span></>}
                    </div>
                  </div>
                  <div class={`score-badge ${scoreClass(review.score)}`}>{review.score}</div>
                </div>
                {review.contains_spoilers && <div class="spoiler-pill">⚠ spoilers</div>}
                {review.title && <div class="review-title">{review.title}</div>}
                <div class="review-body" id={`body-${review.id}`}>{review.body}</div>
                <div class="review-footer">
                  {review.played_on && <span class="footer-tag">{review.played_on.name}</span>}
                  {review.play_time_hours && <span class="footer-tag">{review.play_time_hours}h played</span>}
                  <button class="expand-btn" onclick={`toggleReview('${review.id}',this)`}>Read more →</button>
                </div>
              </div>
            ))}
          </div>
        </>
      )}
    </div>

    <!-- ── STATS TAB ── -->
    <div class={`tab-panel ${activeTab === 'stats' ? 'active' : ''}`}>
      {reviewList.length === 0 ? (
        <div class="empty-state">
          <div class="empty-title">No stats yet</div>
          <p style="font-size:14px;color:var(--text-tertiary)">Stats will appear once reviews are submitted.</p>
        </div>
      ) : (
        <div id="statsContent"></div>
      )}
    </div>

  </div>

  <div class="lightbox" id="lightbox" onclick="closeLightbox()">
    <div class="lightbox-inner" onclick="event.stopPropagation()">
      <img id="lightboxImg" src="" alt="Screenshot" />
    </div>
  </div>

  <script define:vars={{ distJson, coverBlurUrl, trailerSrc, showCoverBlur, statsJson, activeTab }}>

    if (showCoverBlur) {
      var blur = document.getElementById('heroCoverBlur')
      if (blur) blur.style.backgroundImage = 'url(' + coverBlurUrl + ')'
    }

    // score dist bars
    var dist = JSON.parse(distJson)
    var maxVal = Math.max.apply(null, dist.concat([1]))
    var barColors = ['#f87171','#f87171','#fb923c','#fbbf24','#fbbf24','#60a5fa','#60a5fa','#4ade80','#4ade80','#4ade80']
    var container = document.getElementById('scoreDist')
    if (container) {
      dist.forEach(function(count, i) {
        var wrap = document.createElement('div'); wrap.className = 'dist-bar-wrap'
        wrap.title = 'Score ' + (i+1) + ': ' + count + ' reviews'
        var bar = document.createElement('div'); bar.className = 'dist-bar'
        bar.style.height = Math.max(4,(count/maxVal)*40)+'px'
        bar.style.background = barColors[i]; bar.style.opacity = '0.65'
        var label = document.createElement('div'); label.className = 'dist-label'
        label.textContent = String(i+1)
        wrap.appendChild(bar); wrap.appendChild(label); container.appendChild(wrap)
      })
    }

    function loadTrailer() {
      var thumb = document.getElementById('trailerThumb')
      var wrap = document.getElementById('trailerIframe')
      var player = document.getElementById('trailerPlayer')
      if (thumb) thumb.style.display = 'none'
      if (wrap) wrap.style.display = 'block'
      if (player) player.src = trailerSrc
    }
    window.loadTrailer = loadTrailer

    function openLightbox(src) {
      var lb = document.getElementById('lightbox')
      var img = document.getElementById('lightboxImg')
      if (lb && img) { img.src = src; lb.classList.add('open') }
    }
    function closeLightbox() {
      var lb = document.getElementById('lightbox')
      if (lb) lb.classList.remove('open')
    }
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeLightbox() })
    window.openLightbox = openLightbox; window.closeLightbox = closeLightbox

    function toggleReview(id, btn) {
      var body = document.getElementById('body-' + id)
      if (!body) return
      body.classList.toggle('expanded')
      btn.textContent = body.classList.contains('expanded') ? 'Read less ↑' : 'Read more →'
    }
    window.toggleReview = toggleReview

    function toggleDesc() {
      var desc = document.getElementById('desc')
      var btn = document.getElementById('readMoreBtn')
      if (!desc || !btn) return
      desc.classList.toggle('expanded')
      btn.textContent = desc.classList.contains('expanded') ? 'Read less ↑' : 'Read more →'
    }
    window.toggleDesc = toggleDesc

    function sortReviews(type, btn) {
      document.querySelectorAll('.sort-tab').forEach(function(b) { b.classList.remove('active') })
      btn.classList.add('active')
      var list = document.getElementById('reviewsList')
      if (!list) return
      var cards = Array.from(list.querySelectorAll('.review-card'))
      cards.sort(function(a, b) {
        if (type === 'highest') return parseInt(b.dataset.score) - parseInt(a.dataset.score)
        if (type === 'lowest') return parseInt(a.dataset.score) - parseInt(b.dataset.score)
        return new Date(b.dataset.date).getTime() - new Date(a.dataset.date).getTime()
      })
      cards.forEach(function(card) { list.appendChild(card) })
    }
    window.sortReviews = sortReviews

    // ── STATS — all inline styles so no dependency on external CSS classes ──
    var s = JSON.parse(statsJson)

    function css(obj) {
      return Object.entries(obj).map(function(e){return e[0]+':'+e[1]}).join(';')
    }

    var C = {
      card: 'background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:12px 14px;margin-bottom:10px;position:relative;overflow:hidden',
      cardNoMb: 'background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:12px 14px;position:relative;overflow:hidden',
      lbl: 'font-size:9px;font-weight:700;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.12em;margin-bottom:5px',
      sub: 'font-size:11px;color:var(--text-tertiary);margin-top:2px',
    }

    // score color helpers
    function scoreCol(score) {
      if (score >= 9) return '#4ade80'
      if (score >= 7) return '#60a5fa'
      if (score >= 5) return '#fbbf24'
      return '#f87171'
    }

    function buildStats() {
      var el = document.getElementById('statsContent')
      if (!el || !s.reviewCount) return

      var accent = 'var(--game-accent)'
      var accentSub = 'var(--game-accent-subtle)'
      var pieColors = ['#6050c8','#60a5fa','#4ade80','#fbbf24','#f87171']

      var html = ''

      // ── RANK CARDS — bold hero style ──
      var rankDefs = [
        { scope: 'All time', rank: s.allTimeRank, total: s.allTimeTotal, pct: 100 - s.allTimePct, hasData: s.allTimeTotal > 0, color: '#6050c8', glow: 'rgba(96,80,200,.3)' },
        { scope: s.genreName, rank: s.genreRank, total: s.genreTotal, pct: 100 - s.genrePct, hasData: s.genreTotal > 0, color: '#60a5fa', glow: 'rgba(96,165,250,.3)' },
        { scope: 'Released in ' + s.releaseYear, rank: s.yearRank, total: s.yearTotal, pct: 100 - s.yearPct, hasData: s.yearTotal > 0, color: '#4ade80', glow: 'rgba(74,222,128,.3)' },
      ]
      html += '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:10px">'
      rankDefs.forEach(function(rc) {
        html += '<div style="background:var(--bg-card);border:1px solid ' + rc.color + '44;border-radius:12px;padding:14px;position:relative;overflow:hidden">'
        html += '<div style="position:absolute;inset:0;background:linear-gradient(135deg,' + rc.color + '12 0%,transparent 65%);pointer-events:none"></div>'
        html += '<div style="font-size:9px;font-weight:700;color:' + rc.color + ';text-transform:uppercase;letter-spacing:.14em;margin-bottom:6px;position:relative;opacity:.85">' + rc.scope + '</div>'
        if (rc.hasData) {
          html += '<div style="display:flex;align-items:flex-start;gap:0;line-height:1;position:relative;margin-bottom:4px">'
          html += '<span style="font-size:16px;font-weight:800;color:' + rc.color + ';opacity:.6;margin-top:6px;margin-right:1px">#</span>'
          html += '<span style="font-family:\'DM Serif Display\',serif;font-size:52px;line-height:1;letter-spacing:-3px;color:' + rc.color + ';text-shadow:0 0 40px ' + rc.glow + '">' + rc.rank.toLocaleString() + '</span></div>'
          html += '<div style="font-size:11px;color:var(--text-tertiary);position:relative;margin-bottom:8px">of ' + rc.total.toLocaleString() + ' games</div>'
          html += '<div style="display:inline-flex;background:' + rc.color + '1a;color:' + rc.color + ';font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;border:1px solid ' + rc.color + '44;position:relative">Top ' + rc.pct + '%</div>'
        } else {
          html += '<div style="font-family:\'DM Serif Display\',serif;font-size:40px;line-height:1.1;color:var(--text-tertiary);opacity:.18;position:relative;margin-bottom:4px">—</div>'
          html += '<div style="font-size:11px;color:var(--text-tertiary);position:relative;opacity:.5">no data yet</div>'
        }
        html += '</div>'
      })
      html += '</div>'

      // ── PERCENTILE BARS ──
      html += '<div style="' + C.card + '">'
      html += '<div style="' + C.lbl + ';margin-bottom:10px">Percentile ranking</div>'
      var pctBars = [
        { label: 'All games', val: s.allTimePct, color: '#6050c8' },
        { label: s.genreName + ' genre', val: s.genrePct, color: '#60a5fa' },
        { label: s.releaseYear + ' releases', val: s.yearPct, color: '#4ade80' },
      ]
      pctBars.forEach(function(b, bi) {
        html += '<div style="margin-bottom:' + (bi < 2 ? '11' : '0') + 'px">'
        html += '<div style="display:flex;justify-content:space-between;margin-bottom:5px">'
        html += '<span style="font-size:12px;color:var(--text-secondary);font-weight:500">' + b.label + '</span>'
        html += '<span style="font-size:12px;color:' + b.color + ';font-weight:600">' + b.val + 'th</span></div>'
        html += '<div style="height:6px;background:var(--tag-bg);border-radius:3px;overflow:hidden">'
        html += '<div class="pct-anim" data-w="' + b.val + '" style="height:100%;border-radius:3px;width:0;transition:width 1.1s cubic-bezier(.4,0,.2,1);background:' + b.color + '"></div></div></div>'
      })
      html += '</div>'

      // ── STAT CARDS ──
      var topPlat = s.platformBreakdown && s.platformBreakdown[0]
      var statCards = [
        { lbl: 'Total hours logged', val: (s.totalHours || 0) + 'h', sub: 'across all reviewers', color: '#fbbf24' },
        { lbl: 'Avg hours played', val: (s.avgHours ? s.avgHours + 'h' : '—'), sub: 'per reviewer', color: '#fb923c' },
        { lbl: 'Most played on', val: topPlat ? topPlat.name.split(' ')[0] : '—', sub: topPlat ? topPlat.pct + '% of reviewers' : '', color: '#60a5fa', small: true },
        { lbl: 'Recommended', val: s.recommendedRate + '%', sub: 'rated 7 or above', color: s.recommendedRate >= 70 ? '#4ade80' : s.recommendedRate >= 50 ? '#fbbf24' : '#f87171' },
      ]
      html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">'
      statCards.forEach(function(sc) {
        html += '<div style="background:var(--bg-card);border:1px solid ' + sc.color + '33;border-radius:12px;padding:12px 14px;position:relative;overflow:hidden">'
        html += '<div style="position:absolute;inset:0;background:linear-gradient(135deg,' + sc.color + '0d 0%,transparent 70%);pointer-events:none"></div>'
        html += '<div style="' + C.lbl + ';color:' + sc.color + ';opacity:.8;position:relative">' + sc.lbl + '</div>'
        html += '<div style="font-family:\'DM Serif Display\',serif;font-size:' + (sc.small ? '22' : '30') + 'px;letter-spacing:-.5px;line-height:1;margin-bottom:2px;color:' + sc.color + ';position:relative">' + sc.val + '</div>'
        html += '<div style="font-size:11px;color:var(--text-tertiary);position:relative">' + sc.sub + '</div>'
        html += '</div>'
      })
      html += '</div>'

      // ── SCORES OVER TIME — bar chart with hover ──
      html += '<div style="' + C.card + '">'
      html += '<div style="' + C.lbl + ';margin-bottom:10px">Avg score by month <span style="font-size:9px;font-weight:400;color:var(--text-tertiary);text-transform:none;letter-spacing:0"> — hover for review count</span></div>'
      html += '<div id="scoreBarWrap" style="position:relative">'
      html += '<svg id="scoreBarChart" height="90" style="width:100%;overflow:visible;display:block"></svg>'
      html += '<div id="scoreBarTooltip" style="display:none;position:absolute;background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:6px 10px;font-size:12px;color:var(--text-primary);pointer-events:none;z-index:10;white-space:nowrap;box-shadow:0 4px 16px rgba(0,0,0,.4)"></div>'
      html += '</div></div>'

      // ── HOURS PLAYED DISTRIBUTION ──
      html += '<div style="' + C.card + '">'
      html += '<div style="' + C.lbl + ';margin-bottom:10px">Hours played distribution</div>'
      html += '<svg id="hoursDistChart" height="80" style="width:100%;overflow:visible;display:block"></svg>'
      html += '</div>'

      // ── SCORE BY PLATFORM ──
      if (s.platformBreakdown && s.platformBreakdown.length > 0 && s.platformScores) {
        html += '<div style="' + C.card + '">'
        html += '<div style="' + C.lbl + ';margin-bottom:10px">Score by platform</div>'
        s.platformScores.forEach(function(p) {
          var col = scoreCol(p.avg)
          html += '<div style="display:flex;align-items:center;gap:10px;padding:5px 0;border-bottom:1px solid var(--border-subtle)">'
          html += '<span style="font-size:12px;color:var(--text-secondary);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + p.name + '</span>'
          html += '<div style="flex:0 0 120px;height:6px;background:var(--tag-bg);border-radius:3px;overflow:hidden;position:relative">'
          html += '<div style="position:absolute;top:0;left:0;height:100%;border-radius:3px;background:' + col + ';width:' + (p.avg/10*100) + '%"></div></div>'
          html += '<span style="font-size:13px;font-weight:700;color:' + col + ';width:28px;text-align:right;flex-shrink:0">' + p.avg.toFixed(1) + '</span>'
          html += '<span style="font-size:10px;color:var(--text-tertiary);flex-shrink:0">(' + p.count + ')</span>'
          html += '</div>'
        })
        html += '</div>'
      }

      // ── PIE CHART — platforms ──
      if (s.platformBreakdown && s.platformBreakdown.length > 0) {
        html += '<div style="' + C.card + '">'
        html += '<div style="' + C.lbl + ';margin-bottom:10px">Played on</div>'
        html += '<div style="display:flex;align-items:center;gap:20px">'
        html += '<svg id="pieSvg" width="90" height="90" viewBox="0 0 90 90" style="flex-shrink:0"></svg>'
        html += '<div id="pieLegend" style="display:flex;flex-direction:column;gap:6px;flex:1;min-width:0"></div>'
        html += '</div></div>'
      }

      // ── GENRE COMPARISON ──
      if (s.genreAvgScore > 0) {
        var gameAvgNum = parseFloat(String(s.scoreDistribution
          ? (s.scoreDistribution.reduce(function(a,b,i){return a+(b*(i+1))},0) / Math.max(1,s.reviewCount)).toFixed(1)
          : s.genreAvgScore))
        var delta1 = (gameAvgNum - s.genreAvgScore).toFixed(1)
        var delta2 = s.recommendedRate - 72
        html += '<div style="' + C.card + ';margin-bottom:0">'
        html += '<div style="' + C.lbl + ';margin-bottom:8px">vs. ' + s.genreName + ' average</div>'
        html += '<div style="display:flex;gap:14px;margin-bottom:10px">'
        html += '<div style="display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text-tertiary)"><div style="width:8px;height:8px;border-radius:2px;background:#6050c8"></div>This game</div>'
        html += '<div style="display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text-tertiary)"><div style="width:8px;height:8px;border-radius:2px;background:var(--text-tertiary);opacity:.4"></div>Genre avg</div>'
        html += '</div>'
        function cmpRow(label, gamePct, avgPct, display, delta, suffix) {
          var dCls = parseFloat(delta) > 0 ? '#4ade80' : parseFloat(delta) < 0 ? '#f87171' : 'var(--text-tertiary)'
          var dStr = (parseFloat(delta) > 0 ? '+' : '') + delta + (suffix || '')
          return '<div style="display:flex;align-items:center;gap:12px;padding:7px 0;border-bottom:1px solid var(--border-subtle)">'
            + '<span style="font-size:12px;color:var(--text-secondary);width:110px;flex-shrink:0">' + label + '</span>'
            + '<div style="flex:1;position:relative;height:7px"><div style="position:absolute;inset:0;background:var(--tag-bg);border-radius:4px"></div>'
            + '<div style="position:absolute;top:0;left:0;height:100%;border-radius:4px;background:var(--text-tertiary);opacity:.35;width:' + Math.min(100,avgPct) + '%"></div>'
            + '<div style="position:absolute;top:0;left:0;height:100%;border-radius:4px;background:#6050c8;width:' + Math.min(100,gamePct) + '%"></div></div>'
            + '<span style="font-size:12px;font-weight:600;width:32px;text-align:right;flex-shrink:0;color:var(--text-primary)">' + display + '</span>'
            + '<span style="font-size:11px;width:42px;text-align:right;font-weight:700;flex-shrink:0;color:' + dCls + '">' + dStr + '</span>'
            + '</div>'
        }
        html += cmpRow('Avg score', gameAvgNum/10*100, s.genreAvgScore/10*100, gameAvgNum, delta1, '')
        html += cmpRow('Recommended', s.recommendedRate, 72, s.recommendedRate+'%', delta2, '%')
        html += '</div>'
      }

      el.innerHTML = html

      // animate pct bars
      setTimeout(function() {
        document.querySelectorAll('.pct-anim').forEach(function(el) { el.style.width = el.dataset.w + '%' })
      }, 100)

      // ── DRAW SCORES OVER TIME BAR CHART ──
      var scoreBarEl = document.getElementById('scoreBarChart')
      var tooltip = document.getElementById('scoreBarTooltip')
      if (scoreBarEl && s.monthLabels && s.monthCounts && s.monthAvgScores) {
        setTimeout(function() {
          var w = scoreBarEl.getBoundingClientRect().width || 400
          var chartH = 68, padL = 4, padR = 4
          var n = s.monthLabels.length
          var barW = Math.max(4, (w - padL - padR) / n - 4)
          var step = (w - padL - padR) / n

          // grid lines
          for (var gi = 0; gi <= 4; gi++) {
            var gy = chartH - (gi/4) * chartH
            var gval = (gi/4) * 10
            var gl = document.createElementNS('http://www.w3.org/2000/svg','line')
            gl.setAttribute('x1', padL); gl.setAttribute('x2', w - padR)
            gl.setAttribute('y1', gy); gl.setAttribute('y2', gy)
            gl.setAttribute('stroke','var(--border)'); gl.setAttribute('stroke-width','1')
            if (gi === 0 || gi === 4) gl.setAttribute('stroke-opacity','0.5')
            else gl.setAttribute('stroke-opacity','0.25')
            scoreBarEl.appendChild(gl)
            if (gi > 0 && gi < 4) {
              var gtxt = document.createElementNS('http://www.w3.org/2000/svg','text')
              gtxt.setAttribute('x', padL - 2); gtxt.setAttribute('y', gy + 3)
              gtxt.setAttribute('text-anchor','end'); gtxt.setAttribute('font-size','8')
              gtxt.setAttribute('fill','var(--text-tertiary)'); gtxt.setAttribute('font-family','DM Sans,sans-serif')
              gtxt.textContent = gval; scoreBarEl.appendChild(gtxt)
            }
          }

          s.monthLabels.forEach(function(lbl, i) {
            var avg = s.monthAvgScores[i]
            var cnt = s.monthCounts[i]
            if (!cnt || !avg) {
              // empty month tick
              var etxt = document.createElementNS('http://www.w3.org/2000/svg','text')
              etxt.setAttribute('x', padL + i*step + step/2); etxt.setAttribute('y', chartH + 16)
              etxt.setAttribute('text-anchor','middle'); etxt.setAttribute('font-size','9')
              etxt.setAttribute('fill','var(--text-tertiary)'); etxt.setAttribute('font-family','DM Sans,sans-serif')
              etxt.textContent = lbl; scoreBarEl.appendChild(etxt)
              return
            }
            var col = scoreCol(avg)
            var bh = Math.max(4, (avg / 10) * chartH)
            var bx = padL + i*step + (step - barW)/2
            var by = chartH - bh

            // bar
            var rect = document.createElementNS('http://www.w3.org/2000/svg','rect')
            rect.setAttribute('x', bx); rect.setAttribute('y', by)
            rect.setAttribute('width', barW); rect.setAttribute('height', bh)
            rect.setAttribute('rx','3'); rect.setAttribute('fill', col); rect.setAttribute('opacity','0.8')
            rect.style.cursor = 'pointer'
            rect.style.transition = 'opacity .15s'
            rect.addEventListener('mouseenter', (function(lbl, avg, cnt, bx, barW) {
              return function() {
                this.setAttribute('opacity','1')
                tooltip.style.display = 'block'
                tooltip.innerHTML = '<strong style="color:' + scoreCol(avg) + '">' + avg.toFixed(1) + '</strong>'
                  + ' avg · <span style="color:var(--text-secondary)">' + cnt + ' review' + (cnt !== 1 ? 's' : '') + '</span>'
                  + '<br><span style="color:var(--text-tertiary);font-size:10px">' + lbl + '</span>'
                var wrap = document.getElementById('scoreBarWrap')
                var wRect = wrap.getBoundingClientRect()
                var tLeft = bx + barW/2 - 60
                tLeft = Math.max(0, Math.min(tLeft, wRect.width - 140))
                tooltip.style.left = tLeft + 'px'
                tooltip.style.bottom = (90 - by + 8) + 'px'
              }
            })(lbl, avg, cnt, bx, barW))
            rect.addEventListener('mouseleave', function() {
              this.setAttribute('opacity','0.8')
              tooltip.style.display = 'none'
            })
            scoreBarEl.appendChild(rect)

            // score label above bar
            var stxt = document.createElementNS('http://www.w3.org/2000/svg','text')
            stxt.setAttribute('x', bx + barW/2); stxt.setAttribute('y', by - 4)
            stxt.setAttribute('text-anchor','middle'); stxt.setAttribute('font-size','9')
            stxt.setAttribute('fill', col); stxt.setAttribute('font-weight','600')
            stxt.setAttribute('font-family','DM Sans,sans-serif')
            stxt.textContent = avg.toFixed(1); scoreBarEl.appendChild(stxt)

            // month label
            var mtxt = document.createElementNS('http://www.w3.org/2000/svg','text')
            mtxt.setAttribute('x', bx + barW/2); mtxt.setAttribute('y', chartH + 16)
            mtxt.setAttribute('text-anchor','middle'); mtxt.setAttribute('font-size','9')
            mtxt.setAttribute('fill','var(--text-tertiary)'); mtxt.setAttribute('font-family','DM Sans,sans-serif')
            mtxt.textContent = lbl; scoreBarEl.appendChild(mtxt)
          })
        }, 60)
      }

      // ── DRAW HOURS DISTRIBUTION ──
      var hoursEl = document.getElementById('hoursDistChart')
      if (hoursEl && s.hoursDistribution) {
        setTimeout(function() {
          var w = hoursEl.getBoundingClientRect().width || 400
          var chartH = 58, padL = 4, padR = 4
          var buckets = s.hoursDistribution
          var n = buckets.length
          var barW = Math.max(4, (w - padL - padR) / n - 6)
          var step = (w - padL - padR) / n
          var maxVal = Math.max.apply(null, buckets.map(function(b){return b.count}).concat([1]))
          var hColors = ['#60a5fa','#818cf8','#a78bfa','#c084fc','#e879f9']

          buckets.forEach(function(b, i) {
            var bh = Math.max(0, (b.count / maxVal) * chartH)
            var bx = padL + i*step + (step - barW)/2
            var by = chartH - bh

            if (b.count > 0) {
              var rect = document.createElementNS('http://www.w3.org/2000/svg','rect')
              rect.setAttribute('x', bx); rect.setAttribute('y', by)
              rect.setAttribute('width', barW); rect.setAttribute('height', bh)
              rect.setAttribute('rx','3')
              rect.setAttribute('fill', hColors[i % hColors.length])
              rect.setAttribute('opacity','0.85')
              hoursEl.appendChild(rect)

              var cnt = document.createElementNS('http://www.w3.org/2000/svg','text')
              cnt.setAttribute('x', bx + barW/2); cnt.setAttribute('y', by - 3)
              cnt.setAttribute('text-anchor','middle'); cnt.setAttribute('font-size','9')
              cnt.setAttribute('fill', hColors[i % hColors.length]); cnt.setAttribute('font-weight','600')
              cnt.setAttribute('font-family','DM Sans,sans-serif')
              cnt.textContent = b.count; hoursEl.appendChild(cnt)
            }

            var lbl = document.createElementNS('http://www.w3.org/2000/svg','text')
            lbl.setAttribute('x', bx + barW/2); lbl.setAttribute('y', chartH + 14)
            lbl.setAttribute('text-anchor','middle'); lbl.setAttribute('font-size','8')
            lbl.setAttribute('fill','var(--text-tertiary)'); lbl.setAttribute('font-family','DM Sans,sans-serif')
            lbl.textContent = b.label; hoursEl.appendChild(lbl)
          })
        }, 60)
      }

      // ── PIE CHART ──
      if (s.platformBreakdown && s.platformBreakdown.length > 0) {
        var pieSvg = document.getElementById('pieSvg')
        var pieLegend = document.getElementById('pieLegend')
        var total = s.platformBreakdown.reduce(function(a,b){return a+b.count},0)
        var startAngle = -Math.PI/2
        var cx=45, cy=45, r=42

        s.platformBreakdown.forEach(function(p, i) {
          var angle = (p.count/total)*Math.PI*2
          var endAngle = startAngle + angle
          var x1=cx+r*Math.cos(startAngle), y1=cy+r*Math.sin(startAngle)
          var x2=cx+r*Math.cos(endAngle), y2=cy+r*Math.sin(endAngle)
          var large = angle>Math.PI?1:0
          var path = document.createElementNS('http://www.w3.org/2000/svg','path')
          path.setAttribute('d','M'+cx+','+cy+' L'+x1+','+y1+' A'+r+','+r+' 0 '+large+',1 '+x2+','+y2+' Z')
          path.setAttribute('fill', pieColors[i%pieColors.length])
          path.setAttribute('opacity','0.88')
          path.style.transition = 'opacity .15s,transform .15s'
          path.style.transformOrigin = cx+'px '+cy+'px'
          path.addEventListener('mouseenter',function(){this.setAttribute('opacity','1');this.style.transform='scale(1.04)'})
          path.addEventListener('mouseleave',function(){this.setAttribute('opacity','0.88');this.style.transform='scale(1)'})
          pieSvg.appendChild(path)
          startAngle = endAngle

          var item = document.createElement('div')
          item.style.cssText = 'display:flex;align-items:center;gap:8px;min-width:0'
          item.innerHTML = '<div style="width:10px;height:10px;border-radius:2px;flex-shrink:0;background:' + pieColors[i%pieColors.length] + '"></div>'
            + '<span style="font-size:12px;color:var(--text-secondary);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + p.name + '</span>'
            + '<span style="font-size:12px;color:var(--text-tertiary);font-weight:600;flex-shrink:0">' + p.pct + '%</span>'
          pieLegend.appendChild(item)
        })

        var hole = document.createElementNS('http://www.w3.org/2000/svg','circle')
        hole.setAttribute('cx',cx);hole.setAttribute('cy',cy);hole.setAttribute('r',r*0.42)
        hole.setAttribute('fill','var(--bg-card)')
        pieSvg.appendChild(hole)
      }
    }

        if (activeTab === 'stats') buildStats()

    function toggleTheme() {
      var html = document.documentElement
      var next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light'
      html.setAttribute('data-theme', next)
      localStorage.setItem('theme', next)
      updateIcon(next)
      if (activeTab === 'stats') {
        var el = document.getElementById('statsContent')
        if (el) { el.innerHTML = ''; buildStats() }
      }
    }
    function updateIcon(theme) {
      var icon = document.getElementById('themeIcon')
      if (!icon) return
      icon.innerHTML = theme === 'dark'
        ? '<path d="M15 10.5A7 7 0 016.5 3a7 7 0 100 12 7 7 0 008.5-4.5z"/>'
        : '<circle cx="9" cy="9" r="3.5"/><path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>'
    }
    window.toggleTheme = toggleTheme

    var saved = localStorage.getItem('theme') ||
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
    document.documentElement.setAttribute('data-theme', saved)
    updateIcon(saved)

  </script>
</body>
</html>
