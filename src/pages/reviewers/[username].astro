<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@{reviewer.username} — Cartridge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    :root[data-theme="light"] {
      --bg:#f5f4f2;--bg-card:#ffffff;--bg-hover:#f4f3f0;
      --border:#e8e6e1;--border-subtle:#f0ede8;
      --text-primary:#141412;--text-secondary:#6b6860;--text-tertiary:#a09d98;
      --tag-bg:#f0ede8;--tag-text:#6b6860;
      --shadow:0 1px 3px rgba(0,0,0,.06);--shadow-md:0 4px 16px rgba(0,0,0,.1);
      --score-great:#1a6b3c;--score-great-bg:#eaf5ee;
      --score-good:#1a4a6b;--score-good-bg:#eaf0f5;
      --score-mid:#6b5a1a;--score-mid-bg:#f5f0ea;
      --score-low:#6b1a1a;--score-low-bg:#f5eaea;
      --accent:#4a3a8a;--accent-sub:rgba(74,58,138,.06);
    }
    :root[data-theme="dark"] {
      --bg:#09090a;--bg-card:#131314;--bg-hover:#1c1c1e;
      --border:#222224;--border-subtle:#191919;
      --text-primary:#f0ede8;--text-secondary:#908d87;--text-tertiary:#484644;
      --tag-bg:#1c1c1e;--tag-text:#6a6866;
      --shadow:0 1px 3px rgba(0,0,0,.5);--shadow-md:0 4px 16px rgba(0,0,0,.7);
      --score-great:#4ade80;--score-great-bg:#0b2016;
      --score-good:#60a5fa;--score-good-bg:#0b1828;
      --score-mid:#fbbf24;--score-mid-bg:#201808;
      --score-low:#f87171;--score-low-bg:#200808;
      --accent:#6050c8;--accent-sub:rgba(96,80,200,.09);
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text-primary);min-height:100vh;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}

    .topnav{position:sticky;top:0;z-index:30;background:rgba(9,9,10,.85);border-bottom:1px solid var(--border);padding:13px 28px;display:flex;align-items:center;gap:16px;backdrop-filter:blur(20px)}
    [data-theme="light"] .topnav{background:rgba(245,244,242,.85)}
    .back-btn{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-tertiary);transition:color .15s}
    .back-btn:hover{color:var(--text-primary)}
    .logo{font-family:'DM Serif Display',serif;font-size:19px;display:flex;align-items:center;gap:7px;margin-left:auto}
    .logo-dot{width:6px;height:6px;background:var(--accent);border-radius:50%;box-shadow:0 0 10px var(--accent)}
    .theme-btn{background:none;border:none;cursor:pointer;color:var(--text-tertiary);padding:6px;display:flex;margin-left:8px;transition:color .15s}

    /* BANNER */
    .profile-banner{width:100%;height:200px;background:linear-gradient(135deg,#1a1030 0%,#0d1a2e 40%,#0a1a1a 100%);position:relative;overflow:hidden}
    [data-theme="light"] .profile-banner{background:linear-gradient(135deg,#e8e4f8 0%,#dce8f5 40%,#daf0f0 100%)}
    .banner-glow{position:absolute;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,var(--accent) 0%,transparent 70%);opacity:.15;top:-120px;right:5%}
    .banner-glow2{position:absolute;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,#60a5fa 0%,transparent 70%);opacity:.1;top:-60px;left:20%}
    .banner-edit-btn{position:absolute;bottom:12px;right:16px;display:flex;align-items:center;gap:7px;background:rgba(0,0,0,.55);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.2);color:white;font-size:12px;font-weight:500;font-family:'DM Sans',sans-serif;padding:7px 14px;border-radius:20px;cursor:pointer;transition:background .15s;z-index:2}
    .banner-edit-btn:hover{background:rgba(0,0,0,.75)}
    .banner-uploading{position:absolute;inset:0;background:rgba(0,0,0,.5);display:none;align-items:center;justify-content:center;gap:10px;z-index:3}

    /* AVATAR */
    .profile-header{max-width:980px;margin:0 auto;padding:0 28px;position:relative}
    .avatar-wrap{position:absolute;top:-52px;left:28px}
    .avatar-container{position:relative;width:104px;height:104px;border-radius:50%}
    .avatar-lg{width:104px;height:104px;border-radius:50%;background:var(--bg-card);border:4px solid var(--bg);display:flex;align-items:center;justify-content:center;font-family:'DM Serif Display',serif;font-size:36px;color:var(--text-secondary);overflow:hidden;box-shadow:0 0 0 2px var(--accent)}
    .avatar-lg img{width:100%;height:100%;object-fit:cover}
    .avatar-edit-overlay{position:absolute;inset:0;border-radius:50%;background:rgba(0,0,0,.55);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;opacity:0;transition:opacity .2s;cursor:pointer;border:4px solid transparent}
    .avatar-container:hover .avatar-edit-overlay{opacity:1}
    .avatar-edit-overlay span{font-size:10px;font-weight:600;color:white;text-transform:uppercase;letter-spacing:.08em}
    .avatar-uploading{position:absolute;inset:0;border-radius:50%;background:rgba(0,0,0,.7);display:flex;align-items:center;justify-content:center;display:none}
    .spinner{width:24px;height:24px;border:2px solid rgba(255,255,255,.3);border-top-color:white;border-radius:50%;animation:spin .7s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}

    /* PROFILE INFO */
    .profile-info-row{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;padding-top:62px;padding-bottom:20px}
    .profile-left{flex:1;min-width:0}
    .profile-username{font-family:'Cinzel',serif;font-size:28px;font-weight:600;letter-spacing:.04em;margin-bottom:6px}
    .profile-bio-wrap{margin-bottom:10px;max-width:480px}
    .profile-bio{font-size:14px;color:var(--text-secondary);line-height:1.6;cursor:text;border-radius:6px;padding:4px 6px;transition:background .15s;margin:-4px -6px}
    .profile-bio:hover{background:var(--tag-bg)}
    .profile-bio.editing{display:none}
    .bio-textarea{width:100%;font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.6;color:var(--text-primary);background:var(--bg-hover);border:1px solid var(--accent);border-radius:8px;padding:8px 10px;resize:none;outline:none;display:none}
    .bio-textarea.editing{display:block}
    .bio-actions{display:none;gap:8px;margin-top:6px}
    .bio-actions.editing{display:flex}
    .bio-empty{font-size:14px;color:var(--text-tertiary);font-style:italic;cursor:text;padding:4px 6px;border-radius:6px;transition:background .15s;display:inline-block}
    .bio-empty:hover{background:var(--tag-bg);color:var(--text-secondary)}
    .btn-sm{padding:5px 12px;border-radius:8px;font-size:12px;font-weight:500;font-family:inherit;cursor:pointer;border:none;transition:opacity .15s}
    .btn-sm-primary{background:var(--accent);color:white}
    .btn-sm-ghost{background:var(--tag-bg);color:var(--text-secondary)}
    .profile-stats-row{display:flex;align-items:center;gap:20px;flex-wrap:wrap}
    .profile-stat{display:flex;flex-direction:column;gap:2px}
    .pstat-val{font-family:'DM Serif Display',serif;font-size:20px;letter-spacing:-.3px;line-height:1}
    .pstat-lbl{font-size:10px;font-weight:600;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.1em}
    .profile-since{font-size:12px;color:var(--text-tertiary);align-self:center}
    .follow-btn{padding:9px 22px;border-radius:22px;font-size:13px;font-weight:500;font-family:inherit;cursor:pointer;transition:all .15s;border:none}
    .follow-btn.not-following{background:var(--accent);color:white;box-shadow:0 4px 16px rgba(96,80,200,.35)}
    .follow-btn.not-following:hover{opacity:.88;transform:translateY(-1px)}
    .follow-btn.following{background:var(--tag-bg);color:var(--text-secondary);border:1px solid var(--border)}
    .follow-btn.following:hover{border-color:#c0392b;color:#c0392b}

    /* TABS */
    .page{max-width:980px;margin:0 auto;padding:20px 28px 80px}
    .tab-nav{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:24px}
    .tab-link{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:14px 12px;background:var(--bg-card);border:1px solid var(--border);border-radius:14px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden;text-decoration:none}
    .tab-link::before{content:'';position:absolute;inset:0;background:var(--accent-sub);opacity:0;transition:opacity .2s}
    .tab-link:hover::before,.tab-link.active::before{opacity:1}
    .tab-link:hover{border-color:rgba(96,80,200,.35);transform:translateY(-2px);box-shadow:var(--shadow-md)}
    .tab-link.active{border-color:var(--accent);box-shadow:0 0 0 1px var(--accent),0 4px 20px rgba(96,80,200,.15)}
    .tab-link.active::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent)}
    .tab-icon{width:28px;height:28px;border-radius:8px;background:var(--tag-bg);display:flex;align-items:center;justify-content:center}
    .tab-link.active .tab-icon,.tab-link:hover .tab-icon{background:var(--accent-sub)}
    .tab-link.active .tab-icon svg,.tab-link:hover .tab-icon svg{stroke:var(--accent)}
    .tab-label{font-size:13px;font-weight:600;color:var(--text-secondary);position:relative;z-index:1;transition:color .2s}
    .tab-link.active .tab-label,.tab-link:hover .tab-label{color:var(--text-primary)}
    .tab-meta{font-size:11px;color:var(--text-tertiary);position:relative;z-index:1}
    .tab-link.active .tab-meta{color:var(--accent)}
    .tab-badge{background:var(--accent);color:white;font-size:10px;font-weight:700;padding:1px 7px;border-radius:10px;position:absolute;top:8px;right:8px;z-index:2}
    .tab-panel{display:none}
    .tab-panel.active{display:block}

    /* OVERVIEW */
    .two-col{display:grid;grid-template-columns:1fr 280px;gap:20px;align-items:start}
    @media(max-width:700px){.two-col{grid-template-columns:1fr}}
    .sidebar{display:flex;flex-direction:column;gap:14px}
    .card{background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:16px;margin-bottom:14px}
    .card:last-child{margin-bottom:0}
    .card-title{font-size:10px;font-weight:700;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.12em;margin-bottom:12px}

    /* FAVORITE GAME */
    .fav-game-card{background:var(--bg-card);border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:14px;position:relative;min-height:140px}
    .fav-game-bg{width:100%;height:150px;object-fit:cover;object-position:center 20%;display:block;opacity:.45}
    .fav-game-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,transparent 20%,rgba(13,13,15,.96) 75%)}
    .fav-game-content{position:absolute;bottom:0;left:0;right:0;padding:16px;display:flex;gap:14px;align-items:flex-end}
    .fav-cover{width:56px;height:75px;border-radius:8px;object-fit:cover;border:1px solid rgba(96,80,200,.4);box-shadow:0 4px 20px rgba(0,0,0,.8);flex-shrink:0}
    .fav-info{flex:1;min-width:0}
    .fav-label{font-size:9px;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:.14em;margin-bottom:4px;opacity:.85}
    .fav-title{font-family:'Cinzel',serif;font-size:17px;font-weight:600;letter-spacing:.04em;margin-bottom:4px;line-height:1.1;color:#f0ede8}
    .fav-review-blurb{font-size:12px;color:rgba(240,237,232,.6);line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .fav-score{flex-shrink:0;width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;font-family:'Century Schoolbook',Georgia,serif}
    .fav-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px;text-align:center;gap:10px;cursor:pointer;transition:background .15s;border-radius:14px}
    .fav-empty:hover{background:var(--bg-hover)}
    .fav-empty-icon{width:44px;height:44px;border-radius:12px;background:var(--tag-bg);border:1px dashed var(--border);display:flex;align-items:center;justify-content:center;font-size:20px;transition:border-color .15s}
    .fav-empty:hover .fav-empty-icon{border-color:var(--accent)}

    /* SHOWCASE */
    .showcase-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
    .showcase-item{aspect-ratio:3/4;border-radius:10px;overflow:hidden;border:1px solid var(--border);position:relative;transition:transform .2s,border-color .2s}
    .showcase-item:hover{transform:translateY(-3px);border-color:rgba(96,80,200,.5)}
    .showcase-item img{width:100%;height:100%;object-fit:cover;display:block}
    .showcase-remove{position:absolute;top:6px;right:6px;width:22px;height:22px;background:rgba(0,0,0,.7);border-radius:50%;display:none;align-items:center;justify-content:center;cursor:pointer;color:white;font-size:14px;line-height:1}
    .showcase-item:hover .showcase-remove{display:flex}
    .showcase-empty{background:var(--tag-bg);border:1px dashed var(--border);border-radius:10px;aspect-ratio:3/4;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:22px;cursor:pointer;transition:border-color .15s,background .15s;gap:6px}
    .showcase-empty:hover{border-color:var(--accent);background:var(--bg-hover)}
    .showcase-empty span{font-size:10px;color:var(--text-tertiary)}

    /* RECENT */
    .recent-game{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid var(--border-subtle)}
    .recent-game:last-child{border-bottom:none}
    .mini-cover{width:34px;height:45px;border-radius:5px;background:var(--tag-bg);overflow:hidden;flex-shrink:0;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:14px}
    .mini-cover img{width:100%;height:100%;object-fit:cover}
    .mini-score{flex-shrink:0;width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;font-family:'Century Schoolbook',Georgia,serif}
    .dist-mini{display:flex;gap:4px;align-items:flex-end;height:48px;margin-top:4px}
    .dist-col{display:flex;flex-direction:column;align-items:center;gap:2px;flex:1}
    .dist-bar{width:100%;border-radius:3px 3px 0 0;min-height:3px;opacity:.75}
    .dist-num{font-size:8px;color:var(--text-tertiary);margin-top:3px}

    /* REVIEWS */
    .sort-tabs{display:flex;gap:6px;margin-bottom:16px}
    .sort-tab{background:var(--tag-bg);color:var(--text-tertiary);border:1px solid var(--border);border-radius:20px;padding:5px 14px;font-size:11px;font-weight:500;font-family:inherit;cursor:pointer;transition:all .15s;text-transform:uppercase;letter-spacing:.04em}
    .sort-tab.active{background:var(--accent);color:white;border-color:transparent}
    .review-card{display:flex;gap:14px;padding:18px 0;border-bottom:1px solid var(--border-subtle)}
    .review-card:last-child{border-bottom:none}
    .game-cover{flex-shrink:0;width:48px;height:64px;border-radius:8px;background:var(--tag-bg);border:1px solid var(--border);overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:20px;transition:transform .15s}
    .game-cover:hover{transform:scale(1.06)}
    .game-cover img{width:100%;height:100%;object-fit:cover}
    .review-content{flex:1;min-width:0}
    .review-game-row{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:6px}
    .game-link{font-size:14px;font-weight:500;transition:color .15s;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .game-link:hover{color:var(--text-secondary)}
    .score-badge{flex-shrink:0;width:32px;height:32px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;font-family:'Century Schoolbook',Georgia,serif}
    .score-great{color:var(--score-great);background:var(--score-great-bg);border:1px solid rgba(74,222,128,.2)}
    .score-good{color:var(--score-good);background:var(--score-good-bg);border:1px solid rgba(96,165,250,.2)}
    .score-mid{color:var(--score-mid);background:var(--score-mid-bg);border:1px solid rgba(251,191,36,.2)}
    .score-low{color:var(--score-low);background:var(--score-low-bg);border:1px solid rgba(248,113,113,.2)}
    .review-title-text{font-family:'DM Serif Display',serif;font-size:16px;line-height:1.3;margin-bottom:5px}
    .review-body{font-size:14px;line-height:1.65;color:var(--text-secondary);display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
    .review-body.expanded{display:block}
    .review-meta{display:flex;align-items:center;gap:7px;margin-top:10px;flex-wrap:wrap}
    .meta-chip{font-size:10px;background:var(--tag-bg);color:var(--tag-text);padding:2px 8px;border-radius:5px;border:1px solid var(--border);text-transform:uppercase;letter-spacing:.04em;font-weight:500}
    .meta-time{font-size:11px;color:var(--text-tertiary);margin-left:auto}
    .spoiler-pill{display:inline-flex;align-items:center;gap:4px;background:rgba(251,191,36,.08);color:#fbbf24;font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px;margin-bottom:6px;text-transform:uppercase;letter-spacing:.06em;border:1px solid rgba(251,191,36,.2)}
    .expand-btn{font-size:11px;color:var(--accent);margin-left:auto;cursor:pointer;background:none;border:none;font-family:inherit;padding:0;font-weight:500}
    .empty-state{padding:60px 0;text-align:center;color:var(--text-tertiary)}
    .empty-title{font-family:'DM Serif Display',serif;font-size:20px;color:var(--text-secondary);margin-bottom:8px}

    /* GAME PICKER MODAL */
    .modal-backdrop{display:none;position:fixed;inset:0;z-index:100;background:rgba(0,0,0,.7);backdrop-filter:blur(8px);align-items:center;justify-content:center;padding:20px}
    .modal-backdrop.open{display:flex}
    .modal{background:var(--bg-card);border:1px solid var(--border);border-radius:20px;width:100%;max-width:520px;max-height:80vh;display:flex;flex-direction:column;box-shadow:0 24px 80px rgba(0,0,0,.8)}
    .modal-header{padding:20px 20px 0;display:flex;align-items:center;justify-content:space-between}
    .modal-title{font-family:'DM Serif Display',serif;font-size:20px;letter-spacing:-.2px}
    .modal-close{background:none;border:none;cursor:pointer;color:var(--text-tertiary);padding:6px;display:flex;transition:color .15s;font-size:20px;line-height:1}
    .modal-close:hover{color:var(--text-primary)}
    .modal-search{padding:16px 20px}
    .modal-search-input{width:100%;background:var(--bg-hover);border:1px solid var(--border);border-radius:10px;padding:10px 14px;font-size:14px;font-family:inherit;color:var(--text-primary);outline:none;transition:border-color .15s}
    .modal-search-input:focus{border-color:var(--accent)}
    .modal-search-input::placeholder{color:var(--text-tertiary)}
    .modal-results{flex:1;overflow-y:auto;padding:0 20px 20px;scrollbar-width:thin}
    .modal-result{display:flex;align-items:center;gap:12px;padding:10px;border-radius:10px;cursor:pointer;transition:background .15s}
    .modal-result:hover{background:var(--bg-hover)}
    .modal-result-cover{width:38px;height:50px;border-radius:6px;object-fit:cover;border:1px solid var(--border);flex-shrink:0;background:var(--tag-bg);display:flex;align-items:center;justify-content:center;font-size:16px;overflow:hidden}
    .modal-result-cover img{width:100%;height:100%;object-fit:cover}
    .modal-result-title{font-size:14px;font-weight:500;margin-bottom:2px}
    .modal-result-meta{font-size:12px;color:var(--text-tertiary)}
    .modal-empty{padding:32px;text-align:center;color:var(--text-tertiary);font-size:14px}
    .modal-loading{padding:32px;text-align:center;color:var(--text-tertiary);display:flex;align-items:center;justify-content:center;gap:10px}

    /* TOAST */
    .toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:10px 18px;font-size:13px;font-weight:500;box-shadow:var(--shadow-md);z-index:200;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap}
    .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
    .toast.success{border-color:rgba(74,222,128,.4);color:var(--score-great)}
    .toast.error{border-color:rgba(248,113,113,.4);color:var(--score-low)}

    @media(max-width:600px){
      .profile-username{font-size:22px}
      .page{padding:16px 16px 60px}
      .profile-header{padding:0 16px}
      .avatar-wrap{left:16px}
      .tab-nav{grid-template-columns:1fr}
    }
  </style>
</head>
<body>

<nav class="topnav">
  <a href="/" class="back-btn">
    <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8L10 4"/></svg>
    Back
  </a>
  <a href="/" class="logo"><span class="logo-dot"></span>Cartridge</a>
  <button class="theme-btn" onclick="toggleTheme()">
    <svg id="themeIcon" width="17" height="17" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="9" cy="9" r="3.5"/>
      <path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>
    </svg>
  </button>
</nav>

<div class="profile-banner" id="profileBanner" style={bannerStyle}>
  {!reviewer.banner_url && <div class="banner-glow"></div>}
  {!reviewer.banner_url && <div class="banner-glow2"></div>}
  {isOwnProfile && (
    <div class="banner-edit-btn" id="bannerEditBtn" onclick="document.getElementById('bannerInput').click()" title="Change banner image">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
      Change banner
    </div>
  )}
  {isOwnProfile && (
    <div class="banner-uploading" id="bannerUploading">
      <div class="spinner" style="width:20px;height:20px;border-width:2px;border-color:rgba(255,255,255,.3);border-top-color:white"></div>
      <span style="font-size:13px;color:white;font-weight:500">Uploading…</span>
    </div>
  )}
  {isOwnProfile && <input type="file" id="bannerInput" accept="image/jpeg,image/png,image/webp" style="display:none" />}
</div>

<div class="profile-header">
  <div class="avatar-wrap">
    <div class="avatar-container" id="avatarContainer">
      <div class="avatar-lg" id="avatarEl">
        {reviewer.avatar_url
          ? <img src={reviewer.avatar_url} alt={reviewer.username} id="avatarImg" />
          : <span id="avatarInitials">{getInitials(reviewer.username)}</span>
        }
      </div>
      {isOwnProfile && (
        <>
          <div class="avatar-edit-overlay" id="avatarOverlay" onclick="document.getElementById('avatarInput').click()">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
            <span>Change</span>
          </div>
          <div class="avatar-uploading" id="avatarUploading">
            <div class="spinner"></div>
          </div>
          <input type="file" id="avatarInput" accept="image/*" style="display:none" />
        </>
      )}
    </div>
  </div>

  <div class="profile-info-row">
    <div class="profile-left">
      <h1 class="profile-username">
        <span style="font-family:'DM Sans',sans-serif;font-weight:300;opacity:.6;font-size:.8em;letter-spacing:0">@</span>{reviewer.username}
      </h1>

      <div class="profile-bio-wrap">
        {isOwnProfile ? (
          <>
            <div class="profile-bio" id="bioDisplay" onclick="startEditBio()" title="Click to edit">
              {reviewer.bio || <span class="bio-empty">Add a bio…</span>}
            </div>
            <textarea
              class="bio-textarea"
              id="bioTextarea"
              rows={3}
              maxlength={300}
              placeholder="Tell people about yourself…"
            >{reviewer.bio ?? ''}</textarea>
            <div class="bio-actions" id="bioActions">
              <button class="btn-sm btn-sm-primary" onclick="saveBio()">Save</button>
              <button class="btn-sm btn-sm-ghost" onclick="cancelBio()">Cancel</button>
            </div>
          </>
        ) : (
          reviewer.bio && <p class="profile-bio">{reviewer.bio}</p>
        )}
      </div>

      <div class="profile-stats-row">
        <div class="profile-stat">
          <span class="pstat-val">{publishedReviews.length}</span>
          <span class="pstat-lbl">Reviews</span>
        </div>
        {avgScore && (
          <div class="profile-stat">
            <span class="pstat-val">{avgScore}</span>
            <span class="pstat-lbl">Avg score</span>
          </div>
        )}
        <div class="profile-stat">
          <span class="pstat-val" id="followerCount">{followerCount ?? 0}</span>
          <span class="pstat-lbl">Followers</span>
        </div>
        <div class="profile-stat">
          <span class="pstat-val">{followingCount ?? 0}</span>
          <span class="pstat-lbl">Following</span>
        </div>
        {totalHours > 0 && (
          <div class="profile-stat">
            <span class="pstat-val">{totalHours}h</span>
            <span class="pstat-lbl">Hours logged</span>
          </div>
        )}
        {memberSince && <div class="profile-since">Since {memberSince}</div>}
      </div>
    </div>

    <div>
      {!isOwnProfile && user && (
        <button
          class={`follow-btn ${isFollowing ? 'following' : 'not-following'}`}
          id="followBtn"
          data-reviewer-id={reviewer.id}
          data-following={isFollowing ? 'true' : 'false'}
        >
          {isFollowing ? 'Following' : '+ Follow'}
        </button>
      )}
      {!isOwnProfile && !user && (
        <a href="/signin" class="follow-btn not-following">+ Follow</a>
      )}
    </div>
  </div>
</div>

<div class="page">

  <nav class="tab-nav">
    <a href={`/reviewers/${reviewer.username}?tab=overview`} class={`tab-link ${activeTab === 'overview' ? 'active' : ''}`}>
      <div class="tab-icon">
        <svg width="14" height="14" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="6" height="6" rx="1.5"/><rect x="10" y="2" width="6" height="6" rx="1.5"/>
          <rect x="2" y="10" width="6" height="6" rx="1.5"/><rect x="10" y="10" width="6" height="6" rx="1.5"/>
        </svg>
      </div>
      <div class="tab-label">Overview</div>
      <div class="tab-meta">Activity &amp; recent games</div>
    </a>
    <a href={`/reviewers/${reviewer.username}?tab=reviews`} class={`tab-link ${activeTab === 'reviews' ? 'active' : ''}`}>
      {publishedReviews.length > 0 && <span class="tab-badge">{publishedReviews.length}</span>}
      <div class="tab-icon">
        <svg width="14" height="14" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 4h12M3 8h8M3 12h5"/>
        </svg>
      </div>
      <div class="tab-label">Reviews</div>
      <div class="tab-meta">{publishedReviews.length > 0 ? `${publishedReviews.length} reviews` : 'No reviews yet'}</div>
    </a>
    <a href={`/reviewers/${reviewer.username}?tab=stats`} class={`tab-link ${activeTab === 'stats' ? 'active' : ''}`}>
      <div class="tab-icon">
        <svg width="14" height="14" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 14l4-5 3 3 3-4 4 6"/>
        </svg>
      </div>
      <div class="tab-label">Stats</div>
      <div class="tab-meta">Scores &amp; patterns</div>
    </a>
  </nav>

  <!-- ── OVERVIEW TAB ── -->
  <div class={`tab-panel ${activeTab === 'overview' ? 'active' : ''}`}>
    <div class="two-col">
      <div>

        <!-- FAVORITE GAME -->
        {favGame ? (
          <div class="fav-game-card" id="favGameCard">
            <img class="fav-game-bg" src={igdbCover(favGame.cover_img_url, 't_screenshot_big') ?? ''} alt="" />
            <div class="fav-game-overlay"></div>
            <div class="fav-game-content">
              <a href={`/games/${favGame.slug}`}>
                <img class="fav-cover" src={igdbCover(favGame.cover_img_url) ?? ''} alt={favGame.title} />
              </a>
              <div class="fav-info">
                <div class="fav-label">⭐ Favorite game</div>
                <a href={`/games/${favGame.slug}`} class="fav-title">{favGame.title}</a>
                {favReview?.body && <div class="fav-review-blurb">"{favReview.body}"</div>}
              </div>
              {favReview && (
                <div class={`fav-score ${scoreClass(favReview.score)}`}>{favReview.score}</div>
              )}
            </div>
            {isOwnProfile && (
              <button
                onclick="openGamePicker('favorite')"
                style="position:absolute;top:10px;right:10px;background:rgba(0,0,0,.6);border:none;color:white;font-size:11px;font-family:inherit;padding:4px 10px;border-radius:8px;cursor:pointer;backdrop-filter:blur(4px)"
              >
                Change
              </button>
            )}
          </div>
        ) : isOwnProfile ? (
          <div class="fav-game-card">
            <div class="fav-empty" onclick="openGamePicker('favorite')">
              <div class="fav-empty-icon">⭐</div>
              <div style="font-size:14px;font-weight:500;color:var(--text-secondary)">Set a favorite game</div>
              <div style="font-size:12px;color:var(--text-tertiary)">The one game that defines you</div>
            </div>
          </div>
        ) : null}

        <!-- SHOWCASE -->
        <div class="card">
          <div class="card-title" style="display:flex;align-items:center;justify-content:space-between">
            <span>Showcase</span>
            {isOwnProfile && <span style="font-size:10px;color:var(--text-tertiary);font-weight:400;text-transform:none;letter-spacing:0">Click to edit</span>}
          </div>
          <div class="showcase-grid" id="showcaseGrid">
            <!-- Filled by JS from localStorage/server -->
            <div class="showcase-empty" onclick={isOwnProfile ? "openGamePicker('showcase',0)" : ''}>
              <span style="font-size:24px">+</span>
              <span>Add game</span>
            </div>
            <div class="showcase-empty" onclick={isOwnProfile ? "openGamePicker('showcase',1)" : ''}>
              <span style="font-size:24px">+</span>
              <span>Add game</span>
            </div>
            <div class="showcase-empty" onclick={isOwnProfile ? "openGamePicker('showcase',2)" : ''}>
              <span style="font-size:24px">+</span>
              <span>Add game</span>
            </div>
          </div>
        </div>

        <!-- SCORE DISTRIBUTION -->
        {publishedReviews.length > 0 && (
          <div class="card" style="margin-bottom:14px">
            <div class="card-title">Score distribution</div>
            <div class="dist-mini" id="distMini"></div>
          </div>
        )}

        <!-- ACTIVITY CHART -->
        {publishedReviews.length > 0 && (
          <div class="card">
            <div class="card-title">Review activity — last 12 months</div>
            <svg id="activityChart" height="70" style="width:100%;overflow:visible;display:block"></svg>
          </div>
        )}
      </div>

      <!-- SIDEBAR -->
      <div class="sidebar">
        {recentGames.length > 0 && (
          <div class="card">
            <div class="card-title">Recent reviews</div>
            {recentGames.map((game: any, i: number) => {
              const review = publishedReviews[i]
              return (
                <div class="recent-game">
                  <a href={`/games/${game.slug}`} class="mini-cover">
                    {game.cover_img_url
                      ? <img src={igdbCover(game.cover_img_url) ?? ''} alt={game.title} loading="lazy" />
                      : '🎮'
                    }
                  </a>
                  <a href={`/games/${game.slug}`} style="font-size:12px;font-weight:500;flex:1;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">{game.title}</a>
                  <div class={`mini-score ${scoreClass(review.score)}`}>{review.score}</div>
                </div>
              )
            })}
          </div>
        )}

        {platformBreakdown.length > 0 && (
          <div class="card">
            <div class="card-title">Platforms played on</div>
            {platformBreakdown.map((p) => (
              <div style="display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid var(--border-subtle)">
                <span style="font-size:12px;color:var(--text-secondary);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{p.name}</span>
                <div style="flex:0 0 60px;height:5px;background:var(--tag-bg);border-radius:3px;overflow:hidden">
                  <div style={`height:100%;width:${p.pct}%;background:#60a5fa;border-radius:3px;opacity:.8`}></div>
                </div>
                <span style="font-size:11px;color:var(--text-tertiary);flex-shrink:0">{p.pct}%</span>
              </div>
            ))}
          </div>
        )}

        {genreBreakdown.length > 0 && (
          <div class="card">
            <div class="card-title">Genres reviewed</div>
            {genreBreakdown.map((g) => (
              <div style="display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid var(--border-subtle)">
                <span style="font-size:13px;color:var(--text-secondary);flex:1">{g.name}</span>
                <div style="flex:0 0 60px;height:5px;background:var(--tag-bg);border-radius:3px;overflow:hidden">
                  <div style={`height:100%;width:${g.pct}%;background:var(--accent);border-radius:3px;opacity:.7`}></div>
                </div>
                <span style="font-size:12px;color:var(--text-tertiary);width:20px;text-align:right">{g.count}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- ── REVIEWS TAB ── -->
  <div class={`tab-panel ${activeTab === 'reviews' ? 'active' : ''}`}>
    {publishedReviews.length === 0 ? (
      <div class="empty-state">
        <div class="empty-title">No reviews yet</div>
        <p style="font-size:14px;color:var(--text-tertiary)">@{reviewer.username} hasn't posted any reviews.</p>
      </div>
    ) : (
      <>
        <div class="sort-tabs">
          <button class="sort-tab active" onclick="sortReviews('recent',this)">Recent</button>
          <button class="sort-tab" onclick="sortReviews('highest',this)">Highest</button>
          <button class="sort-tab" onclick="sortReviews('lowest',this)">Lowest</button>
        </div>
        <div id="reviewsList">
          {publishedReviews.map((review: any) => (
            <div class="review-card" data-score={review.score} data-date={review.published_at ?? review.created_at}>
              <a href={`/games/${review.games?.slug}`} class="game-cover">
                {review.games?.cover_img_url
                  ? <img src={igdbCover(review.games.cover_img_url) ?? ''} alt={review.games.title} loading="lazy" />
                  : '🎮'
                }
              </a>
              <div class="review-content">
                <div class="review-game-row">
                  <a href={`/games/${review.games?.slug}`} class="game-link">{review.games?.title ?? 'Unknown Game'}</a>
                  <div class={`score-badge ${scoreClass(review.score)}`}>{review.score}</div>
                </div>
                {review.contains_spoilers && <div class="spoiler-pill">⚠ spoilers</div>}
                {review.title && <div class="review-title-text">{review.title}</div>}
                <div class="review-body" id={`body-${review.id}`}>{review.body}</div>
                <div class="review-meta">
                  {review.played_on && <span class="meta-chip">{review.played_on.name}</span>}
                  {review.play_time_hours && <span class="meta-chip">{review.play_time_hours}h played</span>}
                  <span class="meta-time">{timeAgo(review.published_at ?? review.created_at)}</span>
                  <button class="expand-btn" onclick={`toggleReview('${review.id}',this)`}>Read more →</button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </>
    )}
  </div>

  <!-- ── STATS TAB ── -->
  <div class={`tab-panel ${activeTab === 'stats' ? 'active' : ''}`}>
    {publishedReviews.length === 0 ? (
      <div class="empty-state">
        <div class="empty-title">No stats yet</div>
        <p style="font-size:14px;color:var(--text-tertiary)">Stats appear once reviews are posted.</p>
      </div>
    ) : (
      <div id="statsContent"></div>
    )}
  </div>

</div>

<!-- GAME PICKER MODAL -->
<div class="modal-backdrop" id="gamePickerModal" onclick="closePickerOnBackdrop(event)">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="pickerTitle">Pick a game</div>
      <button class="modal-close" onclick="closePicker()">×</button>
    </div>
    <div class="modal-search">
      <input
        type="text"
        class="modal-search-input"
        id="pickerSearch"
        placeholder="Search games…"
        oninput="debouncedSearch(this.value)"
        autocomplete="off"
      />
    </div>
    <div class="modal-results" id="pickerResults">
      <div class="modal-empty">Start typing to search games…</div>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script define:vars={{ distJson, statsJson, activeTab, isOwnProfile: isOwnProfileJson, reviewerUsername: reviewer.username }}>

  var barColors = ['#f87171','#f87171','#fb923c','#fbbf24','#fbbf24','#60a5fa','#60a5fa','#4ade80','#4ade80','#4ade80']
  var s = JSON.parse(statsJson)
  var ownProfile = JSON.parse(isOwnProfile)

  // ── TOAST ──
  function showToast(msg, type) {
    var t = document.getElementById('toast')
    t.textContent = msg
    t.className = 'toast show ' + (type || '')
    clearTimeout(t._timer)
    t._timer = setTimeout(function() { t.className = 'toast' }, 2500)
  }

  // ── BANNER UPLOAD ──
  var bannerInput = document.getElementById('bannerInput')
  var bannerUploading = document.getElementById('bannerUploading')
  if (bannerInput) {
    bannerInput.addEventListener('change', async function() {
      var file = bannerInput.files[0]
      if (!file) return

      // 6MB check
      if (file.size > 6 * 1024 * 1024) {
        showToast('Banner must be under 6MB', 'error'); return
      }

      // dimension check — min 2048x1152
      var img = new Image()
      var objectUrl = URL.createObjectURL(file)
      img.onload = async function() {
        URL.revokeObjectURL(objectUrl)
        if (img.width < 2048 || img.height < 1152) {
          showToast('Banner must be at least 2048 × 1152 px', 'error')
          bannerInput.value = ''
          return
        }
        bannerUploading.style.display = 'flex'
        var form = new FormData()
        form.append('banner', file)
        try {
          var res = await fetch('/api/profile/banner', { method: 'POST', body: form })
          var data = await res.json()
          if (!res.ok) { showToast(data.error || 'Upload failed', 'error'); return }
          var banner = document.getElementById('profileBanner')
          if (banner) {
            banner.style.backgroundImage = 'url(' + data.url + ')'
            banner.style.backgroundSize = 'cover'
            banner.style.backgroundPosition = 'center'
            // hide gradient glows since we now have a real image
            banner.querySelectorAll('.banner-glow,.banner-glow2').forEach(function(el){ el.style.display='none' })
          }
          showToast('Banner updated', 'success')
        } catch(e) {
          showToast('Upload failed — try again', 'error')
        } finally {
          bannerUploading.style.display = 'none'
          bannerInput.value = ''
        }
      }
      img.onerror = function() {
        URL.revokeObjectURL(objectUrl)
        showToast('Could not read image', 'error')
        bannerInput.value = ''
      }
      img.src = objectUrl
    })
  }

  // ── AVATAR UPLOAD ──
  var avatarInput = document.getElementById('avatarInput')
  var avatarUploading = document.getElementById('avatarUploading')
  if (avatarInput) {
    avatarInput.addEventListener('change', async function() {
      var file = avatarInput.files[0]
      if (!file) return
      if (file.size > 5 * 1024 * 1024) { showToast('Image must be under 5MB', 'error'); return }
      avatarUploading.style.display = 'flex'
      var form = new FormData()
      form.append('avatar', file)
      try {
        var res = await fetch('/api/profile/avatar', { method: 'POST', body: form })
        if (!res.ok) throw new Error('Upload failed')
        var data = await res.json()
        var img = document.getElementById('avatarImg')
        var initials = document.getElementById('avatarInitials')
        if (img) { img.src = data.url + '?t=' + Date.now() }
        else {
          var el = document.getElementById('avatarEl')
          el.innerHTML = '<img id="avatarImg" src="' + data.url + '" alt="" style="width:100%;height:100%;object-fit:cover" />'
          if (initials) initials.remove()
        }
        showToast('Photo updated', 'success')
      } catch(e) {
        showToast('Upload failed — try again', 'error')
      } finally {
        avatarUploading.style.display = 'none'
        avatarInput.value = ''
      }
    })
  }

  // ── BIO EDIT ──
  var _origBio = ''
  function startEditBio() {
    if (!ownProfile) return
    var display = document.getElementById('bioDisplay')
    var textarea = document.getElementById('bioTextarea')
    var actions = document.getElementById('bioActions')
    _origBio = textarea.value
    display.classList.add('editing')
    textarea.classList.add('editing')
    actions.classList.add('editing')
    textarea.focus()
    textarea.setSelectionRange(textarea.value.length, textarea.value.length)
  }
  function cancelBio() {
    var display = document.getElementById('bioDisplay')
    var textarea = document.getElementById('bioTextarea')
    var actions = document.getElementById('bioActions')
    textarea.value = _origBio
    display.classList.remove('editing')
    textarea.classList.remove('editing')
    actions.classList.remove('editing')
  }
  async function saveBio() {
    var textarea = document.getElementById('bioTextarea')
    var display = document.getElementById('bioDisplay')
    var actions = document.getElementById('bioActions')
    var newBio = textarea.value.trim()
    try {
      var res = await fetch('/api/profile/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bio: newBio })
      })
      if (!res.ok) throw new Error()
      display.textContent = newBio || ''
      if (!newBio) display.innerHTML = '<span class="bio-empty">Add a bio…</span>'
      display.classList.remove('editing')
      textarea.classList.remove('editing')
      actions.classList.remove('editing')
      showToast('Bio saved', 'success')
    } catch(e) {
      showToast('Failed to save bio', 'error')
    }
  }
  window.startEditBio = startEditBio
  window.cancelBio = cancelBio
  window.saveBio = saveBio

  // ── GAME PICKER MODAL ──
  var _pickerMode = 'favorite'  // 'favorite' or 'showcase'
  var _pickerSlot = 0
  var _searchTimer = null

  function openGamePicker(mode, slot) {
    _pickerMode = mode
    _pickerSlot = slot ?? 0
    var title = document.getElementById('pickerTitle')
    title.textContent = mode === 'favorite' ? 'Set favorite game' : 'Add to showcase'
    document.getElementById('pickerSearch').value = ''
    document.getElementById('pickerResults').innerHTML = '<div class="modal-empty">Start typing to search games…</div>'
    document.getElementById('gamePickerModal').classList.add('open')
    setTimeout(function() { document.getElementById('pickerSearch').focus() }, 100)
  }
  function closePicker() {
    document.getElementById('gamePickerModal').classList.remove('open')
  }
  function closePickerOnBackdrop(e) {
    if (e.target === document.getElementById('gamePickerModal')) closePicker()
  }
  window.openGamePicker = openGamePicker
  window.closePicker = closePicker
  window.closePickerOnBackdrop = closePickerOnBackdrop

  function debouncedSearch(q) {
    clearTimeout(_searchTimer)
    if (!q.trim()) {
      document.getElementById('pickerResults').innerHTML = '<div class="modal-empty">Start typing to search games…</div>'
      return
    }
    _searchTimer = setTimeout(function() { searchGames(q) }, 300)
  }
  window.debouncedSearch = debouncedSearch

  async function searchGames(q) {
    var resultsEl = document.getElementById('pickerResults')
    resultsEl.innerHTML = '<div class="modal-loading"><div class="spinner" style="width:18px;height:18px;border-width:2px"></div> Searching…</div>'
    try {
      var res = await fetch('/api/games/search?q=' + encodeURIComponent(q) + '&limit=10')
      if (!res.ok) throw new Error()
      var games = await res.json()
      if (!games.length) {
        resultsEl.innerHTML = '<div class="modal-empty">No games found for "' + q + '"</div>'
        return
      }
      resultsEl.innerHTML = ''
      games.forEach(function(game) {
        var item = document.createElement('div')
        item.className = 'modal-result'
        var coverUrl = game.cover_img_url
          ? game.cover_img_url.replace(/t_[a-z0-9_]+/, 't_cover_big')
          : null
        item.innerHTML = '<div class="modal-result-cover">'
          + (coverUrl ? '<img src="' + coverUrl + '" alt="" />' : '🎮')
          + '</div><div><div class="modal-result-title">' + game.title + '</div>'
          + '<div class="modal-result-meta">' + (game.date_released ? new Date(game.date_released).getFullYear() : '') + '</div></div>'
        item.onclick = function() { selectGame(game) }
        resultsEl.appendChild(item)
      })
    } catch(e) {
      resultsEl.innerHTML = '<div class="modal-empty">Search failed — try again</div>'
    }
  }

  async function selectGame(game) {
    closePicker()
    if (_pickerMode === 'favorite') {
      try {
        var res = await fetch('/api/profile/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ favorite_game_id: game.id })
        })
        if (!res.ok) throw new Error()
        showToast('Favorite game updated — reload to see changes', 'success')
        setTimeout(function() { location.reload() }, 1800)
      } catch(e) {
        showToast('Failed to update — try again', 'error')
      }
    } else {
      // showcase — store in localStorage for now
      var showcase = JSON.parse(localStorage.getItem('showcase_' + reviewerUsername) || '[]')
      while (showcase.length < 3) showcase.push(null)
      showcase[_pickerSlot] = { id: game.id, title: game.title, cover_img_url: game.cover_img_url, slug: game.slug }
      localStorage.setItem('showcase_' + reviewerUsername, JSON.stringify(showcase))
      renderShowcase(showcase)
      showToast('Added to showcase', 'success')
    }
  }

  function renderShowcase(showcase) {
    var grid = document.getElementById('showcaseGrid')
    if (!grid) return
    grid.innerHTML = ''
    for (var i = 0; i < 3; i++) {
      var game = showcase[i] ?? null
      var slot = document.createElement('div')
      if (game) {
        var coverUrl = game.cover_img_url
          ? game.cover_img_url.replace(/t_[a-z0-9_]+/, 't_cover_big')
          : null
        slot.className = 'showcase-item'
        slot.innerHTML = coverUrl
          ? '<img src="' + coverUrl + '" alt="' + game.title + '" />'
          : '<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:28px;background:var(--tag-bg)">🎮</div>'
        if (ownProfile) {
          var removeBtn = document.createElement('div')
          removeBtn.className = 'showcase-remove'
          removeBtn.innerHTML = '×'
          removeBtn.title = 'Remove'
            ; (function(idx) {
            removeBtn.onclick = function(e) {
              e.stopPropagation()
              var sc = JSON.parse(localStorage.getItem('showcase_' + reviewerUsername) || '[]')
              while (sc.length < 3) sc.push(null)
              sc[idx] = null
              localStorage.setItem('showcase_' + reviewerUsername, JSON.stringify(sc))
              renderShowcase(sc)
            }
          })(i)
          slot.appendChild(removeBtn)
          ; (function(idx) {
            slot.onclick = function() { openGamePicker('showcase', idx) }
          })(i)
        } else {
          slot.style.cursor = 'default'
          var link = document.createElement('a')
          link.href = '/games/' + game.slug
          link.style.cssText = 'position:absolute;inset:0'
          slot.appendChild(link)
        }
      } else {
        slot.className = 'showcase-empty'
        slot.innerHTML = '<span style="font-size:24px">+</span><span>Add game</span>'
        if (ownProfile) {
          ; (function(idx) { slot.onclick = function() { openGamePicker('showcase', idx) } })(i)
        } else {
          slot.style.display = 'none'
        }
      }
      grid.appendChild(slot)
    }
  }

  // init showcase from localStorage
  var savedShowcase = JSON.parse(localStorage.getItem('showcase_' + reviewerUsername) || 'null')
  if (savedShowcase) renderShowcase(savedShowcase)
  else if (!ownProfile) {
    // hide empty slots for non-owners if no showcase set
    document.querySelectorAll('.showcase-empty').forEach(function(el) {
      el.style.display = 'none'
    })
    var grid = document.getElementById('showcaseGrid')
    if (grid && !grid.querySelector('.showcase-item')) {
      grid.closest('.card').style.display = 'none'
    }
  }

  // ── SCORE DIST MINI BARS (overview) ──
  var dist = JSON.parse(distJson)
  var maxD = Math.max.apply(null, dist.concat([1]))
  var distEl = document.getElementById('distMini')
  if (distEl) {
    dist.forEach(function(count, i) {
      var col = document.createElement('div'); col.className = 'dist-col'
      var bar = document.createElement('div'); bar.className = 'dist-bar'
      bar.style.height = Math.max(3, (count/maxD)*40)+'px'
      bar.style.background = barColors[i]
      var num = document.createElement('div'); num.className = 'dist-num'
      num.textContent = i+1
      col.appendChild(bar); col.appendChild(num); distEl.appendChild(col)
    })
  }

  // ── ACTIVITY LINE CHART ──
  var actEl = document.getElementById('activityChart')
  if (actEl && s.monthLabels && s.monthCounts) {
    setTimeout(function() {
      var w = actEl.getBoundingClientRect().width || 500
      var chartH = 48, padL = 4, padR = 4
      var pts = s.monthCounts
      var n = pts.length
      var step = (w-padL-padR)/(n-1)
      var maxM = Math.max.apply(null, pts.concat([1]))
      var coords = pts.map(function(v,i){return [padL+i*step, chartH-(v/maxM)*chartH*0.85-4]})

      var aPath = 'M'+coords[0][0]+','+chartH+coords.map(function(c){return ' L'+c[0]+','+c[1]}).join('')+' L'+coords[n-1][0]+','+chartH+' Z'
      var area = document.createElementNS('http://www.w3.org/2000/svg','path')
      area.setAttribute('d',aPath); area.setAttribute('fill','var(--accent)'); area.setAttribute('opacity','0.1')
      actEl.appendChild(area)

      var lPath = 'M'+coords[0][0]+','+coords[0][1]+coords.slice(1).map(function(c){return ' L'+c[0]+','+c[1]}).join('')
      var line = document.createElementNS('http://www.w3.org/2000/svg','path')
      line.setAttribute('d',lPath); line.setAttribute('fill','none')
      line.setAttribute('stroke','var(--accent)'); line.setAttribute('stroke-width','2')
      line.setAttribute('stroke-linecap','round'); line.setAttribute('stroke-linejoin','round')
      actEl.appendChild(line)

      coords.forEach(function(c,i){
        var dot = document.createElementNS('http://www.w3.org/2000/svg','circle')
        dot.setAttribute('cx',c[0]); dot.setAttribute('cy',c[1])
        dot.setAttribute('r', pts[i]>0?'4':'2')
        dot.setAttribute('fill', pts[i]>0?'var(--accent)':'var(--border)')
        dot.setAttribute('stroke','var(--bg-card)'); dot.setAttribute('stroke-width','2')
        actEl.appendChild(dot)
        if (i % 3 === 0 || i === n-1) {
          var lbl = document.createElementNS('http://www.w3.org/2000/svg','text')
          lbl.setAttribute('x',c[0]); lbl.setAttribute('y',chartH+14)
          lbl.setAttribute('text-anchor','middle'); lbl.setAttribute('font-size','9')
          lbl.setAttribute('fill','var(--text-tertiary)'); lbl.setAttribute('font-family','DM Sans,sans-serif')
          lbl.textContent = s.monthLabels[i]; actEl.appendChild(lbl)
        }
      })
    }, 50)
  }

  // ── SORT REVIEWS ──
  function sortReviews(type, btn) {
    document.querySelectorAll('.sort-tab').forEach(function(b) { b.classList.remove('active') })
    btn.classList.add('active')
    var list = document.getElementById('reviewsList')
    if (!list) return
    var cards = Array.from(list.querySelectorAll('.review-card'))
    cards.sort(function(a, b) {
      if (type === 'highest') return parseInt(b.dataset.score) - parseInt(a.dataset.score)
      if (type === 'lowest') return parseInt(a.dataset.score) - parseInt(b.dataset.score)
      return new Date(b.dataset.date).getTime() - new Date(a.dataset.date).getTime()
    })
    cards.forEach(function(card) { list.appendChild(card) })
  }
  window.sortReviews = sortReviews

  function toggleReview(id, btn) {
    var body = document.getElementById('body-' + id)
    if (!body) return
    body.classList.toggle('expanded')
    btn.textContent = body.classList.contains('expanded') ? 'Read less ↑' : 'Read more →'
  }
  window.toggleReview = toggleReview

  // ── STATS TAB ──
  function scoreCol(score) {
    if (score >= 9) return '#4ade80'
    if (score >= 7) return '#60a5fa'
    if (score >= 5) return '#fbbf24'
    return '#f87171'
  }

  function buildStats() {
    var el = document.getElementById('statsContent')
    if (!el || !s.reviewCount) return
    var pieColors = ['#6050c8','#60a5fa','#4ade80','#fbbf24','#f87171']
    var html = ''

    var recColor = s.recommendedRate >= 70 ? '#4ade80' : s.recommendedRate >= 50 ? '#fbbf24' : '#f87171'
    html += '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:10px">'
    var heroStats = [
      { lbl: 'Reviews written', val: s.reviewCount, color: '#6050c8' },
      { lbl: 'Avg score given', val: s.avgScore || '—', color: scoreCol(parseFloat(s.avgScore||'0')) },
      { lbl: 'Avg hours played', val: s.avgHours ? s.avgHours+'h' : '—', color: '#fbbf24' },
      { lbl: 'Recommended', val: s.recommendedRate+'%', color: recColor },
    ]
    heroStats.forEach(function(hs) {
      html += '<div style="background:var(--bg-card);border:1px solid '+hs.color+'33;border-radius:12px;padding:12px 14px;position:relative;overflow:hidden">'
      html += '<div style="position:absolute;inset:0;background:linear-gradient(135deg,'+hs.color+'0d 0%,transparent 70%);pointer-events:none"></div>'
      html += '<div style="font-size:9px;font-weight:700;color:'+hs.color+';text-transform:uppercase;letter-spacing:.12em;margin-bottom:6px;opacity:.85;position:relative">'+hs.lbl+'</div>'
      html += '<div style="font-family:\'DM Serif Display\',serif;font-size:28px;letter-spacing:-.5px;line-height:1;color:'+hs.color+';position:relative">'+hs.val+'</div>'
      html += '</div>'
    })
    html += '</div>'

    html += '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:14px;margin-bottom:10px">'
    html += '<div style="font-size:9px;font-weight:700;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.12em;margin-bottom:12px">Score distribution</div>'
    html += '<div style="display:flex;gap:4px;align-items:flex-end;height:60px" id="statsDistRow"></div>'
    html += '</div>'

    html += '<div style="display:grid;grid-template-columns:3fr 2fr;gap:10px;margin-bottom:10px">'
    html += '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:14px">'
    html += '<div style="font-size:9px;font-weight:700;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.12em;margin-bottom:10px">Reviews over time — last 12 months</div>'
    html += '<svg id="statsLineChart" height="90" style="width:100%;overflow:visible;display:block"></svg>'
    html += '</div>'

    if (s.platformBreakdown && s.platformBreakdown.length > 0) {
      html += '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:14px;display:flex;flex-direction:column">'
      html += '<div style="font-size:9px;font-weight:700;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.12em;margin-bottom:10px">Platforms played</div>'
      html += '<div style="display:flex;flex-direction:column;align-items:center;gap:10px;flex:1;justify-content:center">'
      html += '<svg id="statsPieSvg" width="80" height="80" viewBox="0 0 80 80" style="flex-shrink:0"></svg>'
      html += '<div id="statsPieLegend" style="display:flex;flex-direction:column;gap:5px;width:100%"></div>'
      html += '</div></div>'
    }
    html += '</div>'

    if (s.genreBreakdown && s.genreBreakdown.length > 0) {
      var gColors = ['#6050c8','#60a5fa','#4ade80','#fbbf24','#f87171','#fb923c']
      html += '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:14px;margin-bottom:10px">'
      html += '<div style="font-size:9px;font-weight:700;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.12em;margin-bottom:12px">Genres reviewed</div>'
      s.genreBreakdown.forEach(function(g, i) {
        var col = gColors[i % gColors.length]
        html += '<div style="display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid var(--border-subtle)">'
        html += '<span style="font-size:12px;color:var(--text-secondary);flex:1">'+g.name+'</span>'
        html += '<div style="flex:0 0 120px;height:7px;background:var(--tag-bg);border-radius:4px;overflow:hidden"><div style="height:100%;border-radius:4px;background:'+col+';width:'+g.pct+'%;opacity:.8"></div></div>'
        html += '<span style="font-size:12px;font-weight:600;color:'+col+';width:20px;text-align:right">'+g.count+'</span></div>'
      })
      html += '</div>'
    }

    el.innerHTML = html

    // dist bars
    var distRow = document.getElementById('statsDistRow')
    if (distRow && s.scoreDistribution) {
      var maxVal = Math.max.apply(null, s.scoreDistribution.concat([1]))
      s.scoreDistribution.forEach(function(count, i) {
        var col = document.createElement('div')
        col.style.cssText = 'display:flex;flex-direction:column;align-items:center;gap:3px;flex:1'
        var bar = document.createElement('div')
        bar.style.cssText = 'width:100%;border-radius:3px 3px 0 0;min-height:3px;opacity:.75;background:'+barColors[i]+';height:'+Math.max(3,(count/maxVal)*52)+'px;transition:opacity .15s;cursor:default'
        bar.title = 'Score '+(i+1)+': '+count+' reviews'
        bar.onmouseenter = function(){this.style.opacity='1'}
        bar.onmouseleave = function(){this.style.opacity='.75'}
        var lbl = document.createElement('div')
        lbl.style.cssText = 'font-size:9px;color:var(--text-tertiary);margin-top:3px'
        lbl.textContent = i+1
        col.appendChild(bar); col.appendChild(lbl); distRow.appendChild(col)
      })
    }

    // line chart
    var lineEl = document.getElementById('statsLineChart')
    if (lineEl && s.monthLabels && s.monthCounts) {
      setTimeout(function() {
        var w = lineEl.getBoundingClientRect().width || 400
        var chartH = 72, padL = 4, padR = 4
        var pts = s.monthCounts
        var n = pts.length
        var step = (w-padL-padR)/(n-1)
        var maxM = Math.max.apply(null, pts.concat([1]))
        var coords = pts.map(function(v,i){return [padL+i*step, chartH-(v/maxM)*chartH*0.82-4]})
        for (var gi=0;gi<=2;gi++) {
          var gy = chartH-(gi/2)*chartH
          var gl = document.createElementNS('http://www.w3.org/2000/svg','line')
          gl.setAttribute('x1',padL);gl.setAttribute('x2',w-padR)
          gl.setAttribute('y1',gy);gl.setAttribute('y2',gy)
          gl.setAttribute('stroke','var(--border)');gl.setAttribute('stroke-width','1')
          lineEl.appendChild(gl)
        }
        var aPath = 'M'+coords[0][0]+','+chartH+coords.map(function(c){return ' L'+c[0]+','+c[1]}).join('')+' L'+coords[n-1][0]+','+chartH+' Z'
        var area = document.createElementNS('http://www.w3.org/2000/svg','path')
        area.setAttribute('d',aPath);area.setAttribute('fill','#6050c8');area.setAttribute('opacity','0.12')
        lineEl.appendChild(area)
        var lPath = 'M'+coords[0][0]+','+coords[0][1]+coords.slice(1).map(function(c){return ' L'+c[0]+','+c[1]}).join('')
        var line2 = document.createElementNS('http://www.w3.org/2000/svg','path')
        line2.setAttribute('d',lPath);line2.setAttribute('fill','none')
        line2.setAttribute('stroke','#6050c8');line2.setAttribute('stroke-width','2')
        line2.setAttribute('stroke-linecap','round');line2.setAttribute('stroke-linejoin','round')
        lineEl.appendChild(line2)
        coords.forEach(function(c,i) {
          var dot = document.createElementNS('http://www.w3.org/2000/svg','circle')
          dot.setAttribute('cx',c[0]);dot.setAttribute('cy',c[1])
          dot.setAttribute('r',pts[i]>0?'4':'2')
          dot.setAttribute('fill',pts[i]>0?'#6050c8':'var(--border)')
          dot.setAttribute('stroke','var(--bg-card)');dot.setAttribute('stroke-width','2')
          lineEl.appendChild(dot)
          if (pts[i]>0) {
            var txt = document.createElementNS('http://www.w3.org/2000/svg','text')
            txt.setAttribute('x',c[0]);txt.setAttribute('y',c[1]-8)
            txt.setAttribute('text-anchor','middle');txt.setAttribute('font-size','9')
            txt.setAttribute('fill','#6050c8');txt.setAttribute('font-family','DM Sans,sans-serif');txt.setAttribute('font-weight','600')
            txt.textContent = pts[i]; lineEl.appendChild(txt)
          }
          if (i % 2 === 0 || i === n-1) {
            var mlbl = document.createElementNS('http://www.w3.org/2000/svg','text')
            mlbl.setAttribute('x',c[0]);mlbl.setAttribute('y',chartH+16)
            mlbl.setAttribute('text-anchor','middle');mlbl.setAttribute('font-size','8')
            mlbl.setAttribute('fill','var(--text-tertiary)');mlbl.setAttribute('font-family','DM Sans,sans-serif')
            mlbl.textContent = s.monthLabels[i]; lineEl.appendChild(mlbl)
          }
        })
      }, 60)
    }

    // pie chart
    if (s.platformBreakdown && s.platformBreakdown.length > 0) {
      var pieSvg = document.getElementById('statsPieSvg')
      var pieLegend = document.getElementById('statsPieLegend')
      if (pieSvg && pieLegend) {
        var total = s.platformBreakdown.reduce(function(a,b){return a+b.count},0)
        var startAngle = -Math.PI/2
        var cx=40,cy=40,r=37
        s.platformBreakdown.forEach(function(p,i) {
          var angle = (p.count/total)*Math.PI*2
          var endAngle = startAngle+angle
          var x1=cx+r*Math.cos(startAngle),y1=cy+r*Math.sin(startAngle)
          var x2=cx+r*Math.cos(endAngle),y2=cy+r*Math.sin(endAngle)
          var large=angle>Math.PI?1:0
          var path=document.createElementNS('http://www.w3.org/2000/svg','path')
          path.setAttribute('d','M'+cx+','+cy+' L'+x1+','+y1+' A'+r+','+r+' 0 '+large+',1 '+x2+','+y2+' Z')
          path.setAttribute('fill',pieColors[i%pieColors.length]);path.setAttribute('opacity','0.85')
          pieSvg.appendChild(path); startAngle=endAngle
          var item=document.createElement('div')
          item.style.cssText='display:flex;align-items:center;gap:7px;min-width:0'
          item.innerHTML='<div style="width:8px;height:8px;border-radius:2px;flex-shrink:0;background:'+pieColors[i%pieColors.length]+'"></div>'
            +'<span style="font-size:11px;color:var(--text-secondary);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+p.name+'</span>'
            +'<span style="font-size:11px;color:var(--text-tertiary);font-weight:600">'+p.pct+'%</span>'
          pieLegend.appendChild(item)
        })
        var hole=document.createElementNS('http://www.w3.org/2000/svg','circle')
        hole.setAttribute('cx',cx);hole.setAttribute('cy',cy);hole.setAttribute('r',r*0.42)
        hole.setAttribute('fill','var(--bg-card)'); pieSvg.appendChild(hole)
      }
    }
  }

  if (activeTab === 'stats') buildStats()

  // ── THEME ──
  function toggleTheme() {
    var html = document.documentElement
    var next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light'
    html.setAttribute('data-theme', next)
    localStorage.setItem('theme', next)
    updateIcon(next)
    if (activeTab === 'stats') {
      var el = document.getElementById('statsContent')
      if (el) { el.innerHTML = ''; buildStats() }
    }
  }
  function updateIcon(theme) {
    var icon = document.getElementById('themeIcon')
    if (!icon) return
    icon.innerHTML = theme === 'dark'
      ? '<path d="M15 10.5A7 7 0 016.5 3a7 7 0 100 12 7 7 0 008.5-4.5z"/>'
      : '<circle cx="9" cy="9" r="3.5"/><path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>'
  }
  window.toggleTheme = toggleTheme

  var saved = localStorage.getItem('theme') ||
    (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
  document.documentElement.setAttribute('data-theme', saved)
  updateIcon(saved)

  // ── FOLLOW ──
  var followBtn = document.getElementById('followBtn')
  if (followBtn) {
    followBtn.addEventListener('click', async function() {
      var reviewerId = followBtn.dataset.reviewerId
      var currentlyFollowing = followBtn.dataset.following === 'true'
      followBtn.disabled = true
      var res = await fetch('/api/follows/toggle', {
        method: currentlyFollowing ? 'DELETE' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ following_id: reviewerId }),
      })
      if (res.ok) {
        var nowFollowing = !currentlyFollowing
        followBtn.dataset.following = nowFollowing ? 'true' : 'false'
        followBtn.textContent = nowFollowing ? 'Following' : '+ Follow'
        followBtn.className = 'follow-btn ' + (nowFollowing ? 'following' : 'not-following')
        var countEl = document.getElementById('followerCount')
        if (countEl) countEl.textContent = String(parseInt(countEl.textContent) + (nowFollowing ? 1 : -1))
      }
      followBtn.disabled = false
    })
  }

  document.querySelectorAll('.review-body').forEach(function(el) {
    el.addEventListener('click', function() { el.classList.remove('spoiler-hidden') })
  })

  // ESC to close modal
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closePicker()
  })
</script>
</body>
</html>
