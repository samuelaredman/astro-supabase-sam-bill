---
export const prerender = false;
import { createSupabaseServerClientFromContext } from '../../utils/database';

const supabase = createSupabaseServerClientFromContext(Astro);
const { username } = Astro.params;
const activeTab = Astro.url.searchParams.get('tab') || 'overview'

const { data: { user } } = await supabase.auth.getUser();

const { data: reviewer } = await (supabase as any)
  .from('profiles')
  .select(`
    id, username, avatar_url, bio, banner_url, created_at, is_active,
    favorite_game_id,
    favorite_game:favorite_game_id (
      id, title, slug, cover_img_url,
      reviews ( score, body, profile_id )
    ),
    reviews (
      id, score, title, body, published_at, created_at,
      contains_spoilers, play_time_hours, status,
      played_on:platform_played_on ( id, name, slug ),
      games ( id, title, slug, cover_img_url, game_genres(genres(id, name, slug)) )
    )
  `)
  .eq('username', username)
  .single();

if (!reviewer) return Astro.redirect('/404');

const publishedReviews = (reviewer.reviews ?? [])
  .filter((r: any) => r.status === 'published')
  .sort((a: any, b: any) =>
    new Date(b.published_at ?? b.created_at).getTime() -
    new Date(a.published_at ?? a.created_at).getTime()
  );

const avgScore = publishedReviews.length > 0
  ? (publishedReviews.reduce((sum: number, r: any) => sum + r.score, 0) / publishedReviews.length).toFixed(1)
  : null;

const totalHours = publishedReviews.reduce((sum: number, r: any) => sum + (r.play_time_hours ?? 0), 0)
const avgHours = publishedReviews.length > 0 ? Math.round(totalHours / publishedReviews.length) : null

const memberSince = reviewer.created_at
  ? new Date(reviewer.created_at).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  : null;

const { count: followerCount } = await (supabase as any)
  .from('follows').select('*', { count: 'exact', head: true }).eq('following_id', reviewer.id);

const { count: followingCount } = await (supabase as any)
  .from('follows').select('*', { count: 'exact', head: true }).eq('follower_id', reviewer.id);

let currentProfile: any = null;
let isFollowing = false;
let isOwnProfile = false;

if (user) {
  const { data: cp } = await (supabase as any)
    .from('profiles').select('id').eq('auth_user_id', user.id).single();
  currentProfile = cp;
  if (currentProfile) {
    isOwnProfile = currentProfile.id === reviewer.id;
    if (!isOwnProfile) {
      const { data: followRow } = await (supabase as any)
        .from('follows').select('id')
        .eq('follower_id', currentProfile.id).eq('following_id', reviewer.id).single();
      isFollowing = !!followRow;
    }
  }
}

// favorite game — find reviewer's own review of it
const favGame = reviewer.favorite_game ?? null
const favReview = favGame
  ? publishedReviews.find((r: any) => r.games?.id === favGame.id) ?? null
  : null

// stats
const scoreDistribution = Array.from({ length: 10 }, (_, i) =>
  publishedReviews.filter((r: any) => r.score === i + 1).length
)
const platCounts: Record<string, number> = {}
for (const r of publishedReviews) {
  const name = (r as any).played_on?.name ?? 'Unknown'
  platCounts[name] = (platCounts[name] ?? 0) + 1
}
const platformBreakdown = Object.entries(platCounts)
  .sort((a, b) => b[1] - a[1]).slice(0, 5)
  .map(([name, count]) => ({ name, count, pct: Math.round((count / publishedReviews.length) * 100) }))

const genreCounts: Record<string, number> = {}
for (const r of publishedReviews) {
  const genres = (r as any).games?.game_genres ?? []
  for (const gg of genres) {
    const name = gg.genres?.name
    if (name) genreCounts[name] = (genreCounts[name] ?? 0) + 1
  }
}
const genreBreakdown = Object.entries(genreCounts)
  .sort((a, b) => b[1] - a[1]).slice(0, 6)
  .map(([name, count]) => ({ name, count, pct: Math.round((count / publishedReviews.length) * 100) }))

const monthlyActivity: Record<string, number> = {}
for (const r of publishedReviews) {
  const d = new Date((r as any).published_at ?? (r as any).created_at)
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`
  monthlyActivity[key] = (monthlyActivity[key] ?? 0) + 1
}
const monthLabels: string[] = []
const monthCounts: number[] = []
for (let i = 11; i >= 0; i--) {
  const d = new Date()
  d.setMonth(d.getMonth() - i)
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`
  monthLabels.push(d.toLocaleDateString('en-US', { month: 'short' }))
  monthCounts.push(monthlyActivity[key] ?? 0)
}

const recommendedCount = publishedReviews.filter((r: any) => r.score >= 7).length
const recommendedRate = publishedReviews.length > 0 ? Math.round((recommendedCount / publishedReviews.length) * 100) : 0
const recentGames = publishedReviews.slice(0, 6).map((r: any) => r.games).filter(Boolean)

function igdbCover(url: string | null, size = 't_cover_big') {
  if (!url) return null
  const clean = url.startsWith('//') ? `https:${url}` : url
  return clean.replace(/t_[a-z0-9_]+/, size)
}
function timeAgo(dateStr: string): string {
  const diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
  if (diff < 60) return `${diff}s`;
  if (diff < 3600) return `${Math.floor(diff / 60)}m`;
  if (diff < 86400) return `${Math.floor(diff / 3600)}h`;
  if (diff < 604800) return `${Math.floor(diff / 86400)}d`;
  return `${Math.floor(diff / 604800)}w`;
}
function scoreClass(score: number): string {
  if (score >= 9) return 'score-great'
  if (score >= 7) return 'score-good'
  if (score >= 5) return 'score-mid'
  return 'score-low'
}
function getInitials(u: string): string { return u.slice(0, 2).toUpperCase() }

const bannerStyle = reviewer.banner_url
  ? `background-image:url(${reviewer.banner_url});background-size:cover;background-position:center`
  : ''

const distJson = JSON.stringify(scoreDistribution)
const statsJson = JSON.stringify({
  reviewCount: publishedReviews.length,
  avgScore, avgHours, totalHours, recommendedRate,
  platformBreakdown, genreBreakdown,
  monthLabels, monthCounts, scoreDistribution,
})
const isOwnProfileJson = JSON.stringify(isOwnProfile)
