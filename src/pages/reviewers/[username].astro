---
import { getSupabase } from '../../utils/database';

const supabase = getSupabase();
const { username } = Astro.params;

const { data: reviewer } = await (supabase as any)
  .from('profiles')
  .select('*, reviews(*, games(title, slug))')
  .eq('username', username)
  .single();

if (!reviewer) return Astro.redirect('/404');
---
<html>
  <head><title>{reviewer.username}'s Reviews</title></head>
  <body>
    <h1>{reviewer.username}</h1>
    <ul>
      {reviewer.reviews.map((review: any) => (
        <li>
          <a href={`/games/${review.games.slug}`}>{review.games.title}</a>
          — {review.score}/10
        </li>
      ))}
    </ul>
  </body>
</html>
