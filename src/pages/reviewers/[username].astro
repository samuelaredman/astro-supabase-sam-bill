---
import { supabase } from '../../lib/supabase'

const { username } = Astro.params

const { data: reviewer } = await supabase
  .from('profiles')
  .select('*, reviews(*, games(title, slug))')  // join their reviews + games
  .eq('username', username)
  .single()

if (!reviewer) return Astro.redirect('/404')
---

<html>
  <head><title>{reviewer.username}'s Reviews</title></head>
  <body>
    <h1>{reviewer.username}</h1>
    <ul>
      {reviewer.reviews.map(review => (
        <li>
          <a href={`/games/${review.games.slug}`}>{review.games.title}</a>
          — {review.score}/10
        </li>
      ))}
    </ul>
  </body>
</html>
