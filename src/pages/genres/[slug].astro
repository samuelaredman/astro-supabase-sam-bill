---
export const prerender = false;
import { getSupabase } from '../../utils/database'
import { igdbFetch } from '../../utils/igdb'

const supabase = getSupabase()

const { slug } = Astro.params;

const { data: genre } = await supabase
  .from('genres')
  .select('id, name, slug, igdb_id')
  .eq('slug', slug)
  .single()

if (!genre) return Astro.redirect('/404')

// fetch all games in this genre
const { data: gameGenres } = await supabase
  .from('game_genres')
  .select(`games(id, title, slug, cover_img_url, date_released)`)
  .eq('genre_id', genre.id)

const allGames = (gameGenres ?? [])
  .map((gg: any) => gg.games)
  .filter(Boolean)
  .sort((a: any, b: any) =>
    new Date(b.date_released ?? 0).getTime() - new Date(a.date_released ?? 0).getTime()
  )

const gameIds = allGames.map((g: any) => g.id)

// fetch review scores
const { data: reviewScores } = await supabase
  .from('reviews')
  .select('game_id, score')
  .in('game_id', gameIds.length > 0 ? gameIds : ['00000000-0000-0000-0000-000000000000'])
  .eq('status', 'published')

const reviewsByGame: Record<string, number[]> = {}
for (const r of reviewScores ?? []) {
  if (!reviewsByGame[r.game_id]) reviewsByGame[r.game_id] = []
  reviewsByGame[r.game_id].push(r.score)
}

function gameAvgScore(gameId: string): string | null {
  const scores = reviewsByGame[gameId]
  if (!scores || scores.length === 0) return null
  return (scores.reduce((a, b) => a + b, 0) / scores.length).toFixed(1)
}

function gameReviewCount(gameId: string): number {
  return reviewsByGame[gameId]?.length ?? 0
}

// overall stats
const allScores = Object.values(reviewsByGame).flat()
const overallAvg = allScores.length > 0
  ? (allScores.reduce((a, b) => a + b, 0) / allScores.length).toFixed(1)
  : null
const totalReviews = allScores.length

// top rated games — all games sorted by avg score (min 3 reviews)
const topRated = allGames
  .filter((g: any) => gameReviewCount(g.id) >= 3)
  .sort((a: any, b: any) => {
    const aScore = parseFloat(gameAvgScore(a.id) ?? '0')
    const bScore = parseFloat(gameAvgScore(b.id) ?? '0')
    return bScore - aScore
  })
  .slice(0, 25)

// most reviewed games
const mostReviewed = allGames
  .filter((g: any) => gameReviewCount(g.id) > 0)
  .sort((a: any, b: any) => gameReviewCount(b.id) - gameReviewCount(a.id))
  .slice(0, 25)

// group by year, top 25 per year sorted by score
const byYear: Record<number, any[]> = {}
for (const g of allGames) {
  const year = g.date_released ? new Date(g.date_released).getFullYear() : 0
  if (!byYear[year]) byYear[year] = []
  byYear[year].push(g)
}

const byYearSorted: Record<number, any[]> = {}
for (const [year, games] of Object.entries(byYear)) {
  byYearSorted[parseInt(year)] = (games as any[])
    .sort((a: any, b: any) => {
      const aScore = parseFloat(gameAvgScore(a.id) ?? '0')
      const bScore = parseFloat(gameAvgScore(b.id) ?? '0')
      return bScore - aScore
    })
    .slice(0, 25)
}

const years = Object.keys(byYearSorted)
  .map(Number)
  .filter(y => y > 0)
  .sort((a, b) => b - a)

// related genres — genres that frequently appear alongside this one
const { data: coGenreRows } = await supabase
  .from('game_genres')
  .select('genre_id')
  .in('game_id', gameIds.length > 0 ? gameIds.slice(0, 200) : ['00000000-0000-0000-0000-000000000000'])
  .neq('genre_id', genre.id)

const coGenreCounts: Record<string, number> = {}
for (const row of coGenreRows ?? []) {
  coGenreCounts[row.genre_id] = (coGenreCounts[row.genre_id] ?? 0) + 1
}

const topCoGenreIds = Object.entries(coGenreCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([id]) => id)

let relatedGenres: any[] = []
if (topCoGenreIds.length > 0) {
  const { data: relGenreRows } = await supabase
    .from('genres')
    .select('id, name, slug')
    .in('id', topCoGenreIds)
  relatedGenres = relGenreRows ?? []
}

// fetch IGDB genre details for summary/description
let igdbData: any = null
if (genre.igdb_id) {
  const [igdbGenre] = await igdbFetch('genres',
    `fields name, slug; where id = ${genre.igdb_id};`)
  igdbData = igdbGenre ?? null
}

// genre descriptions — manually curated for top genres
const genreDescriptions: Record<string, string> = {
  'role-playing-rpg': 'Role-playing games let players assume the roles of characters in a fictional world, typically featuring character progression, stat systems, and story-driven gameplay. From classic JRPGs to open-world western RPGs, the genre spans a vast range of styles united by player agency and character development.',
  'shooter': 'Shooter games center on ranged combat, typically from a first or third-person perspective. The genre ranges from arcade-style run-and-guns to tactical military simulations, with player skill and precision at the core of the experience.',
  'adventure': 'Adventure games prioritize exploration, story, and puzzle-solving over reflexes. They range from classic point-and-click mysteries to sprawling open-world narratives, often featuring rich worlds and compelling characters.',
  'platform': 'Platformers challenge players to navigate environments by jumping between platforms and avoiding obstacles. From Mario to Celeste, the genre has evolved from simple side-scrollers to complex precision challenges with deep movement systems.',
  'strategy': 'Strategy games challenge players to think tactically or plan long-term, whether in real time or turn-based. The genre includes everything from city builders to grand strategy simulations covering centuries of history.',
  'fighting': 'Fighting games pit players against each other in direct combat, rewarding mastery of complex move sets and frame-perfect timing. The genre has a rich competitive scene and a history stretching back to the early days of arcades.',
  'indie': 'Indie games are developed outside the major publisher system, often by small teams or solo developers. The label has become associated with creative risk-taking, unique aesthetics, and games that push against mainstream conventions.',
  'puzzle': 'Puzzle games challenge logic, spatial reasoning, or pattern recognition. From simple block-matching to mind-bending physics simulations, the genre rewards patience and lateral thinking over reaction time.',
  'arcade': 'Arcade games prioritize immediate, pick-up-and-play fun with simple controls and escalating difficulty. Rooted in the coin-op era, the style lives on in score-chasing games designed for short sessions with high replayability.',
  'sport': 'Sports games simulate or draw inspiration from real-world athletic competitions. From realistic simulations of football and basketball to stylized takes on skateboarding and golf, the genre covers a wide spectrum of athletic experiences.',
}

const genreDescription = genreDescriptions[genre.slug] ?? null

function igdbImage(url: string | null, size = 't_cover_big') {
  if (!url) return null
  return `https:${url.replace('t_thumb', size)}`
}

function scoreClass(score: number): string {
  if (score >= 9) return 'great'
  if (score >= 7) return 'good'
  if (score >= 5) return 'mid'
  return 'low'
}

function releaseYear(dateStr: string | null): string | null {
  if (!dateStr) return null
  return String(new Date(dateStr).getFullYear())
}

const overallScoreClass = overallAvg ? scoreClass(parseFloat(overallAvg)) : null

function serializeGames(games: any[]) {
  return games.map((g: any) => {
    const avg = gameAvgScore(g.id)
    const count = gameReviewCount(g.id)
    const sc = avg ? scoreClass(parseFloat(avg)) : null
    return {
      title: g.title,
      slug: g.slug,
      cover: igdbImage(g.cover_img_url),
      score: avg,
      badge: sc ? `badge-${sc}` : null,
      reviews: count > 0 ? `${count} ${count === 1 ? 'review' : 'reviews'}` : null,
      year: releaseYear(g.date_released),
    }
  })
}

const topRatedJson = JSON.stringify(serializeGames(topRated))
const mostReviewedJson = JSON.stringify(serializeGames(mostReviewed))
const byYearJson = JSON.stringify(
  years.reduce((acc: any, year: number) => {
    acc[year] = serializeGames(byYearSorted[year] ?? [])
    return acc
  }, {})
)
const yearsJson = JSON.stringify(years)
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{genre.name} Games — Cartridge</title>
  <meta name="description" content={genreDescription?.slice(0, 160) ?? `Browse the best ${genre.name} games and reviews on Cartridge.`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    :root[data-theme="light"] {
      --bg: #f5f4f2; --bg-card: #ffffff; --bg-hover: #f4f3f0;
      --border: #e8e6e1; --border-subtle: #f0ede8;
      --text-primary: #141412; --text-secondary: #6b6860; --text-tertiary: #a09d98;
      --tag-bg: #f0ede8; --tag-text: #6b6860;
      --shadow: 0 1px 3px rgba(0,0,0,0.06); --shadow-md: 0 4px 16px rgba(0,0,0,0.1);
      --score-great: #1a6b3c; --score-great-bg: #eaf5ee;
      --score-good: #1a4a6b;  --score-good-bg: #eaf0f5;
      --score-mid: #6b5a1a;   --score-mid-bg: #f5f0ea;
      --score-low: #6b1a1a;   --score-low-bg: #f5eaea;
      --game-accent: #4a3a8a; --game-accent-subtle: rgba(74,58,138,0.06);
      --hero-overlay: linear-gradient(to bottom,rgba(245,244,242,0)0%,rgba(245,244,242,.6)65%,rgba(245,244,242,1)100%);
    }
    :root[data-theme="dark"] {
      --bg: #09090a; --bg-card: #131314; --bg-hover: #1c1c1e;
      --border: #222224; --border-subtle: #191919;
      --text-primary: #f0ede8; --text-secondary: #908d87; --text-tertiary: #484644;
      --tag-bg: #1c1c1e; --tag-text: #6a6866;
      --shadow: 0 1px 3px rgba(0,0,0,.5); --shadow-md: 0 4px 16px rgba(0,0,0,.7);
      --score-great: #4ade80; --score-great-bg: #0b2016;
      --score-good: #60a5fa;  --score-good-bg: #0b1828;
      --score-mid: #fbbf24;   --score-mid-bg: #201808;
      --score-low: #f87171;   --score-low-bg: #200808;
      --game-accent: #6050c8; --game-accent-subtle: rgba(96,80,200,0.09);
      --hero-overlay: linear-gradient(to bottom,rgba(9,9,10,0)0%,rgba(9,9,10,.65)65%,rgba(9,9,10,1)100%);
    }

    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text-primary);min-height:100vh;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}

    .topnav{position:sticky;top:0;z-index:30;background:rgba(9,9,10,.88);border-bottom:1px solid var(--border);padding:13px 28px;display:flex;align-items:center;gap:16px;backdrop-filter:blur(20px)}
    [data-theme="light"] .topnav{background:rgba(245,244,242,.88)}
    .back-btn{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-tertiary);transition:color .15s}
    .back-btn:hover{color:var(--text-primary)}
    .logo{font-family:'DM Serif Display',serif;font-size:19px;letter-spacing:-.3px;display:flex;align-items:center;gap:7px;margin-left:auto}
    .logo-dot{width:6px;height:6px;background:var(--game-accent);border-radius:50%;box-shadow:0 0 10px var(--game-accent)}
    .theme-btn{background:none;border:none;cursor:pointer;color:var(--text-tertiary);padding:6px;display:flex;align-items:center;transition:color .15s;margin-left:8px}
    .theme-btn:hover{color:var(--text-primary)}

    .jump-nav{position:sticky;top:53px;z-index:20;background:rgba(9,9,10,.72);border-bottom:1px solid var(--border);backdrop-filter:blur(16px);display:flex;overflow-x:auto;scrollbar-width:none}
    .jump-nav::-webkit-scrollbar{display:none}
    [data-theme="light"] .jump-nav{background:rgba(245,244,242,.82)}
    .jump-link{font-size:11px;font-weight:500;color:var(--text-tertiary);padding:10px 20px;letter-spacing:.08em;text-transform:uppercase;transition:color .15s,border-color .15s;border-bottom:2px solid transparent;white-space:nowrap;flex-shrink:0}
    .jump-link:hover{color:var(--text-primary)}
    .jump-link.active{color:var(--text-primary);border-color:var(--game-accent)}

    /* HERO — blurred mosaic of genre's top games */
    .hero{position:relative;width:100%;height:320px;overflow:hidden;background:#04040a}
    .hero-mosaic{position:absolute;inset:-20px;display:flex;flex-wrap:wrap;filter:blur(18px) saturate(1.5) brightness(.38);transform:scale(1.08)}
    .hero-mosaic-tile{flex:1 1 90px;min-width:90px;min-height:160px;background-size:cover;background-position:center}
    .hero-overlay{position:absolute;inset:0;background:var(--hero-overlay)}

    .page{max-width:900px;margin:0 auto;padding:0 28px 100px}

    /* GENRE HEADER */
    .genre-header{display:flex;gap:24px;align-items:flex-end;margin-top:-70px;margin-bottom:32px;position:relative;z-index:2}
    .genre-icon-wrap{flex-shrink:0;width:120px;height:120px;border-radius:20px;background:var(--bg-card);border:1px solid rgba(96,80,200,.3);box-shadow:0 12px 40px rgba(0,0,0,.7),0 0 30px rgba(96,80,200,.15);display:flex;align-items:center;justify-content:center;font-size:52px}
    .genre-info{flex:1;min-width:0;padding-bottom:4px}
    .genre-eyebrow{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--game-accent);margin-bottom:6px}
    .genre-name{font-family:'Cinzel',serif;font-size:34px;line-height:1.1;letter-spacing:.04em;font-weight:600;text-shadow:0 2px 24px rgba(0,0,0,.6);margin-bottom:10px}
    .genre-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
    .genre-meta-item{font-size:13px;color:var(--text-secondary)}
    .genre-meta-sep{color:var(--text-tertiary);font-size:10px}

    /* STATS */
    .stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:28px}
    .stat-card{background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:22px 20px 18px}
    .stat-card.score-card-great{border-bottom:2px solid var(--score-great)}
    .stat-card.score-card-good{border-bottom:2px solid var(--score-good)}
    .stat-card.score-card-mid{border-bottom:2px solid var(--score-mid)}
    .stat-card.score-card-low{border-bottom:2px solid var(--score-low)}
    .stat-num{font-family:'Century Schoolbook','New Century Schoolbook',Georgia,serif;font-size:36px;font-weight:400;line-height:1;letter-spacing:-1px;margin-bottom:6px;color:var(--text-primary);background:none}
    .stat-num.great{color:var(--score-great)}
    .stat-num.good{color:var(--score-good)}
    .stat-num.mid{color:var(--score-mid)}
    .stat-num.low{color:var(--score-low)}
    .stat-label{font-size:11px;font-weight:500;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.08em}
    .stat-sub{font-size:11px;color:var(--text-tertiary);margin-top:3px}

    /* ABOUT */
    .about-grid{display:grid;grid-template-columns:1fr 260px;gap:24px;margin-bottom:40px}
    @media(max-width:720px){.about-grid{grid-template-columns:1fr}}
    .description{font-size:14px;line-height:1.8;color:var(--text-secondary)}
    .description.collapsed{display:-webkit-box;-webkit-line-clamp:5;-webkit-box-orient:vertical;overflow:hidden}
    .read-more-btn{background:none;border:none;font-family:inherit;font-size:12px;color:var(--game-accent);cursor:pointer;padding:8px 0 0;display:block}
    .details-card{background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:4px 18px;height:fit-content}
    .detail-row{display:flex;gap:12px;padding:11px 0;border-bottom:1px solid var(--border-subtle);font-size:12px}
    .detail-row:last-child{border-bottom:none}
    .detail-label{flex-shrink:0;width:80px;color:var(--text-tertiary);padding-top:2px;text-transform:uppercase;letter-spacing:.06em;font-size:10px;font-weight:500}
    .detail-value{color:var(--text-secondary);line-height:1.5}

    /* related genres chips */
    .related-genres{display:flex;flex-wrap:wrap;gap:8px}
    .genre-chip{background:var(--tag-bg);color:var(--text-secondary);border:1px solid var(--border);border-radius:20px;padding:5px 14px;font-size:12px;font-weight:500;transition:all .15s;cursor:pointer}
    .genre-chip:hover{border-color:var(--game-accent);color:var(--game-accent)}

    /* SECTIONS */
    .section{margin-bottom:48px}
    .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
    .section-title{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--text-tertiary)}
    .section-count{font-size:12px;color:var(--text-tertiary)}

    /* YEAR PICKER */
    .year-picker{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px}
    .year-btn{background:var(--tag-bg);color:var(--text-tertiary);border:1px solid var(--border);border-radius:20px;padding:5px 14px;font-size:12px;font-weight:500;font-family:inherit;cursor:pointer;transition:all .15s;letter-spacing:.02em}
    .year-btn:hover{color:var(--text-primary)}
    .year-btn.active{background:var(--game-accent);color:white;border-color:transparent}

    .year-panel-header{display:flex;align-items:center;gap:12px;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--border)}
    .year-panel-label{font-family:'DM Serif Display',serif;font-size:22px;letter-spacing:-.3px;color:var(--text-primary)}
    .year-panel-count{font-size:12px;color:var(--text-tertiary)}

    /* PAGINATED ROW */
    .game-row{display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
    @media(max-width:700px){.game-row{grid-template-columns:repeat(3,1fr)}}
    .row-nav{display:flex;align-items:center;gap:8px;margin-top:14px}
    .row-nav-info{font-size:12px;color:var(--text-tertiary)}
    .row-arrow{background:var(--bg-card);border:1px solid var(--border);border-radius:8px;width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;color:var(--text-secondary);flex-shrink:0}
    .row-arrow:hover{border-color:var(--game-accent);color:var(--game-accent)}
    .row-arrow:disabled{opacity:.25;cursor:default;pointer-events:none}

    /* GAME CARDS */
    .game-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:transform .15s,box-shadow .15s,border-color .15s;display:block}
    .game-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-md);border-color:rgba(96,80,200,.3)}
    .game-cover{aspect-ratio:3/4;background:var(--tag-bg);overflow:hidden;position:relative}
    .game-cover img{width:100%;height:100%;object-fit:cover;display:block}
    .game-cover-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:32px}
    .game-score-badge{position:absolute;top:7px;right:7px;width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;font-family:'Century Schoolbook',Georgia,serif}
    .badge-great{color:var(--score-great);background:var(--score-great-bg);border:1px solid rgba(74,222,128,.3)}
    .badge-good{color:var(--score-good);background:var(--score-good-bg);border:1px solid rgba(96,165,250,.3)}
    .badge-mid{color:var(--score-mid);background:var(--score-mid-bg);border:1px solid rgba(251,191,36,.3)}
    .badge-low{color:var(--score-low);background:var(--score-low-bg);border:1px solid rgba(248,113,113,.3)}
    .game-info{padding:9px 10px 11px}
    .game-title-text{font-size:11px;font-weight:500;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:2px}
    .game-review-count{font-size:10px;color:var(--text-tertiary);margin-top:1px}

    .empty-state{padding:60px 0;text-align:center;color:var(--text-tertiary)}
    .empty-title{font-family:'DM Serif Display',serif;font-size:20px;color:var(--text-secondary);margin-bottom:8px}

    @media(max-width:600px){
      .genre-header{flex-direction:column;align-items:flex-start;margin-top:-40px}
      .genre-name{font-size:26px}
      .hero{height:220px}
      .stats-row{gap:8px}
      .stat-num{font-size:30px}
      .jump-nav{display:none}
    }
  </style>
</head>

<body>
  <nav class="topnav">
    <a href="/" class="back-btn">
      <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8L10 4"/></svg>
      Back
    </a>
    <a href="/" class="logo"><span class="logo-dot"></span>Cartridge</a>
    <button class="theme-btn" onclick="toggleTheme()">
      <svg id="themeIcon" width="17" height="17" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="9" r="3.5"/>
        <path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>
      </svg>
    </button>
  </nav>

  <nav class="jump-nav">
    <a href="#overview" class="jump-link active">Overview</a>
    {topRated.length > 0 && <a href="#top-rated" class="jump-link">Top Rated</a>}
    {years.length > 0 && <a href="#by-year" class="jump-link">By Year</a>}
    {relatedGenres.length > 0 && <a href="#related" class="jump-link">Related</a>}
  </nav>

  <!-- HERO — blurred mosaic from top genre games -->
  <div class="hero" id="overview">
    <div class="hero-mosaic" id="heroMosaic"></div>
    <div class="hero-overlay"></div>
  </div>

  <div class="page">

    <div class="genre-header">
      <div class="genre-icon-wrap">
        {genre.slug === 'role-playing-rpg' && '⚔️'}
        {genre.slug === 'shooter' && '🔫'}
        {genre.slug === 'adventure' && '🗺️'}
        {genre.slug === 'platform' && '🕹️'}
        {genre.slug === 'strategy' && '♟️'}
        {genre.slug === 'fighting' && '🥊'}
        {genre.slug === 'puzzle' && '🧩'}
        {genre.slug === 'sport' && '⚽'}
        {genre.slug === 'indie' && '✨'}
        {genre.slug === 'arcade' && '🕹️'}
        {!['role-playing-rpg','shooter','adventure','platform','strategy','fighting','puzzle','sport','indie','arcade'].includes(genre.slug) && '🎮'}
      </div>
      <div class="genre-info">
        <div class="genre-eyebrow">Genre</div>
        <h1 class="genre-name">{genre.name}</h1>
        <div class="genre-meta">
          <span class="genre-meta-item">{allGames.length.toLocaleString()} games</span>
          {totalReviews > 0 && (
            <>
              <span class="genre-meta-sep">•</span>
              <span class="genre-meta-item">{totalReviews.toLocaleString()} reviews</span>
            </>
          )}
          {overallAvg && (
            <>
              <span class="genre-meta-sep">•</span>
              <span class="genre-meta-item" style={`color:var(--score-${overallScoreClass})`}>
                {overallAvg} avg
              </span>
            </>
          )}
        </div>
      </div>
    </div>

    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-num">{allGames.length.toLocaleString()}</div>
        <div class="stat-label">Games</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{totalReviews.toLocaleString()}</div>
        <div class="stat-label">Reviews</div>
        <div class="stat-sub">across all games</div>
      </div>
      <div class={`stat-card ${overallScoreClass ? `score-card-${overallScoreClass}` : ''}`}>
        {overallAvg
          ? <div class={`stat-num ${overallScoreClass}`}>{overallAvg}</div>
          : <div class="stat-num" style="color:var(--text-tertiary)">—</div>
        }
        <div class="stat-label">Avg score</div>
      </div>
    </div>

    {(genreDescription || relatedGenres.length > 0) && (
      <div class="about-grid">
        <div>
          {genreDescription && (
            <>
              <p class="description collapsed" id="desc">{genreDescription}</p>
              <button class="read-more-btn" id="readMoreBtn" onclick="toggleDesc()">Read more →</button>
            </>
          )}
        </div>
        <div class="details-card">
          <div class="detail-row">
            <span class="detail-label">Games</span>
            <span class="detail-value">{allGames.length.toLocaleString()} on Cartridge</span>
          </div>
          {totalReviews > 0 && (
            <div class="detail-row">
              <span class="detail-label">Reviews</span>
              <span class="detail-value">{totalReviews.toLocaleString()} total</span>
            </div>
          )}
          {topRated.length > 0 && (
            <div class="detail-row">
              <span class="detail-label">Top game</span>
              <span class="detail-value">{topRated[0].title}</span>
            </div>
          )}
          {years.length > 0 && (
            <div class="detail-row">
              <span class="detail-label">Active</span>
              <span class="detail-value">{years[years.length - 1]} – {years[0]}</span>
            </div>
          )}
        </div>
      </div>
    )}

    <!-- TOP RATED -->
    {topRated.length > 0 && (
      <div class="section" id="top-rated">
        <div class="section-header">
          <span class="section-title">Top Rated</span>
          <span class="section-count">{topRated.length} games</span>
        </div>
        <div class="game-row" id="topRatedRow"></div>
        <div class="row-nav">
          <button class="row-arrow" id="topPrev" onclick="pageRow('top',-1)">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8l4-4"/></svg>
          </button>
          <button class="row-arrow" id="topNext" onclick="pageRow('top',1)">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 12l4-4-4-4"/></svg>
          </button>
          <span class="row-nav-info" id="topInfo"></span>
        </div>
      </div>
    )}

    <!-- MOST REVIEWED -->
    {mostReviewed.length > 0 && (
      <div class="section" id="most-reviewed">
        <div class="section-header">
          <span class="section-title">Most Reviewed</span>
          <span class="section-count">{mostReviewed.length} games</span>
        </div>
        <div class="game-row" id="mostReviewedRow"></div>
        <div class="row-nav">
          <button class="row-arrow" id="mrPrev" onclick="pageRow('mr',-1)">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8l4-4"/></svg>
          </button>
          <button class="row-arrow" id="mrNext" onclick="pageRow('mr',1)">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 12l4-4-4-4"/></svg>
          </button>
          <span class="row-nav-info" id="mrInfo"></span>
        </div>
      </div>
    )}

    <!-- BY YEAR -->
    {years.length > 0 && (
      <div class="section" id="by-year">
        <div class="section-header">
          <span class="section-title">By Year</span>
          <span class="section-count" id="yearPanelCount"></span>
        </div>
        <div class="year-picker" id="yearPicker"></div>
        <div>
          <div class="year-panel-header">
            <span class="year-panel-label" id="yearPanelLabel"></span>
            <span class="year-panel-count" id="yearPanelTotal"></span>
          </div>
          <div class="game-row" id="yearGamesRow"></div>
          <div class="row-nav">
            <button class="row-arrow" id="yearPrev" onclick="pageRow('year',-1)">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8l4-4"/></svg>
            </button>
            <button class="row-arrow" id="yearNext" onclick="pageRow('year',1)">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 12l4-4-4-4"/></svg>
            </button>
            <span class="row-nav-info" id="yearInfo"></span>
          </div>
        </div>
      </div>
    )}

    <!-- RELATED GENRES -->
    {relatedGenres.length > 0 && (
      <div class="section" id="related">
        <div class="section-header">
          <span class="section-title">Related Genres</span>
        </div>
        <div class="related-genres">
          {relatedGenres.map((g: any) => (
            <a href={`/genres/${g.slug}`} class="genre-chip">{g.name}</a>
          ))}
        </div>
      </div>
    )}

    {allGames.length === 0 && (
      <div class="empty-state">
        <div class="empty-title">No games yet</div>
        <p>We don't have any {genre.name} games in our database yet.</p>
      </div>
    )}

  </div>

  <script define:vars={{ topRatedJson, mostReviewedJson, byYearJson, yearsJson }}>

    var topRated = JSON.parse(topRatedJson);
    var mostReviewed = JSON.parse(mostReviewedJson);
    var byYear = JSON.parse(byYearJson);
    var years = JSON.parse(yearsJson);

    // hero mosaic from top game covers
    var mosaic = document.getElementById('heroMosaic');
    if (mosaic) {
      var coverUrls = topRated.slice(0,12).map(function(g){return g.cover;}).filter(Boolean);
      if (coverUrls.length > 0) {
        var tiles = coverUrls.concat(coverUrls).concat(coverUrls).slice(0,24);
        tiles.forEach(function(url){
          var tile = document.createElement('div');
          tile.className = 'hero-mosaic-tile';
          tile.style.backgroundImage = 'url('+url+')';
          mosaic.appendChild(tile);
        });
      }
    }

    function makeCard(g) {
      var cv = g.cover ? '<img src="'+g.cover+'" alt="" loading="lazy"/>' : '<div class="game-cover-placeholder">🎮</div>';
      var bd = g.score ? '<div class="game-score-badge '+g.badge+'">'+g.score+'</div>' : '';
      return '<a href="/games/'+g.slug+'" class="game-card">'
        +'<div class="game-cover">'+cv+bd+'</div>'
        +'<div class="game-info">'
        +'<div class="game-title-text">'+g.title+'</div>'
        +(g.reviews?'<div class="game-review-count">'+g.reviews+'</div>':'')
        +'</div></a>';
    }

    var rows = {};

    function initRow(key, data, rowId, prevId, nextId, infoId) {
      rows[key] = {data:data,page:0,pageSize:5,rowId:rowId,prevId:prevId,nextId:nextId,infoId:infoId};
      renderRow(key);
    }

    function renderRow(key) {
      var r = rows[key];
      var start = r.page * r.pageSize;
      var slice = r.data.slice(start, start+r.pageSize);
      var el = document.getElementById(r.rowId);
      if (el) el.innerHTML = slice.map(function(g){return makeCard(g);}).join('');
      var tot = Math.ceil(r.data.length / r.pageSize);
      var prev = document.getElementById(r.prevId);
      var next = document.getElementById(r.nextId);
      var info = document.getElementById(r.infoId);
      if (prev) prev.disabled = r.page === 0;
      if (next) next.disabled = r.page >= tot-1;
      if (info) info.textContent = (r.page+1)+' / '+tot;
    }

    function pageRow(key, dir) {
      var r = rows[key];
      if (!r) return;
      var tot = Math.ceil(r.data.length/r.pageSize);
      r.page = Math.max(0, Math.min(tot-1, r.page+dir));
      renderRow(key);
    }
    window.pageRow = pageRow;

    if (topRated.length > 0) initRow('top', topRated, 'topRatedRow', 'topPrev', 'topNext', 'topInfo');
    if (mostReviewed.length > 0) initRow('mr', mostReviewed, 'mostReviewedRow', 'mrPrev', 'mrNext', 'mrInfo');

    // year picker
    if (years.length > 0) {
      var activeYear = years[0];
      var picker = document.getElementById('yearPicker');
      if (picker) {
        years.forEach(function(y) {
          var btn = document.createElement('button');
          btn.className = 'year-btn' + (y === activeYear ? ' active' : '');
          btn.textContent = y;
          btn.onclick = function(){ selectYear(y); };
          picker.appendChild(btn);
        });
      }

      function selectYear(y) {
        activeYear = y;
        document.querySelectorAll('.year-btn').forEach(function(b){
          b.classList.toggle('active', parseInt(b.textContent) === y);
        });
        var games = byYear[y] || [];
        var lbl = document.getElementById('yearPanelLabel');
        var tot = document.getElementById('yearPanelTotal');
        var cnt = document.getElementById('yearPanelCount');
        if (lbl) lbl.textContent = y;
        if (tot) tot.textContent = games.length+' games';
        if (cnt) cnt.textContent = games.length+' games';
        rows['year'] = {data:games,page:0,pageSize:5,rowId:'yearGamesRow',prevId:'yearPrev',nextId:'yearNext',infoId:'yearInfo'};
        renderRow('year');
      }
      selectYear(activeYear);
    }

    function toggleDesc() {
      var d=document.getElementById('desc'), b=document.getElementById('readMoreBtn');
      if (!d||!b) return;
      d.classList.toggle('collapsed');
      b.textContent = d.classList.contains('collapsed') ? 'Read more →' : 'Read less ↑';
    }
    window.toggleDesc = toggleDesc;

    var sections = ['overview','top-rated','most-reviewed','by-year','related'];
    var jumpLinks = document.querySelectorAll('.jump-link');
    window.addEventListener('scroll', function(){
      var c='overview';
      sections.forEach(function(id){
        var el=document.getElementById(id);
        if(el&&window.scrollY>=el.offsetTop-120) c=id;
      });
      jumpLinks.forEach(function(l){
        l.classList.toggle('active',l.getAttribute('href')==='#'+c);
      });
    });

    function toggleTheme() {
      var h=document.documentElement,n=h.getAttribute('data-theme')==='light'?'dark':'light';
      h.setAttribute('data-theme',n);localStorage.setItem('theme',n);updateIcon(n);
    }
    function updateIcon(t) {
      var i=document.getElementById('themeIcon');
      if (!i) return;
      i.innerHTML=t==='dark'
        ?'<path d="M15 10.5A7 7 0 016.5 3a7 7 0 100 12 7 7 0 008.5-4.5z"/>'
        :'<circle cx="9" cy="9" r="3.5"/><path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>';
    }
    window.toggleTheme = toggleTheme;

    var saved=localStorage.getItem('theme')||(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light');
    document.documentElement.setAttribute('data-theme',saved);
    updateIcon(saved);

  </script>
</body>
</html>
