const summary = igdbData?.summary || platformDescriptions[platform.slug] || null
const releaseDate = platformReleaseDates[platform.slug] ?? null
const releaseYearDisplay = releaseDate ? releaseDate.split(' ').pop() ?? null : null
const generation = igdbData?.generation ? `${igdbData.generation}th` : platformGenerations[platform.slug] ?? null
const family = igdbData?.platform_family?.name ?? platformFamilies[platform.slug] ?? null
const officialSite = igdbData?.websites?.find((w: any) => w.category === 1)?.url ?? null

function igdbImage(url: string | null, size = 't_cover_big') {
  if (!url) return null
  const clean = url.startsWith('//') ? `https:${url}` : url
  return clean.replace(/t_[a-z_]+/, size)
}

function scoreClass(score: number): string {
  if (score >= 9) return 'great'
  if (score >= 7) return 'good'
  if (score >= 5) return 'mid'
  return 'low'
}

function timeAgo(dateStr: string): string {
  const diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000)
  if (diff < 60) return `${diff}s`
  if (diff < 3600) return `${Math.floor(diff / 60)}m`
  if (diff < 86400) return `${Math.floor(diff / 3600)}h`
  if (diff < 604800) return `${Math.floor(diff / 86400)}d`
  return `${Math.floor(diff / 604800)}w`
}

function getInitials(username: string): string {
  return username.slice(0, 2).toUpperCase()
}

const consoleScoreClass = consoleAvg ? scoreClass(parseFloat(consoleAvg)) : null
const gameAvgScoreClass = gameAvg ? scoreClass(parseFloat(gameAvg)) : null
const displayGameCount = totalGameCount ?? allGames.length

function serializeGames(games: any[]) {
  return games.map((g: any) => {
    const avg = gameAvgScore(g.id)
    const count = gameReviewCount(g.id)
    const sc = avg ? scoreClass(parseFloat(avg)) : null
    return {
      title: g.title,
      slug: g.slug,
      cover: igdbImage(g.cover_img_url),
      score: avg,
      badge: sc ? `badge-${sc}` : null,
      reviews: count > 0 ? `${count} ${count === 1 ? 'review' : 'reviews'}` : null,
    }
  })
}

const exclusivesJson = JSON.stringify(serializeGames(exclusives))
const byYearJson = JSON.stringify(
  years.reduce((acc: any, year: number) => {
    acc[year] = serializeGames(byYearSorted[year] ?? [])
    return acc
  }, {})
)
