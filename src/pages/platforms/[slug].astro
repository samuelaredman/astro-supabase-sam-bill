<body>
  <nav class="topnav">
    <a href="/" class="back-btn">
      <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8L10 4"/></svg>
      Back
    </a>
    <a href="/" class="logo"><span class="logo-dot"></span>Cartridge</a>
    <button class="theme-btn" onclick="toggleTheme()">
      <svg id="themeIcon" width="17" height="17" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="9" r="3.5"/>
        <path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>
      </svg>
    </button>
  </nav>

  <nav class="jump-nav">
    <a href="#overview" class="jump-link active">Overview</a>
    {exclusives.length > 0 && <a href="#exclusives" class="jump-link">Exclusives</a>}
    {years.length > 0 && <a href="#games" class="jump-link">Games</a>}
    <a href="#reviews" class="jump-link">Reviews</a>
  </nav>

  {bannerImage && (
    <div class="hero">
      <img
        class="hero-img"
        src={bannerImage}
        alt={platform.name}
        onerror="this.style.display='none';document.getElementById('heroMosaic').classList.add('visible')"
      />
      <div class="hero-mosaic" id="heroMosaic"></div>
      <div class="hero-side-fade"></div>
      <div class="hero-overlay"></div>
    </div>
  )}

  <div class="page" id="overview">

    <div class={`platform-header ${bannerImage ? 'has-banner' : 'no-banner'}`}>
      <div class="platform-logo-wrap">
        {igdbData?.platform_logo?.url
          ? <img class="platform-logo" src={igdbImage(igdbData.platform_logo.url, 't_logo_med') ?? ''} alt={platform.name} />
          : <span>🎮</span>
        }
      </div>
      <div class="platform-info">
        <div class="platform-name-row">
          <h1 class="platform-name">{platform.name}</h1>
          {consoleAvg && (
            <div class="console-score-wrap">
              <span class={`console-score-num ${consoleScoreClass}`}>{consoleAvg}</span>
              <span class="console-score-label">· {consoleTotalRatings.toLocaleString()} ratings</span>
            </div>
          )}
        </div>
        <div class="platform-meta">
          {releaseYearDisplay && <span class="platform-meta-item">Released {releaseYearDisplay}</span>}
          {generation && (
            <>
              {releaseYearDisplay && <span class="platform-meta-sep">•</span>}
              <span class="platform-meta-item">{generation} Generation</span>
            </>
          )}
          {family && (
            <>
              <span class="platform-meta-sep">•</span>
              <span class="platform-meta-item">{family}</span>
            </>
          )}
          {officialSite && (
            <>
              <span class="platform-meta-sep">•</span>
              <a href={officialSite} target="_blank" rel="noopener" class="platform-website">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="6"/><path d="M8 2c0 0-3 2-3 6s3 6 3 6M8 2c0 0 3 2 3 6s-3 6-3 6M2 8h12"/></svg>
                Website
              </a>
            </>
          )}
        </div>
        <button class="rate-console-btn" onclick="openRateModal()">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v12M2 8h12"/></svg>
          Rate this console
        </button>
      </div>
    </div>

    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-num">{displayGameCount.toLocaleString()}</div>
        <div class="stat-label">Games</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{totalGameReviews.toLocaleString()}</div>
        <div class="stat-label">Game reviews</div>
        <div class="stat-sub">across all games</div>
      </div>
      <div class={`stat-card ${gameAvgScoreClass ? `score-card-${gameAvgScoreClass}` : ''}`}>
        {gameAvg
          ? <div class={`stat-num ${gameAvgScoreClass}`}>{gameAvg}</div>
          : <div class="stat-num" style="color:var(--text-tertiary)">—</div>
        }
        <div class="stat-label">Avg game score</div>
      </div>
      <div class={`stat-card ${consoleScoreClass ? `score-card-${consoleScoreClass}` : ''}`}>
        {consoleAvg
          ? <div class={`stat-num ${consoleScoreClass}`}>{consoleAvg}</div>
          : <div class="stat-num" style="color:var(--text-tertiary)">—</div>
        }
        <div class="stat-label">Console score</div>
        {consoleTotalRatings > 0 && <div class="stat-sub">{consoleTotalRatings.toLocaleString()} ratings</div>}
      </div>
    </div>

    {summary && (
      <div class="about-grid">
        <div>
          <p class="description collapsed" id="desc">{summary}</p>
          <button class="read-more-btn" id="readMoreBtn" onclick="toggleDesc()">Read more →</button>
        </div>
        <div class="details-card">
          {releaseDate && releaseDate !== 'N/A' && (
            <div class="detail-row">
              <span class="detail-label">Released</span>
              <span class="detail-value">{releaseDate}</span>
            </div>
          )}
          {generation && (
            <div class="detail-row">
              <span class="detail-label">Generation</span>
              <span class="detail-value">{generation}</span>
            </div>
          )}
          {family && (
            <div class="detail-row">
              <span class="detail-label">Family</span>
              <span class="detail-value">{family}</span>
            </div>
          )}
          <div class="detail-row">
            <span class="detail-label">Games</span>
            <span class="detail-value">{displayGameCount.toLocaleString()} on Cartridge</span>
          </div>
          {totalGameReviews > 0 && (
            <div class="detail-row">
              <span class="detail-label">Reviews</span>
              <span class="detail-value">{totalGameReviews.toLocaleString()} total</span>
            </div>
          )}
          {officialSite && (
            <div class="detail-row">
              <span class="detail-label">Website</span>
              <a href={officialSite} target="_blank" rel="noopener" class="detail-value detail-link">
                {officialSite.replace(/^https?:\/\//, '').replace(/\/$/, '')}
              </a>
            </div>
          )}
        </div>
      </div>
    )}

    {exclusives.length > 0 && (
      <div class="section" id="exclusives">
        <div class="section-header">
          <span class="section-title">Exclusives</span>
          <span class="section-count">{exclusives.length} games</span>
        </div>
        <div class="game-row" id="exclusivesRow"></div>
        <div class="row-nav">
          <button class="row-arrow" id="excPrev" onclick="pageRow('exc',-1)">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8l4-4"/></svg>
          </button>
          <button class="row-arrow" id="excNext" onclick="pageRow('exc',1)">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 12l4-4-4-4"/></svg>
          </button>
          <span class="row-nav-info" id="excInfo"></span>
        </div>
      </div>
    )}

    {years.length > 0 && (
      <div class="section" id="games">
        <div class="section-header">
          <span class="section-title">Games</span>
          <span class="section-count" id="yearPanelCount"></span>
        </div>
        <div class="year-picker" id="yearPicker"></div>
        <div>
          <div class="year-panel-header">
            <span class="year-panel-label" id="yearPanelLabel"></span>
            <span class="year-panel-count" id="yearPanelTotal"></span>
          </div>
          <div class="game-row" id="yearGamesRow"></div>
          <div class="row-nav">
            <button class="row-arrow" id="yearPrev" onclick="pageRow('year',-1)">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8l4-4"/></svg>
            </button>
            <button class="row-arrow" id="yearNext" onclick="pageRow('year',1)">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 12l4-4-4-4"/></svg>
            </button>
            <span class="row-nav-info" id="yearInfo"></span>
          </div>
        </div>
      </div>
    )}

    <div class="section" id="reviews">
      <div class="section-header">
        <span class="section-title">Console Reviews</span>
        <span class="section-count">
          {platformReviewList.length} {platformReviewList.length === 1 ? 'review' : 'reviews'}
        </span>
      </div>

      {platformReviewList.length === 0 ? (
        <div class="empty-state">
          <div class="empty-title">No reviews yet</div>
          <p>Be the first to review the {platform.name}.</p>
          <button class="write-review-btn" onclick="openRateModal()">+ Write a review</button>
        </div>
      ) : (
        <>
          <div class="reviews-toolbar">
            <button class="sort-tab active" onclick="sortReviews('recent',this)">Recent</button>
            <button class="sort-tab" onclick="sortReviews('highest',this)">Highest</button>
            <button class="sort-tab" onclick="sortReviews('lowest',this)">Lowest</button>
          </div>
          <div id="platformReviewsList">
            {platformReviewList.map((review: any) => (
              <div class="review-card" data-score={review.score} data-date={review.created_at}>
                <div class="review-top">
                  <div class="avatar">
                    {review.profiles?.avatar_url
                      ? <img src={review.profiles.avatar_url} alt={review.profiles.username} />
                      : getInitials(review.profiles?.username ?? '??')
                    }
                  </div>
                  <div class="reviewer-info">
                    <a href={`/reviewers/${review.profiles?.username}`} class="reviewer-name">
                      @{review.profiles?.username ?? 'unknown'}
                    </a>
                    <div class="reviewer-meta">
                      <span>{timeAgo(review.created_at)}</span>
                    </div>
                  </div>
                  <div class={`score-badge score-${scoreClass(review.score)}`}>{review.score}</div>
                </div>
                {review.title && <div class="review-title">{review.title}</div>}
                {review.body && (
                  <>
                    <div class="review-body collapsed" id={`prb-${review.id}`}>{review.body}</div>
                    <div class="review-footer">
                      <button class="expand-btn" onclick={`toggleReview('${review.id}',this)`}>Read more →</button>
                    </div>
                  </>
                )}
              </div>
            ))}
          </div>
        </>
      )}
    </div>

  </div>

  <script define:vars={{ exclusivesJson, byYearJson, yearsJson }}>

    var exclusives = JSON.parse(exclusivesJson);
    var byYear = JSON.parse(byYearJson);
    var years = JSON.parse(yearsJson);

    var mosaic = document.getElementById('heroMosaic');
    if (mosaic) {
      var coverUrls = exclusives.slice(0,12).map(function(g){return g.cover;}).filter(Boolean);
      if (coverUrls.length > 0) {
        var tiles = coverUrls.concat(coverUrls).concat(coverUrls).slice(0,24);
        tiles.forEach(function(url) {
          var tile = document.createElement('div');
          tile.className = 'hero-mosaic-tile';
          tile.style.backgroundImage = 'url('+url+')';
          mosaic.appendChild(tile);
        });
      }
    }

    function makeCard(g, isExc) {
      var cv = g.cover ? '<img src="'+g.cover+'" alt="" loading="lazy"/>' : '<div class="game-cover-placeholder">🎮</div>';
      var bd = g.score ? '<div class="game-score-badge '+g.badge+'">'+g.score+'</div>' : '';
      var ex = isExc ? '<div class="exclusive-badge">Exclusive</div>' : '';
      return '<a href="/games/'+g.slug+'" class="game-card">'
        +'<div class="game-cover">'+cv+bd+ex+'</div>'
        +'<div class="game-info">'
        +'<div class="game-title-text">'+g.title+'</div>'
        +(g.reviews?'<div class="game-review-count">'+g.reviews+'</div>':'')
        +'</div></a>';
    }

    var rows = {};

    function initRow(key, data, rowId, prevId, nextId, infoId, isExc) {
      rows[key] = {data:data,page:0,pageSize:5,rowId:rowId,prevId:prevId,nextId:nextId,infoId:infoId,isExc:isExc||false};
      renderRow(key);
    }

    function renderRow(key) {
      var r = rows[key];
      var start = r.page * r.pageSize;
      var slice = r.data.slice(start, start+r.pageSize);
      var el = document.getElementById(r.rowId);
      if (el) el.innerHTML = slice.map(function(g){return makeCard(g,r.isExc);}).join('');
      var tot = Math.ceil(r.data.length / r.pageSize);
      var prev = document.getElementById(r.prevId);
      var next = document.getElementById(r.nextId);
      var info = document.getElementById(r.infoId);
      if (prev) prev.disabled = r.page === 0;
      if (next) next.disabled = r.page >= tot-1;
      if (info) info.textContent = (r.page+1)+' / '+tot;
    }

    function pageRow(key, dir) {
      var r = rows[key];
      if (!r) return;
      var tot = Math.ceil(r.data.length/r.pageSize);
      r.page = Math.max(0, Math.min(tot-1, r.page+dir));
      renderRow(key);
    }
    window.pageRow = pageRow;

    if (exclusives.length > 0) {
      initRow('exc', exclusives, 'exclusivesRow', 'excPrev', 'excNext', 'excInfo', true);
    }

    if (years.length > 0) {
      var activeYear = years[0];
      var picker = document.getElementById('yearPicker');
      if (picker) {
        years.forEach(function(y) {
          var btn = document.createElement('button');
          btn.className = 'year-btn' + (y === activeYear ? ' active' : '');
          btn.textContent = y;
          btn.onclick = function() { selectYear(y); };
          picker.appendChild(btn);
        });
      }

      function selectYear(y) {
        activeYear = y;
        document.querySelectorAll('.year-btn').forEach(function(b) {
          b.classList.toggle('active', parseInt(b.textContent) === y);
        });
        var games = byYear[y] || [];
        var lbl = document.getElementById('yearPanelLabel');
        var tot = document.getElementById('yearPanelTotal');
        var cnt = document.getElementById('yearPanelCount');
        if (lbl) lbl.textContent = y;
        if (tot) tot.textContent = games.length + ' games';
        if (cnt) cnt.textContent = games.length + ' games';
        rows['year'] = {data:games,page:0,pageSize:5,rowId:'yearGamesRow',prevId:'yearPrev',nextId:'yearNext',infoId:'yearInfo',isExc:false};
        renderRow('year');
      }
      selectYear(activeYear);
    }

    function sortReviews(type, btn) {
      document.querySelectorAll('.sort-tab').forEach(function(b){b.classList.remove('active');});
      btn.classList.add('active');
      var list = document.getElementById('platformReviewsList');
      if (!list) return;
      var cards = Array.from(list.querySelectorAll('.review-card'));
      cards.sort(function(a,b) {
        if (type === 'highest') return parseInt(b.dataset.score) - parseInt(a.dataset.score);
        if (type === 'lowest') return parseInt(a.dataset.score) - parseInt(b.dataset.score);
        return new Date(b.dataset.date).getTime() - new Date(a.dataset.date).getTime();
      });
      cards.forEach(function(card){list.appendChild(card);});
    }
    window.sortReviews = sortReviews;

    function toggleReview(id, btn) {
      var b = document.getElementById('prb-'+id);
      if (!b) return;
      b.classList.toggle('collapsed');
      btn.textContent = b.classList.contains('collapsed') ? 'Read more →' : 'Read less ↑';
    }
    window.toggleReview = toggleReview;

    function toggleDesc() {
      var d=document.getElementById('desc'), b=document.getElementById('readMoreBtn');
      if (!d||!b) return;
      d.classList.toggle('collapsed');
      b.textContent = d.classList.contains('collapsed') ? 'Read more →' : 'Read less ↑';
    }
    window.toggleDesc = toggleDesc;

    function openRateModal() {
      alert('Sign in to rate this console');
    }
    window.openRateModal = openRateModal;

    var sections=['overview','exclusives','games','reviews'];
    var jumpLinks=document.querySelectorAll('.jump-link');
    window.addEventListener('scroll', function() {
      var c='overview';
      sections.forEach(function(id){
        var el=document.getElementById(id);
        if(el&&window.scrollY>=el.offsetTop-120) c=id;
      });
      jumpLinks.forEach(function(l){
        l.classList.toggle('active',l.getAttribute('href')==='#'+c);
      });
    });

    function toggleTheme() {
      var h=document.documentElement,n=h.getAttribute('data-theme')==='light'?'dark':'light';
      h.setAttribute('data-theme',n);localStorage.setItem('theme',n);updateIcon(n);
    }
    function updateIcon(t) {
      var i=document.getElementById('themeIcon');
      if (!i) return;
      i.innerHTML=t==='dark'
        ?'<path d="M15 10.5A7 7 0 016.5 3a7 7 0 100 12 7 7 0 008.5-4.5z"/>'
        :'<circle cx="9" cy="9" r="3.5"/><path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>';
    }
    window.toggleTheme = toggleTheme;

    var saved=localStorage.getItem('theme')||(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light');
    document.documentElement.setAttribute('data-theme',saved);
    updateIcon(saved);

  </script>
</body>
</html>
