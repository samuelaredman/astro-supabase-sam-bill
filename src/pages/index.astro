import { getSupabase, createSupabaseServerClient } from "../utils/database";
const supabase = getSupabase();

const serverClient = createSupabaseServerClient(Astro.request, new Response());
const { data: { session } } = await serverClient.auth.getSession();
const isLoggedIn = !!session;

const { data: platforms } = await (supabase as any)
  .from("platforms")
  .select("id, name, slug")
  .order("name", { ascending: true });

type Platform = { id: string; name: string; slug: string; };

type Review = {
  id: string;
  score: number;
  title: string;
  body: string;
  play_time_hours: number;
  contains_spoilers: boolean;
  status: string;
  published_at: string;
  created_at: string;
  played_on: Platform | null;
  games: { id: string; title: string; slug: string; cover_img_url: string | null; } | null;
  profiles: { id: string; username: string; avatar_url: string | null; } | null;
  review_votes: vote | null;
}

// recent reviews feed
const { data: rawReviews } = await (supabase as any)
  .from("reviews")
  .select(`
    id, score, title, body, play_time_hours,
    contains_spoilers, status, published_at, created_at,
    played_on:platform_played_on ( id, name, slug ),
    games ( id, title, slug, cover_img_url ),
    profiles ( id, username, avatar_url ),
    review_votes( vote )
  `)
  .eq("status", "published")
  .order("published_at", { ascending: false })
  .limit(20)

const reviews = (rawReviews ?? []) as Review[]

const oneDayAgo = new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString()
const oneWeekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString()

// most reviewed today — for hero
const { data: todayRaw } = await (supabase as any)
  .from('reviews')
  .select('game_id, games(id, title, slug, cover_img_url)')
  .eq('status', 'published')
  .gte('published_at', oneDayAgo)
  .limit(100)

const todayMap: Record<string, { title: string; slug: string; cover: string | null; count: number }> = {}
for (const r of todayRaw ?? []) {
  const g = (r as any).games
  if (!g) continue
  if (!todayMap[g.id]) todayMap[g.id] = { title: g.title, slug: g.slug, cover: g.cover_img_url, count: 0 }
  todayMap[g.id].count++
}

const mostReviewedToday = Object.values(todayMap).sort((a, b) => b.count - a.count)[0] ?? null

// trending this week — most reviewed games
const { data: trendingRaw } = await (supabase as any)
  .from('reviews')
  .select('game_id, games(id, title, slug, cover_img_url)')
  .eq('status', 'published')
  .gte('published_at', oneWeekAgo)
  .limit(200)

const trendingMap: Record<string, { title: string; slug: string; cover: string | null; count: number }> = {}
for (const r of trendingRaw ?? []) {
  const g = (r as any).games
  if (!g) continue
  if (!trendingMap[g.id]) trendingMap[g.id] = { title: g.title, slug: g.slug, cover: g.cover_img_url, count: 0 }
  trendingMap[g.id].count++
}
const trending = Object.values(trendingMap).sort((a, b) => b.count - a.count).slice(0, 5)

// top rated this week — games with best avg score from this week's reviews
const { data: weekReviewsRaw } = await (supabase as any)
  .from('reviews')
  .select('game_id, score, games(id, title, slug, cover_img_url)')
  .eq('status', 'published')
  .gte('published_at', oneWeekAgo)
  .limit(500)

const weekGameMap: Record<string, { title: string; slug: string; cover: string | null; scores: number[] }> = {}
for (const r of weekReviewsRaw ?? []) {
  const g = (r as any).games
  if (!g) continue
  if (!weekGameMap[g.id]) weekGameMap[g.id] = { title: g.title, slug: g.slug, cover: g.cover_img_url, scores: [] }
  if (r.score != null) weekGameMap[g.id].scores.push(r.score)
}

const topRated = Object.entries(weekGameMap)
  .map(([id, g]) => {
    if (g.scores.length < 2) return null
    const avg = g.scores.reduce((a, b) => a + b, 0) / g.scores.length
    return { id, ...g, avg_score: avg, review_count: g.scores.length }
  })
  .filter(Boolean)
  .sort((a: any, b: any) => b.avg_score - a.avg_score)
  .slice(0, 12)

// site stats
const [reviewCountRes, gameCountRes, profileCountRes] = await Promise.all([
  (supabase as any).from('reviews').select('*', { count: 'exact', head: true }).eq('status', 'published'),
  (supabase as any).from('games').select('*', { count: 'exact', head: true }),
  (supabase as any).from('profiles').select('*', { count: 'exact', head: true }),
])
const totalReviews = reviewCountRes.count ?? 0
const totalGames = gameCountRes.count ?? 0
const totalReviewers = profileCountRes.count ?? 0

// featured game — most reviewed today
const featuredGame = mostReviewedToday

// genre chips for browse
const { data: genres } = await (supabase as any)
  .from('genres')
  .select('id, name')
  .order('name')

const featuredGenres = ['Action','Adventure','Role-playing (RPG)','Shooter','Platform','Puzzle','Strategy','Indie','Fighting','Racing']

function igdbImage(url: string | null, size = 't_cover_big') {
  if (!url) return null
  const clean = url.startsWith('//') ? `https:${url}` : url
  return clean.replace(/t_[a-z_]+/, size)
}

function timeAgo(dateStr: string): string {
  const diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000)
  if (diff < 60) return `${diff}s`
  if (diff < 3600) return `${Math.floor(diff / 60)}m`
  if (diff < 86400) return `${Math.floor(diff / 3600)}h`
  return `${Math.floor(diff / 86400)}d`
}

function scoreColor(score: number): string {
  if (score >= 9) return "score-great"
  if (score >= 7) return "score-good"
  if (score >= 5) return "score-mid"
  return "score-low"
}

function getInitials(username: string): string {
  return username.slice(0, 2).toUpperCase()
}

function formatCount(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k'
  return String(n)
}

function getVoteCounts(votes: any[]) {
  const up = (votes ?? []).filter((v: any) => v.vote === 1).length;
  const down = (votes ?? []).filter((v: any) => v.vote === -1).length;
  return { up, down };
}
