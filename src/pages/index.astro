---
import { getSupabase } from "../utils/database";
const supabase = getSupabase();

type Platform = { id: string; name: string; slug: string; };

type Review = {
  id: string;
  score: number;
  title: string;
  body: string;
  play_time_years: number | null;
  play_time_months: number | null;
  play_time_weeks: number | null;
  play_time_days: number | null;
  play_time_hours: number;
  contains_spoilers: boolean;
  status: string;
  published_at: string;
  created_at: string;
  edited: boolean;
  played_on: Platform | null;
  games: {
    id: string;
    title: string;
    slug: string;
    cover_img_url: string | null;
    platform: string | null;
    developers: { id: string; name: string; slug: string; } | null;
    publishers: { id: string; name: string; slug: string; } | null;
  } | null;
  profiles: {
    id: string;
    username: string;
    avatar_url: string | null;
  } | null;
}

const { data: rawReviews, error } = await (supabase as any)
  .from("reviews")
  .select(`
    id, score, title, body,
    play_time_years, play_time_months, play_time_weeks,
    play_time_days, play_time_hours,
    contains_spoilers, status, published_at, created_at, edited,
    played_on:platform_played_on ( id, name, slug ),
    games (
      id, title, slug, cover_img_url, platform,
      developers:developer_id ( id, name, slug ),
      publishers:publisher_id ( id, name, slug )
    ),
    profiles ( id, username, avatar_url )
  `)
  .eq("status", "published")
  .order("published_at", { ascending: false })
  .limit(30);

if (error) console.error("Error fetching reviews:", error);

const reviews = rawReviews as Review[] | null;

const placeholderReviews: Review[] = [
  {
    id: "1",
    score: 9,
    title: "A masterpiece that redefines the genre",
    body: "Elden Ring is FromSoftware's magnum opus. The open world feels genuinely dangerous and alive, every corner hides something worth discovering. The bosses are brutal but fair, and the lore rewards those willing to dig deep.",
    play_time_years: null,
    play_time_months: null,
    play_time_weeks: null,
    play_time_days: 1,
    play_time_hours: 87,
    contains_spoilers: false,
    status: "published",
    published_at: new Date(Date.now() - 1000 * 60 * 14).toISOString(),
    created_at: new Date(Date.now() - 1000 * 60 * 13).toISOString(),
    edited: false,
    played_on: { id: "p1", name: "PC (Windows)", slug: "pc-windows" },
    games: {
      id: "g1",
      title: "Elden Ring",
      slug: "elden-ring",
      cover_img_url: null,
      platform: "PC (Windows)",
      developers: { id: "d1", name: "FromSoftware", slug: "fromsoftware" },
      publishers: { id: "d2", name: "Bandai Namco", slug: "bandai-namco" },
    },
    profiles: { id: "u1", username: "ashen_one", avatar_url: null }
  },
  {
    id: "2",
    score: 7,
    title: "Gorgeous but hollow",
    body: "Starfield has incredible vibes and I love the ship building, but after 40 hours the repetition really sets in. Procedurally generated planets feel empty. Still worth it for the main quest and faction storylines.",
    play_time_years: null,
    play_time_months: null,
    play_time_weeks: null,
    play_time_days: null,
    play_time_hours: 43,
    contains_spoilers: false,
    status: "published",
    published_at: new Date(Date.now() - 1000 * 60 * 60 * 2).toISOString(),
    created_at: new Date(Date.now() - 1000 * 60 * 13).toISOString(),
    edited: false,
    played_on: { id: "p2", name: "Xbox Series X/S", slug: "xbox-series-xs" },
    games: {
      id: "g2",
      title: "Starfield",
      slug: "starfield",
      cover_img_url: null,
      platform: "Xbox Series X/S",
      developers: { id: "d3", name: "Bethesda Game Studios", slug: "bethesda-game-studios" },
      publishers: { id: "d4", name: "Bethesda Softworks", slug: "bethesda-softworks" },
    },
    profiles: { id: "u2", username: "void_walker", avatar_url: null }
  },
  {
    id: "3",
    score: 10,
    title: "The best game I've played in a decade",
    body: "Baldur's Gate 3 is a miracle. The sheer breadth of choices, the writing, the acting — nothing comes close. I finished my first playthrough at 120 hours and immediately started a second.",
    play_time_years: null,
    play_time_months: null,
    play_time_weeks: null,
    play_time_days: null,
    play_time_hours: 120,
    contains_spoilers: false,
    status: "published",
    published_at: new Date(Date.now() - 1000 * 60 * 60 * 5).toISOString(),
    created_at: new Date(Date.now() - 1000 * 60 * 13).toISOString(),
    edited: false,
    played_on: { id: "p1", name: "PC (Windows)", slug: "pc-windows" },
    games: {
      id: "g3",
      title: "Baldur's Gate 3",
      slug: "baldurs-gate-iii",
      cover_img_url: null,
      platform: "PC (Windows)",
      developers: { id: "d5", name: "Larian Studios", slug: "larian-studios" },
      publishers: { id: "d5", name: "Larian Studios", slug: "larian-studios" },
    },
    profiles: { id: "u3", username: "tavern_keeper", avatar_url: null }
  },
];

const feedData: Review[] = (reviews && reviews.length > 0) ? reviews as Review[] : placeholderReviews;

function timeAgo(dateStr: string): string {
  const now = Date.now();
  const then = new Date(dateStr).getTime();
  const diff = Math.floor((now - then) / 1000);
  if (diff < 60) return `${diff}s`;
  if (diff < 3600) return `${Math.floor(diff / 60)}m`;
  if (diff < 86400) return `${Math.floor(diff / 3600)}h`;
  return `${Math.floor(diff / 86400)}d`;
}

function scoreColor(score: number): string {
  if (score >= 9) return "score-great";
  if (score >= 7) return "score-good";
  if (score >= 5) return "score-mid";
  return "score-low";
}

function getInitials(username: string): string {
  return username.slice(0, 2).toUpperCase();
}
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cartridge — Game Reviews</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    :root[data-theme="light"] {
      --bg: #f9f8f6;
      --bg-card: #ffffff;
      --bg-hover: #f4f3f0;
      --bg-sidebar: #ffffff;
      --border: #e8e6e1;
      --border-subtle: #f0ede8;
      --text-primary: #141412;
      --text-secondary: #6b6860;
      --text-tertiary: #a09d98;
      --accent: #141412;
      --accent-text: #ffffff;
      --score-great: #1a6b3c;
      --score-great-bg: #eaf5ee;
      --score-good: #1a4a6b;
      --score-good-bg: #eaf0f5;
      --score-mid: #6b5a1a;
      --score-mid-bg: #f5f0ea;
      --score-low: #6b1a1a;
      --score-low-bg: #f5eaea;
      --logo-color: #141412;
      --tag-bg: #f0ede8;
      --tag-text: #6b6860;
      --divider: #e8e6e1;
      --shadow: 0 1px 3px rgba(0,0,0,0.06);
      --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
    }

    :root[data-theme="dark"] {
      --bg: #0f0f0e;
      --bg-card: #1a1a18;
      --bg-hover: #222220;
      --bg-sidebar: #141412;
      --border: #2a2a27;
      --border-subtle: #222220;
      --text-primary: #f0ede8;
      --text-secondary: #908d87;
      --text-tertiary: #5a5855;
      --accent: #f0ede8;
      --accent-text: #141412;
      --score-great: #4ade80;
      --score-great-bg: #0d2b1a;
      --score-good: #60a5fa;
      --score-good-bg: #0d1e2b;
      --score-mid: #fbbf24;
      --score-mid-bg: #2b1f0d;
      --score-low: #f87171;
      --score-low-bg: #2b0d0d;
      --logo-color: #f0ede8;
      --tag-bg: #2a2a27;
      --tag-text: #908d87;
      --divider: #2a2a27;
      --shadow: 0 1px 3px rgba(0,0,0,0.3);
      --shadow-md: 0 4px 12px rgba(0,0,0,0.4);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text-primary);
      min-height: 100vh;
      transition: background 0.2s ease, color 0.2s ease;
      -webkit-font-smoothing: antialiased;
    }

    a { color: inherit; text-decoration: none; }

    .layout {
      display: grid;
      grid-template-columns: 240px 1fr 280px;
      max-width: 1140px;
      margin: 0 auto;
      min-height: 100vh;
      gap: 0;
    }

    @media (max-width: 1000px) {
      .layout { grid-template-columns: 200px 1fr; }
      .sidebar-right { display: none; }
    }
    @media (max-width: 680px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar-left { display: none; }
    }

    .sidebar-left {
      position: sticky;
      top: 0;
      height: 100vh;
      padding: 28px 20px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      border-right: 1px solid var(--border);
      background: var(--bg-sidebar);
    }

    .logo {
      font-family: 'DM Serif Display', serif;
      font-size: 22px;
      color: var(--logo-color);
      letter-spacing: -0.5px;
      padding: 8px 12px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .logo-dot {
      width: 8px;
      height: 8px;
      background: var(--text-primary);
      border-radius: 50%;
      display: inline-block;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 12px;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 400;
      color: var(--text-secondary);
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }

    .nav-item:hover, .nav-item.active {
      background: var(--bg-hover);
      color: var(--text-primary);
    }

    .nav-item.active { font-weight: 500; }

    .nav-icon {
      width: 18px;
      height: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .nav-divider {
      height: 1px;
      background: var(--border);
      margin: 10px 0;
    }

    .sidebar-bottom {
      margin-top: auto;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .theme-toggle {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 12px;
      border-radius: 10px;
      cursor: pointer;
      font-size: 15px;
      color: var(--text-secondary);
      background: none;
      border: none;
      font-family: inherit;
      width: 100%;
      text-align: left;
      transition: background 0.15s, color 0.15s;
    }
    .theme-toggle:hover { background: var(--bg-hover); color: var(--text-primary); }

    .feed {
      border-right: 1px solid var(--border);
      min-height: 100vh;
    }

    .feed-header {
      position: sticky;
      top: 0;
      background: var(--bg-card);
      border-bottom: 1px solid var(--border);
      padding: 16px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      z-index: 10;
      backdrop-filter: blur(8px);
    }

    .feed-title {
      font-size: 17px;
      font-weight: 500;
      letter-spacing: -0.2px;
    }

    .feed-subtitle {
      font-size: 13px;
      color: var(--text-tertiary);
      margin-top: 1px;
    }

    .new-review-btn {
      background: var(--accent);
      color: var(--accent-text);
      border: none;
      border-radius: 20px;
      padding: 8px 18px;
      font-size: 14px;
      font-weight: 500;
      font-family: inherit;
      cursor: pointer;
      transition: opacity 0.15s;
    }
    .new-review-btn:hover { opacity: 0.85; }

    .review-card {
      padding: 18px 20px;
      border-bottom: 1px solid var(--border-subtle);
      transition: background 0.15s;
      cursor: pointer;
    }
    .review-card:hover { background: var(--bg-hover); }

    .card-top {
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }

    .avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--bg-hover);
      border: 1px solid var(--border);
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-secondary);
      overflow: hidden;
    }

    .avatar img { width: 100%; height: 100%; object-fit: cover; }

    .card-body { flex: 1; min-width: 0; }

    .card-meta {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 6px;
      flex-wrap: wrap;
    }

    .username { font-size: 14px; font-weight: 500; }
    .meta-dot { color: var(--text-tertiary); font-size: 12px; }
    .timestamp { font-size: 13px; color: var(--text-tertiary); }

    .game-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }

    .game-cover {
      width: 32px;
      height: 32px;
      border-radius: 6px;
      background: var(--tag-bg);
      border: 1px solid var(--border);
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      overflow: hidden;
    }

    .game-cover img { width: 100%; height: 100%; object-fit: cover; }

    .game-info { flex: 1; min-width: 0; }

    .game-title {
      font-size: 14px;
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .game-developer { font-size: 12px; color: var(--text-tertiary); }

    .score-badge {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      font-weight: 500;
      font-family: 'DM Serif Display', serif;
    }

    .score-great { color: var(--score-great); background: var(--score-great-bg); }
    .score-good  { color: var(--score-good);  background: var(--score-good-bg);  }
    .score-mid   { color: var(--score-mid);   background: var(--score-mid-bg);   }
    .score-low   { color: var(--score-low);   background: var(--score-low-bg);   }

    .review-title {
      font-family: 'DM Serif Display', serif;
      font-size: 16px;
      line-height: 1.35;
      margin-bottom: 5px;
      letter-spacing: -0.2px;
    }

    .review-body {
      font-size: 14px;
      line-height: 1.6;
      color: var(--text-secondary);
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .spoiler-pill {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: var(--tag-bg);
      color: var(--tag-text);
      font-size: 11px;
      font-weight: 500;
      padding: 2px 8px;
      border-radius: 20px;
      margin-bottom: 6px;
      letter-spacing: 0.3px;
      text-transform: uppercase;
    }

    .card-footer {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 10px;
      padding-top: 10px;
    }

    .footer-tag {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: var(--tag-bg);
      color: var(--tag-text);
      font-size: 12px;
      padding: 3px 9px;
      border-radius: 6px;
    }

    .read-more {
      margin-left: auto;
      font-size: 13px;
      color: var(--text-tertiary);
      font-weight: 400;
      transition: color 0.15s;
    }
    .review-card:hover .read-more { color: var(--text-primary); }

    .sidebar-right {
      padding: 28px 20px;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .widget {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 16px;
      box-shadow: var(--shadow);
    }

    .widget-title {
      font-size: 14px;
      font-weight: 500;
      margin-bottom: 14px;
      color: var(--text-primary);
    }

    .trending-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      border-bottom: 1px solid var(--border-subtle);
      cursor: pointer;
      transition: opacity 0.15s;
    }
    .trending-item:last-child { border-bottom: none; }
    .trending-item:hover { opacity: 0.7; }

    .trending-rank {
      font-size: 12px;
      color: var(--text-tertiary);
      width: 16px;
      flex-shrink: 0;
      font-weight: 500;
    }

    .trending-info { flex: 1; min-width: 0; }

    .trending-game {
      font-size: 13px;
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .trending-count { font-size: 12px; color: var(--text-tertiary); margin-top: 1px; }

    .stat-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 6px 0;
    }

    .stat-label { font-size: 13px; color: var(--text-secondary); }
    .stat-value { font-size: 14px; font-weight: 500; }

    .empty-state {
      padding: 60px 20px;
      text-align: center;
      color: var(--text-tertiary);
    }
    .empty-state-title {
      font-family: 'DM Serif Display', serif;
      font-size: 20px;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }
    .empty-state-sub { font-size: 14px; }
  </style>
</head>

<body>
  <div class="layout">

    <!-- Left sidebar -->
    <aside class="sidebar-left">
      <div class="logo">
        <span class="logo-dot"></span>
        Cartridge
      </div>

      <a href="/" class="nav-item active">
        <span class="nav-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 7L9 2L16 7V16H11V11H7V16H2V7Z"/>
          </svg>
        </span>
        Home
      </a>

      <a href="/explore" class="nav-item">
        <span class="nav-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="9" r="7"/>
            <path d="M12 6L9.5 9.5L6 12L8.5 8.5L12 6Z"/>
          </svg>
        </span>
        Explore
      </a>

      <a href="/games" class="nav-item">
        <span class="nav-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="14" height="10" rx="2"/>
            <path d="M6 9H8M7 8V10M11 9H11.01M12.5 9H12.51"/>
          </svg>
        </span>
        Games
      </a>

      <a href="/reviews" class="nav-item">
        <span class="nav-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 4h12M3 8h8M3 12h5"/>
          </svg>
        </span>
        Reviews
      </a>

      <div class="nav-divider"></div>

      <a href="/profile" class="nav-item">
        <span class="nav-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="6" r="3"/>
            <path d="M3 16c0-3.314 2.686-6 6-6s6 2.686 6 6"/>
          </svg>
        </span>
        Profile
      </a>

      <div class="sidebar-bottom">
        <button class="theme-toggle" id="themeToggle" onclick="toggleTheme()">
          <span class="nav-icon" id="themeIcon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="9" r="3.5"/>
              <path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>
            </svg>
          </span>
          <span id="themeLabel">Light mode</span>
        </button>
      </div>
    </aside>

    <!-- Main feed -->
    <main class="feed">
      <div class="feed-header">
        <div>
          <div class="feed-title">Recent Reviews</div>
          <div class="feed-subtitle">{feedData.length} reviews loaded</div>
        </div>
        <button class="new-review-btn">+ Write a review</button>
      </div>

      {feedData.length === 0 ? (
        <div class="empty-state">
          <div class="empty-state-title">No reviews yet</div>
          <div class="empty-state-sub">Be the first to review a game.</div>
        </div>
      ) : (
        feedData.map((review) => (
          <article class="review-card">
            <div class="card-top">
              <div class="avatar">
                {review.profiles?.avatar_url
                  ? <img src={review.profiles.avatar_url} alt={review.profiles.username} />
                  : getInitials(review.profiles?.username ?? "??")
                }
              </div>

              <div class="card-body">
                <div class="card-meta">
                  <span class="username">@{review.profiles?.username ?? "unknown"}</span>
                  <span class="meta-dot">·</span>
                  <span class="timestamp">{timeAgo(review.published_at ?? review.created_at)}</span>
                </div>

                <div class="game-row">
                  <div class="game-cover">
                    {review.games?.cover_img_url
                      ? <img src={review.games.cover_img_url} alt={review.games.title} />
                      : "🎮"
                    }
                  </div>
                  <div class="game-info">
                    <div class="game-title">{review.games?.title ?? "Unknown Game"}</div>
                    <div class="game-developer">{review.games?.developers?.name ?? ""}</div>
                  </div>
                  <div class={`score-badge ${scoreColor(review.score)}`}>
                    {review.score}
                  </div>
                </div>

                {review.contains_spoilers && (
                  <div class="spoiler-pill">⚠ spoilers</div>
                )}

                {review.title && (
                  <div class="review-title">{review.title}</div>
                )}

                <div class="review-body">{review.body}</div>

                <div class="card-footer">
                  {review.played_on && (
                    <span class="footer-tag">{review.played_on.name}</span>
                  )}
                  {review.play_time_hours && (
                    <span class="footer-tag">{review.play_time_hours}h played</span>
                  )}
                  <span class="read-more">Read more →</span>
                </div>
              </div>
            </div>
          </article>
        ))
      )}
    </main>

    <!-- Right sidebar -->
    <aside class="sidebar-right">
      <div class="widget">
        <div class="widget-title">Trending this week</div>
        {[
          { title: "Elden Ring", count: "1.2k reviews" },
          { title: "Baldur's Gate 3", count: "984 reviews" },
          { title: "Tears of the Kingdom", count: "761 reviews" },
          { title: "Starfield", count: "602 reviews" },
          { title: "Alan Wake 2", count: "438 reviews" },
        ].map((game, i) => (
          <div class="trending-item">
            <span class="trending-rank">{i + 1}</span>
            <div class="trending-info">
              <div class="trending-game">{game.title}</div>
              <div class="trending-count">{game.count}</div>
            </div>
          </div>
        ))}
      </div>

      <div class="widget">
        <div class="widget-title">Site stats</div>
        {[
          { label: "Total reviews", value: "—" },
          { label: "Games tracked", value: "—" },
          { label: "Active reviewers", value: "—" },
        ].map((stat) => (
          <div class="stat-row">
            <span class="stat-label">{stat.label}</span>
            <span class="stat-value">{stat.value}</span>
          </div>
        ))}
      </div>
    </aside>

  </div>

  <script>
    function toggleTheme() {
      const html = document.documentElement;
      const current = html.getAttribute('data-theme');
      const next = current === 'light' ? 'dark' : 'light';
      html.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      updateThemeUI(next);
    }

    function updateThemeUI(theme: string) {
      const label = document.getElementById('themeLabel');
      const icon = document.getElementById('themeIcon');
      if (!label || !icon) return;
      if (theme === 'dark') {
        label.textContent = 'Dark mode';
        icon.innerHTML = `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10.5A7 7 0 016.5 3a7 7 0 100 12 7 7 0 008.5-4.5z"/></svg>`;
      } else {
        label.textContent = 'Light mode';
        icon.innerHTML = `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="9" r="3.5"/><path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/></svg>`;
      }
    }

    (window as any).toggleTheme = toggleTheme;

    const saved = localStorage.getItem('theme') ||
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    document.documentElement.setAttribute('data-theme', saved);
    updateThemeUI(saved);
  </script>
</body>
</html>
