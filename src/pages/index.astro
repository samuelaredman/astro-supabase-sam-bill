<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>Cartridge — Game Reviews</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    :root[data-theme="light"] {
      --bg: #f9f8f6; --bg-card: #ffffff; --bg-hover: #f4f3f0; --bg-sidebar: #ffffff;
      --border: #e8e6e1; --border-subtle: #f0ede8;
      --text-primary: #141412; --text-secondary: #6b6860; --text-tertiary: #a09d98;
      --accent: #141412; --accent-text: #ffffff; --logo-color: #141412;
      --tag-bg: #f0ede8; --tag-text: #6b6860;
      --shadow: 0 1px 3px rgba(0,0,0,0.06); --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
      --score-great: #1a6b3c; --score-great-bg: #eaf5ee;
      --score-good: #1a4a6b; --score-good-bg: #eaf0f5;
      --score-mid: #6b5a1a; --score-mid-bg: #f5f0ea;
      --score-low: #6b1a1a; --score-low-bg: #f5eaea;
    }
    :root[data-theme="dark"] {
      --bg: #0f0f0e; --bg-card: #1a1a18; --bg-hover: #222220; --bg-sidebar: #141412;
      --border: #2a2a27; --border-subtle: #222220;
      --text-primary: #f0ede8; --text-secondary: #908d87; --text-tertiary: #5a5855;
      --accent: #f0ede8; --accent-text: #141412; --logo-color: #f0ede8;
      --tag-bg: #2a2a27; --tag-text: #908d87;
      --shadow: 0 1px 3px rgba(0,0,0,0.3); --shadow-md: 0 4px 12px rgba(0,0,0,0.4);
      --score-great: #4ade80; --score-great-bg: #0d2b1a;
      --score-good: #60a5fa; --score-good-bg: #0d1e2b;
      --score-mid: #fbbf24; --score-mid-bg: #2b1f0d;
      --score-low: #f87171; --score-low-bg: #2b0d0d;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text-primary); min-height: 100vh; -webkit-font-smoothing: antialiased; transition: background 0.2s, color 0.2s; }
    a { color: inherit; text-decoration: none; }

    .layout { display: grid; grid-template-columns: 240px 1fr 280px; max-width: 1140px; margin: 0 auto; min-height: 100vh; }
    @media (max-width: 1000px) { .layout { grid-template-columns: 200px 1fr; } .sidebar-right { display: none; } }
    @media (max-width: 680px) { .layout { grid-template-columns: 1fr; } .sidebar-left { display: none; } }

    /* SIDEBAR LEFT */
    .sidebar-left { position: sticky; top: 0; height: 100vh; padding: 28px 20px; display: flex; flex-direction: column; gap: 6px; border-right: 1px solid var(--border); background: var(--bg-sidebar); }
    .logo { font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--logo-color); padding: 8px 12px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .logo-dot { width: 8px; height: 8px; background: var(--text-primary); border-radius: 50%; }
    .nav-item { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 10px; font-size: 15px; color: var(--text-secondary); transition: background 0.15s, color 0.15s; }
    .nav-item:hover, .nav-item.active { background: var(--bg-hover); color: var(--text-primary); }
    .nav-item.active { font-weight: 500; }
    .nav-icon { width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .nav-divider { height: 1px; background: var(--border); margin: 10px 0; }
    .sidebar-bottom { margin-top: auto; }
    .theme-toggle { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 10px; cursor: pointer; font-size: 15px; color: var(--text-secondary); background: none; border: none; font-family: inherit; width: 100%; text-align: left; transition: background 0.15s, color 0.15s; }
    .theme-toggle:hover { background: var(--bg-hover); color: var(--text-primary); }

    /* MAIN FEED */
    .feed { border-right: 1px solid var(--border); min-height: 100vh; }
    .feed-header { position: sticky; top: 0; background: var(--bg-card); border-bottom: 1px solid var(--border); padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; z-index: 10; backdrop-filter: blur(8px); }
    .feed-title { font-size: 17px; font-weight: 500; letter-spacing: -0.2px; }
    .feed-subtitle { font-size: 13px; color: var(--text-tertiary); margin-top: 1px; }
    .new-review-btn { background: var(--accent); color: var(--accent-text); border: none; border-radius: 20px; padding: 8px 18px; font-size: 14px; font-weight: 500; font-family: inherit; cursor: pointer; transition: opacity 0.15s; white-space: nowrap; }
    .new-review-btn:hover { opacity: 0.85; }

    /* HERO */
    .hero { position: relative; overflow: hidden; background: #0a0a0a; min-height: 220px; display: flex; align-items: flex-end; }
    .hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center 30%; opacity: 0.4; filter: blur(2px) saturate(1.4); transform: scale(1.05); }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0.6) 50%, rgba(10,10,10,0.2) 100%); }
    .hero-content { position: relative; z-index: 2; padding: 28px 24px; display: flex; align-items: flex-end; gap: 20px; width: 100%; }
    .hero-cover { width: 90px; height: 120px; border-radius: 10px; object-fit: cover; box-shadow: 0 8px 32px rgba(0,0,0,0.6); flex-shrink: 0; border: 1px solid rgba(255,255,255,0.1); }
    .hero-cover-placeholder { width: 90px; height: 120px; border-radius: 10px; background: #222; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 36px; }
    .hero-info { flex: 1; min-width: 0; }
    .hero-label { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px; }
    .hero-title { font-family: 'DM Serif Display', serif; font-size: 26px; color: #fff; line-height: 1.2; margin-bottom: 8px; letter-spacing: -0.3px; }
    .hero-score { display: inline-flex; align-items: center; gap: 6px; }
    .hero-score-num { font-family: 'DM Serif Display', serif; font-size: 22px; color: #4ade80; }
    .hero-score-label { font-size: 12px; color: rgba(255,255,255,0.5); }
    .hero-cta { display: inline-block; margin-top: 10px; background: rgba(255,255,255,0.15); color: #fff; border: 1px solid rgba(255,255,255,0.2); border-radius: 20px; padding: 6px 14px; font-size: 13px; backdrop-filter: blur(8px); transition: background 0.15s; }
    .hero-cta:hover { background: rgba(255,255,255,0.25); }

    /* TOP RATED ROW */
    .section-block { padding: 20px 20px 0; border-bottom: 1px solid var(--border-subtle); }
    .section-block-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .section-block-title { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary); }
    .section-block-link { font-size: 12px; color: var(--text-tertiary); transition: color 0.15s; }
    .section-block-link:hover { color: var(--text-primary); }
    .top-rated-scroll { display: flex; gap: 10px; overflow-x: auto; padding-bottom: 20px; scrollbar-width: none; }
    .top-rated-scroll::-webkit-scrollbar { display: none; }
    .top-rated-card { flex-shrink: 0; width: 100px; display: block; }
    .top-rated-card:hover .top-rated-cover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
    .top-rated-cover { width: 100px; height: 133px; border-radius: 8px; object-fit: cover; border: 1px solid var(--border); transition: transform 0.15s, box-shadow 0.15s; display: block; background: var(--tag-bg); }
    .top-rated-cover-placeholder { width: 100px; height: 133px; border-radius: 8px; border: 1px solid var(--border); background: var(--tag-bg); display: flex; align-items: center; justify-content: center; font-size: 28px; }
    .top-rated-info { margin-top: 6px; }
    .top-rated-title { font-size: 11px; font-weight: 500; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; color: var(--text-secondary); }
    .top-rated-score { font-size: 11px; font-weight: 600; margin-top: 2px; }
    .top-rated-score.score-great { color: var(--score-great); }
    .top-rated-score.score-good { color: var(--score-good); }
    .top-rated-score.score-mid { color: var(--score-mid); }
    .top-rated-score.score-low { color: var(--score-low); }

    /* GENRE CHIPS */
    .genre-section { padding: 16px 20px; border-bottom: 1px solid var(--border-subtle); display: flex; gap: 6px; flex-wrap: wrap; }
    .genre-chip { background: var(--tag-bg); color: var(--tag-text); font-size: 12px; font-weight: 500; padding: 5px 12px; border-radius: 20px; transition: all 0.15s; white-space: nowrap; }
    .genre-chip:hover { background: var(--bg-hover); color: var(--text-primary); }

    /* REVIEW CARDS */
    .review-card { padding: 18px 20px; border-bottom: 1px solid var(--border-subtle); transition: background 0.15s; cursor: pointer; }
    .review-card:hover { background: var(--bg-hover); }
    .card-top { display: flex; gap: 12px; align-items: flex-start; }
    .avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--tag-bg); border: 1px solid var(--border); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 500; color: var(--text-secondary); overflow: hidden; }
    .avatar img { width: 100%; height: 100%; object-fit: cover; }
    .card-body { flex: 1; min-width: 0; }
    .card-meta { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; flex-wrap: wrap; }
    .username { font-size: 14px; font-weight: 500; }
    .meta-dot { color: var(--text-tertiary); font-size: 12px; }
    .timestamp { font-size: 13px; color: var(--text-tertiary); }
    .game-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
    .game-cover-sm { width: 32px; height: 32px; border-radius: 6px; background: var(--tag-bg); border: 1px solid var(--border); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 14px; overflow: hidden; }
    .game-cover-sm img { width: 100%; height: 100%; object-fit: cover; }
    .game-title-text { font-size: 14px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; min-width: 0; }
    .score-badge { flex-shrink: 0; width: 34px; height: 34px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 600; font-family: 'DM Serif Display', serif; }
    .score-great { color: var(--score-great); background: var(--score-great-bg); }
    .score-good { color: var(--score-good); background: var(--score-good-bg); }
    .score-mid { color: var(--score-mid); background: var(--score-mid-bg); }
    .score-low { color: var(--score-low); background: var(--score-low-bg); }
    .review-title { font-family: 'DM Serif Display', serif; font-size: 16px; line-height: 1.35; margin-bottom: 5px; letter-spacing: -0.2px; }
    .review-body { font-size: 14px; line-height: 1.6; color: var(--text-secondary); display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .spoiler-pill { display: inline-flex; align-items: center; gap: 4px; background: var(--tag-bg); color: var(--tag-text); font-size: 11px; font-weight: 500; padding: 2px 8px; border-radius: 20px; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.3px; }
    .review-body.spoiler-hidden {filter: blur(4px); user-select: none; cursor: pointer; transition: filter 0.2s;}
    .review-body.spoiler-hidden:hover {filter: blur(3px);}
    .card-footer { display: flex; align-items: center; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
    .footer-tag { background: var(--tag-bg); color: var(--tag-text); font-size: 12px; padding: 3px 9px; border-radius: 6px; }
    .read-more { margin-left: auto; font-size: 13px; color: var(--text-tertiary); transition: color 0.15s; }
    .review-card:hover .read-more { color: var(--text-primary); }
    .vote-row { display: flex; align-items: center; gap: 6px; margin-top: 10px; }
    .vote-btn { display: flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 20px; border: 1px solid var(--border); background: none; font-size: 12px; font-family: inherit; color: var(--text-tertiary); cursor: pointer; transition: all 0.15s; }
    .vote-btn:hover { border-color: var(--text-secondary); color: var(--text-primary); }
    .vote-btn.active-up { background: var(--score-great-bg); color: var(--score-great); border-color: var(--score-great); }
    .vote-btn.active-down { background: var(--score-low-bg); color: var(--score-low); border-color: var(--score-low); }

    .empty-state { padding: 60px 20px; text-align: center; color: var(--text-tertiary); }
    .empty-state-title { font-family: 'DM Serif Display', serif; font-size: 20px; color: var(--text-secondary); margin-bottom: 8px; }

    /* SIDEBAR RIGHT */
    .sidebar-right { padding: 28px 20px; display: flex; flex-direction: column; gap: 20px; }
    .widget { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 16px; box-shadow: var(--shadow); }
    .widget-title { font-size: 14px; font-weight: 500; margin-bottom: 14px; }
    .trending-item { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border-subtle); transition: opacity 0.15s; }
    .trending-item:last-child { border-bottom: none; padding-bottom: 0; }
    .trending-item:hover { opacity: 0.7; }
    .trending-rank { font-size: 12px; color: var(--text-tertiary); width: 16px; flex-shrink: 0; font-weight: 500; }
    .trending-cover { width: 32px; height: 32px; border-radius: 5px; object-fit: cover; flex-shrink: 0; background: var(--tag-bg); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 14px; overflow: hidden; }
    .trending-cover img { width: 100%; height: 100%; object-fit: cover; }
    .trending-info { flex: 1; min-width: 0; }
    .trending-game { font-size: 13px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .trending-count { font-size: 12px; color: var(--text-tertiary); margin-top: 1px; }
    .stat-row { display: flex; justify-content: space-between; align-items: center; padding: 7px 0; border-bottom: 1px solid var(--border-subtle); }
    .stat-row:last-child { border-bottom: none; padding-bottom: 0; }
    .stat-label { font-size: 13px; color: var(--text-secondary); }
    .stat-value { font-size: 14px; font-weight: 600; }
    .genre-chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .widget-genre-chip { background: var(--tag-bg); color: var(--tag-text); font-size: 12px; padding: 4px 10px; border-radius: 20px; transition: all 0.15s; display: inline-block; }
    .widget-genre-chip:hover { background: var(--bg-hover); color: var(--text-primary); }

    /* COMPOSER */
    .composer { border-bottom: 1px solid var(--border); background: var(--bg-card); }
    .composer-inner { padding: 16px 20px; display: flex; flex-direction: column; gap: 14px; }
    .composer-field { display: flex; flex-direction: column; gap: 6px; }
    .composer-row { display: flex; gap: 12px; align-items: flex-end; }
    .composer-label { font-size: 11px; font-weight: 600; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.5px; }
    .composer-input, .composer-select { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 9px 12px; font-size: 14px; font-family: inherit; color: var(--text-primary); width: 100%; outline: none; transition: border-color 0.15s; }
    .composer-input:focus, .composer-select:focus { border-color: var(--text-secondary); }
    .composer-textarea { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 9px 12px; font-size: 14px; font-family: inherit; color: var(--text-primary); width: 100%; outline: none; resize: vertical; min-height: 90px; transition: border-color 0.15s; line-height: 1.5; }
    .composer-textarea:focus { border-color: var(--text-secondary); }
    .score-picker { display: flex; gap: 6px; flex-wrap: wrap; }
    .score-btn { width: 36px; height: 36px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg); color: var(--text-secondary); font-size: 14px; font-weight: 500; cursor: pointer; font-family: inherit; transition: all 0.12s; }
    .score-btn:hover { border-color: var(--text-secondary); color: var(--text-primary); }
    .score-btn.selected { background: var(--accent); color: var(--accent-text); border-color: var(--accent); }
    .autocomplete-wrap { position: relative; }
    .autocomplete-results { position: absolute; top: calc(100% + 4px); left: 0; right: 0; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; z-index: 100; max-height: 200px; overflow-y: auto; display: none; box-shadow: var(--shadow-md); }
    .autocomplete-results.open { display: block; }
    .autocomplete-item { padding: 10px 14px; font-size: 14px; cursor: pointer; display: flex; align-items: center; gap: 10px; transition: background 0.1s; }
    .autocomplete-item:hover { background: var(--bg-hover); }
    .autocomplete-item-title { font-weight: 500; }
    .composer-actions { display: flex; align-items: center; gap: 12px; padding-top: 4px; }
    .spoiler-toggle { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--text-secondary); cursor: pointer; }
    .composer-cancel { padding: 8px 16px; border-radius: 20px; border: 1px solid var(--border); background: none; font-size: 14px; font-family: inherit; color: var(--text-secondary); cursor: pointer; transition: background 0.15s; }
    .composer-cancel:hover { background: var(--bg-hover); }
    .composer-submit { padding: 8px 18px; border-radius: 20px; border: none; background: var(--accent); color: var(--accent-text); font-size: 14px; font-weight: 500; font-family: inherit; cursor: pointer; transition: opacity 0.15s; }
    .composer-submit:hover { opacity: 0.85; }
    .composer-submit:disabled { opacity: 0.45; cursor: not-allowed; }
    .composer-error { font-size: 13px; color: #c0392b; min-height: 18px; }
  </style>
</head>

<body>
<div class="layout">

  <aside class="sidebar-left">
    <div class="logo"><span class="logo-dot"></span>Cartridge</div>
    <a href="/" class="nav-item active">
      <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7L9 2L16 7V16H11V11H7V16H2V7Z"/></svg></span>
      Home
    </a>
    <a href="/search" class="nav-item">
      <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="5"/><path d="M13 13l3 3"/></svg></span>
      Search
    </a>
    <div class="nav-divider"></div>
    <a href="/profile" class="nav-item">
      <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="6" r="3"/><path d="M3 16c0-3.314 2.686-6 6-6s6 2.686 6 6"/></svg></span>
      Profile
    </a>
    <div class="sidebar-bottom">
      <button class="theme-toggle" id="themeToggle">
        <span class="nav-icon" id="themeIcon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="9" r="3.5"/><path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/></svg>
        </span>
        <span id="themeLabel">Light mode</span>
      </button>
    </div>
  </aside>

  <main class="feed">
    <div class="feed-header">
      <div>
        <div class="feed-title">Recent Reviews</div>
        <div class="feed-subtitle">{reviews.length > 0 ? `${reviews.length} reviews` : 'Be the first to review a game'}</div>
      </div>
      <button class="new-review-btn" id="openComposer">+ Write a review</button>
    </div>

    <!-- HERO — featured top rated game -->
    {featuredGame && (
      <div class="hero">
        {igdbImage((featuredGame as any).cover, 't_1080p') && (
          <div
            class="hero-bg"
            style={`background-image: url('${igdbImage((featuredGame as any).cover, 't_1080p')}')`}
          ></div>
        )}
        <div class="hero-overlay"></div>
        <div class="hero-content">
          {igdbImage((featuredGame as any).cover)
            ? <img class="hero-cover" src={igdbImage((featuredGame as any).cover) ?? ''} alt={(featuredGame as any).title} />
            : <div class="hero-cover-placeholder">🎮</div>
          }
          <div class="hero-info">
            <div class="hero-label">Most Reviewed Today</div>
            <div class="hero-title">{(featuredGame as any).title}</div>
            <div class="hero-score">
              <span class="hero-score-num">{(featuredGame as any).count}</span>
              <span class="hero-score-label">{(featuredGame as any).count === 1 ? 'review' : 'reviews'} today</span>
            </div>
            <a href={`/games/${(featuredGame as any).slug}`} class="hero-cta">Read reviews →</a>
          </div>
        </div>
      </div>
    )}

    <!-- TOP RATED ROW -->
    {topRated.length > 0 && (
      <div class="section-block">
        <div class="section-block-header">
          <span class="section-block-title">Top Rated This Week</span>
          <a href="/search?sort=highest" class="section-block-link">See all →</a>
        </div>
        <div class="top-rated-scroll">
          {topRated.map((game: any) => (
            <a href={`/games/${game.slug}`} class="top-rated-card">
              {igdbImage(game.cover)
                ? <img class="top-rated-cover" src={igdbImage(game.cover) ?? ''} alt={game.title} loading="lazy" />
                : <div class="top-rated-cover-placeholder">🎮</div>
              }
              <div class="top-rated-info">
                <div class="top-rated-title">{game.title}</div>
                <div class={`top-rated-score ${scoreColor(game.avg_score)}`}>
                  ★ {game.avg_score.toFixed(1)}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- GENRE BROWSE CHIPS -->
    {(genres ?? []).length > 0 && (
      <div class="genre-section">
        {(genres ?? [])
          .filter((g: any) => featuredGenres.some(n => g.name.toLowerCase().includes(n.toLowerCase())))
          .slice(0, 10)
          .map((g: any) => (
            <a href={`/search?tab=games&genre=${g.id}`} class="genre-chip">{g.name}</a>
          ))
        }
      </div>
    )}

    <!-- COMPOSER -->
    <div class="composer" id="composer" style="display:none">
      <div class="composer-inner">
        <div class="composer-field">
          <label class="composer-label">Game</label>
          <div class="autocomplete-wrap">
            <input type="text" id="gameSearch" class="composer-input" placeholder="Search for a game..." autocomplete="off" />
            <div class="autocomplete-results" id="gameResults"></div>
          </div>
          <input type="hidden" id="gameId" />
        </div>
        <div class="composer-field">
          <label class="composer-label">Score</label>
          <div style="display:flex;align-items:center;gap:8px">
            <input
              type="number"
              id="scoreVal"
              class="composer-input"
              placeholder="0.0"
              min="0.1"
              max="10"
              step="0.1"
              style="width:90px"
            />
            <span style="font-size:15px;color:var(--text-tertiary);font-family:'DM Serif Display',serif">/ 10</span>
          </div>
        </div>
        <div class="composer-field">
          <label class="composer-label">Title</label>
          <input type="text" id="reviewTitle" class="composer-input" placeholder="Sum it up in a line..." maxlength="120" />
        </div>
        <div class="composer-field">
          <label class="composer-label">Review</label>
          <textarea id="reviewBody" class="composer-textarea" placeholder="Write your review..." rows="4"></textarea>
        </div>
        <div class="composer-row">
          <div class="composer-field" style="flex:1">
            <label class="composer-label">Platform played on</label>
            <select id="platformSelect" class="composer-select">
              <option value="">Select platform...</option>
              {(platforms ?? []).map((p: any) => (
                <option value={p.id}>{p.name}</option>
              ))}
            </select>
          </div>
          <div class="composer-field" style="width:120px">
            <label class="composer-label">Hours played</label>
            <input type="number" id="hoursPlayed" class="composer-input" placeholder="0" min="0" max="9999" />
          </div>
        </div>
        <div class="composer-actions">
          <label class="spoiler-toggle">
            <input type="checkbox" id="spoilerCheck" />
            <span>Contains spoilers</span>
          </label>
          <div style="display:flex;gap:8px;margin-left:auto">
            <button class="composer-cancel" id="cancelComposer">Cancel</button>
            <button class="composer-submit" id="submitReview">Post review</button>
          </div>
        </div>
        <div class="composer-error" id="composerError"></div>
      </div>
    </div>

    <!-- REVIEW FEED -->
    {reviews.length === 0 ? (
      <div class="empty-state">
        <div class="empty-state-title">No reviews yet</div>
        <p>Be the first to review a game.</p>
      </div>
    ) : (
      reviews.map((review) => (
        <article class="review-card">
          <div class="card-top">
            <div class="avatar">
              {review.profiles?.avatar_url
                ? <img src={review.profiles.avatar_url} alt={review.profiles.username} />
                : getInitials(review.profiles?.username ?? "??")
              }
            </div>
            <div class="card-body">
              <div class="card-meta">
                <a href={`/reviewers/${review.profiles?.username}`} class="username">@{review.profiles?.username ?? "unknown"}</a>
                <span class="meta-dot">·</span>
                <span class="timestamp">{timeAgo(review.published_at ?? review.created_at)}</span>
              </div>
              <div class="game-row">
                <a href={`/games/${review.games?.slug}`} class="game-cover-sm">
                  {review.games?.cover_img_url
                    ? <img src={igdbImage(review.games.cover_img_url, 't_thumb') ?? ''} alt={review.games.title} />
                    : "🎮"
                  }
                </a>
                <a href={`/games/${review.games?.slug}`} class="game-title-text">{review.games?.title ?? "Unknown Game"}</a>
                <div class={`score-badge ${scoreColor(review.score)}`}>{review.score}</div>
              </div>
              {review.contains_spoilers && <div class="spoiler-pill">⚠ spoilers</div>}
              {review.title && <div class="review-title">{review.title}</div>}
              <div class={`review-body ${review.contains_spoilers ? 'spoiler-hidden' : ''}`}
                  data-spoiler={review.contains_spoilers ? 'true' : 'false'}>
                {review.body}
              </div>
              <div class="card-footer">
                {review.played_on && <span class="footer-tag">{review.played_on.name}</span>}
                {review.play_time_hours > 0 && <span class="footer-tag">{review.play_time_hours}h played</span>}
                {(() => {
                  const { up, down } = getVoteCounts(review.review_votes);
                  return (
                    <div class="vote-row">
                      <button
                        class="vote-btn"
                        data-review-id={review.id}
                        data-vote="1"
                      >
                        ▲ {up}
                      </button>
                      <button
                        class="vote-btn"
                        data-review-id={review.id}
                        data-vote="-1"
                      >
                        ▼ {down}
                      </button>
                    </div>
                  );
                })()}
                <a href={`/reviews/${review.id}`} class="read-more">Read more →</a>
              </div>
            </div>
          </div>
        </article>
      ))
    )}
  </main>

  <aside class="sidebar-right">

    <!-- TRENDING THIS WEEK -->
    <div class="widget">
      <div class="widget-title">Trending this week</div>
      {trending.length === 0 ? (
        <div style="font-size:13px;color:var(--text-tertiary)">No activity yet this week.</div>
      ) : (
        trending.map((game, i) => (
          <a href={`/games/${game.slug}`} class="trending-item" style="display:flex">
            <span class="trending-rank">{i + 1}</span>
            <div class="trending-cover">
              {game.cover
                ? <img src={igdbImage(game.cover, 't_thumb') ?? ''} alt={game.title} />
                : '🎮'
              }
            </div>
            <div class="trending-info">
              <div class="trending-game">{game.title}</div>
              <div class="trending-count">{game.count} review{game.count !== 1 ? 's' : ''} this week</div>
            </div>
          </a>
        ))
      )}
    </div>

    <!-- SITE STATS -->
    <div class="widget">
      <div class="widget-title">Site stats</div>
      <div class="stat-row">
        <span class="stat-label">Total reviews</span>
        <span class="stat-value">{formatCount(totalReviews)}</span>
      </div>
      <div class="stat-row">
        <span class="stat-label">Games tracked</span>
        <span class="stat-value">{formatCount(totalGames)}</span>
      </div>
      <div class="stat-row">
        <span class="stat-label">Reviewers</span>
        <span class="stat-value">{formatCount(totalReviewers)}</span>
      </div>
    </div>


  </aside>

</div>

<script is:inline define:vars={{ isLoggedIn }}>
  // Theme
  function updateThemeUI(theme) {
    const label = document.getElementById('themeLabel')
    const icon = document.getElementById('themeIcon')
    if (!label || !icon) return
    if (theme === 'dark') {
      label.textContent = 'Dark mode'
      icon.innerHTML = '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10.5A7 7 0 016.5 3a7 7 0 100 12 7 7 0 008.5-4.5z"/></svg>'
    } else {
      label.textContent = 'Light mode'
      icon.innerHTML = '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="9" r="3.5"/><path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/></svg>'
    }
  }

  const saved = localStorage.getItem('theme') ||
    (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
  document.documentElement.setAttribute('data-theme', saved)
  updateThemeUI(saved)

  document.getElementById('themeToggle').addEventListener('click', () => {
    const next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light'
    document.documentElement.setAttribute('data-theme', next)
    localStorage.setItem('theme', next)
    updateThemeUI(next)
  })

  // Composer
  document.getElementById('openComposer').addEventListener('click', () => {
    if (!isLoggedIn) { window.location.href = '/signin'; return; }
    document.getElementById('composer').style.display = 'block'
    document.getElementById('gameSearch').focus()
  })

  document.getElementById('cancelComposer').addEventListener('click', () => {
    document.getElementById('composer').style.display = 'none'
    resetComposer()
  })

  function resetComposer() {
    document.getElementById('gameSearch').value = ''
    document.getElementById('gameId').value = ''
    document.getElementById('reviewTitle').value = ''
    document.getElementById('reviewBody').value = ''
    document.getElementById('hoursPlayed').value = ''
    document.getElementById('scoreVal').value = ''
    document.getElementById('platformSelect').value = ''
    document.getElementById('spoilerCheck').checked = false
    document.getElementById('composerError').textContent = ''
    document.querySelectorAll('.score-btn').forEach(b => b.classList.remove('selected'))
    document.getElementById('gameResults').classList.remove('open')
  }

  // Score picker
  document.querySelectorAll('.score-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.score-btn').forEach(b => b.classList.remove('selected'))
      btn.classList.add('selected')
      document.getElementById('scoreVal').value = btn.dataset.score
    })
  })

  // Game autocomplete
  let searchTimeout
  document.getElementById('gameSearch').addEventListener('input', (e) => {
    clearTimeout(searchTimeout)
    const q = e.target.value.trim()
    if (q.length < 2) { document.getElementById('gameResults').classList.remove('open'); return; }
    searchTimeout = setTimeout(() => searchGames(q), 300)
  })

  document.addEventListener('click', (e) => {
    if (!e.target.closest('.autocomplete-wrap')) {
      document.getElementById('gameResults').classList.remove('open')
    }
  })

  async function searchGames(q) {
    const res = await fetch('/api/games/search?q=' + encodeURIComponent(q))
    const games = await res.json()
    const results = document.getElementById('gameResults')
    results.innerHTML = ''
    if (!games.length) {
      results.innerHTML = '<div class="autocomplete-item" style="color:var(--text-tertiary)">No games found</div>'
    } else {
      games.forEach(game => {
        const item = document.createElement('div')
        item.className = 'autocomplete-item'
        item.innerHTML = '<div><div class="autocomplete-item-title">' + game.title + '</div></div>'
        item.addEventListener('click', () => {
          document.getElementById('gameSearch').value = game.title
          document.getElementById('gameId').value = game.id
          results.classList.remove('open')
        })
        // event listener to shorten and populate available platforms for this specific game
        item.addEventListener('click', () => {
        document.getElementById('gameSearch').value = game.title;
        document.getElementById('gameId').value = game.id;
        results.classList.remove('open');
      
        // Fetch and repopulate platforms for this game
        fetchGamePlatforms(game.id);
      });
        results.appendChild(item)
      })
    }
    results.classList.add('open')
  }

  async function fetchGamePlatforms(gameId) {
    const select = document.getElementById('platformSelect');
    select.innerHTML = '<option value="">Loading...</option>';
  
    const res = await fetch('/api/games/platforms?id=' + gameId);
    const platforms = await res.json();
  
    if (platforms.length === 0) {
      select.innerHTML = '<option value="">Any platform</option>';
    } else {
      select.innerHTML = '<option value="">Select platform...</option>' +
        platforms.map(p => `<option value="${p.id}">${p.name}</option>`).join('');
    }
  }
  //click handler for spoilers
  document.querySelectorAll('.review-body[data-spoiler="true"]').forEach(el => {
    el.addEventListener('click', () => {
      el.classList.remove('spoiler-hidden');
    });
  });

  // Submit review
  document.getElementById('submitReview').addEventListener('click', async () => {
    const gameId = document.getElementById('gameId').value
    const score = document.getElementById('scoreVal').value
    const title = document.getElementById('reviewTitle').value.trim()
    const body = document.getElementById('reviewBody').value.trim()
    const platformId = document.getElementById('platformSelect').value
    const hours = document.getElementById('hoursPlayed').value
    const spoilers = document.getElementById('spoilerCheck').checked
    const errorEl = document.getElementById('composerError')


    errorEl.textContent = ''
    if (!gameId) { errorEl.textContent = 'Please select a game.'; return; }
    if (!score || parseFloat(score) < 0.1 || parseFloat(score) > 10) { errorEl.textContent = 'Please enter a score between 0.1 and 10.'; return;}
    if (!title) { errorEl.textContent = 'Please add a title.'; return; }
    if (!body) { errorEl.textContent = 'Please write a review.'; return; }
    if (!hours || parseInt(hours) < 1) {errorEl.textContent = 'You must have at least 1 hour played to submit a review.'; return;}

    const btn = document.getElementById('submitReview')
    btn.disabled = true
    btn.textContent = 'Posting...'

    const res = await fetch('/api/reviews/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        game_id: gameId,
        score: parseFloat(score),
        title,
        body,
        platform_played_on: platformId || null,
        play_time_hours: hours ? parseInt(hours) : null,
        contains_spoilers: spoilers,
      }),
    })

    const data = await res.json()
    if (!res.ok) {
      errorEl.textContent = data.error ?? 'Something went wrong.'
      btn.disabled = false
      btn.textContent = 'Post review'
    } else {
      document.getElementById('composer').style.display = 'none'
      resetComposer()
      window.location.reload()
    }
  })
    document.querySelectorAll('.vote-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const reviewId = btn.dataset.reviewId;
    const vote = parseInt(btn.dataset.vote);

    const res = await fetch('/api/reviews/vote', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ review_id: reviewId, vote }),
    });

    if (res.status === 401) { window.location.href = '/signin'; return; }
    if (!res.ok) return;

    const data = await res.json();

    // Update both buttons for this review
    const pair = document.querySelectorAll(`.vote-btn[data-review-id="${reviewId}"]`);
    pair.forEach(b => {
      const bVote = parseInt(b.dataset.vote);
      const countEl = b.childNodes[b.childNodes.length - 1];
      const currentCount = parseInt(b.textContent.trim().split(' ').pop());

      if (data.vote === null) {
        // Vote removed
        b.classList.remove('active-up', 'active-down');
        if (bVote === vote) b.textContent = b.textContent.replace(/\d+/, currentCount - 1);
      } else if (data.vote === bVote) {
        // This button is now active
        b.classList.add(bVote === 1 ? 'active-up' : 'active-down');
        b.classList.remove(bVote === 1 ? 'active-down' : 'active-up');
        b.textContent = (bVote === 1 ? '▲ ' : '▼ ') + (currentCount + 1);
      } else {
        // This button lost its vote
        b.classList.remove('active-up', 'active-down');
        b.textContent = (bVote === 1 ? '▲ ' : '▼ ') + Math.max(0, currentCount - 1);
      }
    });
  });
});
</script>
</body>
</html>
