---
import { supabase } from '../lib/supabase'

export const prerender = false

const query = Astro.url.searchParams.get('q') || ''
let games = []
let profiles = []
let companies = []

if (query.length > 0) {
  const [gamesRes, profilesRes, companiesRes] = await Promise.all([
    supabase
      .from('games')
      .select('id, title, slug, cover_img_url')
      .ilike('title', `%${query}%`)
      .limit(5),

    supabase
      .from('profiles')
      .select('id, username, avatar_url')
      .ilike('username', `%${query}%`)
      .limit(5),

    supabase
      .from('companies')
      .select('id, name, slug')
      .ilike('name', `%${query}%`)
      .limit(5),
  ])

  games = gamesRes.data ?? []
  profiles = profilesRes.data ?? []
  companies = companiesRes.data ?? []
}
---

<html>
  <head><title>Search: {query}</title></head>
  <body>
    <h1>Search</h1>

    <form method="GET">
      <input name="q" value={query} placeholder="Search games, reviewers, studios..." />
      <button type="submit">Search</button>
    </form>

    {query && (
      <div>
        <section>
          <h2>Games</h2>
          {games.length === 0 && <p>No games found</p>}
          {games.map((game: any) => (
            <a href={`/games/${game.slug}`}>
              {game.cover_img_url && <img src={`https:${game.cover_img_url}`} width="40" />}
              {game.title}
            </a>
          ))}
        </section>

        <section>
          <h2>Reviewers</h2>
          {profiles.length === 0 && <p>No reviewers found</p>}
          {profiles.map((profile: any) => (
            <a href={`/reviewers/${profile.username}`}>
              {profile.username}
            </a>
          ))}
        </section>

        <section>
          <h2>Studios</h2>
          {companies.length === 0 && <p>No studios found</p>}
          {companies.map((company: any) => (
            <a href={`/studios/${company.slug}`}>
              {company.name}
            </a>
          ))}
        </section>
      </div>
    )}
  </body>
</html>
