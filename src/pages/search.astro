---
import { getSupabase } from '../utils/database'
import { igdbFetch } from '../utils/igdb'

export const prerender = false

const supabase = getSupabase()

const query = Astro.url.searchParams.get('q') || ''
const genreFilter = Astro.url.searchParams.get('genre') || ''
const platformFilter = Astro.url.searchParams.get('platform') || ''
const sortBy = Astro.url.searchParams.get('sort') || 'relevant'
const tab = Astro.url.searchParams.get('tab') || 'games'

let games: any[] = []
let igdbGames: any[] = []
let profiles: any[] = []
let companies: any[] = []

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const igdbId = parseInt(form.get('igdb_id') as string)

  const { data: existing } = await supabase
    .from('games')
    .select('slug')
    .eq('igdb_id', igdbId)
    .single()

  if (existing) return Astro.redirect(`/games/${existing.slug}`)

  const result = await igdbFetch('games',
    `fields id, name, slug, summary, cover.url, first_release_date,
            genres.id, genres.name, genres.slug,
            platforms.id, platforms.name, platforms.slug,
            involved_companies.company.id,
            involved_companies.company.name,
            involved_companies.company.slug,
            involved_companies.developer,
            involved_companies.publisher;
     where id = ${igdbId};`)
  const igdbGame = result?.[0]
  if (!igdbGame) return Astro.redirect('/search')

  const slug = igdbGame.slug || igdbGame.name
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '')

  const { data: inserted } = await supabase.from('games').insert({
    igdb_id: igdbGame.id,
    title: igdbGame.name,
    slug,
    game_description: igdbGame.summary,
    cover_img_url: igdbGame.cover?.url ?? null,
    date_released: igdbGame.first_release_date
      ? new Date(igdbGame.first_release_date * 1000).toISOString()
      : null
  }).select('id').single()

  if (inserted) {
    for (const genre of igdbGame.genres ?? []) {
      await supabase.from('genres').upsert({ igdb_id: genre.id, name: genre.name, slug: genre.slug }, { onConflict: 'igdb_id' })
      const { data: genreRow } = await supabase.from('genres').select('id').eq('igdb_id', genre.id).single()
      if (genreRow) await supabase.from('game_genres').upsert({ game_id: inserted.id, genre_id: genreRow.id }, { onConflict: 'game_id,genre_id' })
    }
    for (const platform of igdbGame.platforms ?? []) {
      await supabase.from('platforms').upsert({ igdb_id: platform.id, name: platform.name, slug: platform.slug }, { onConflict: 'igdb_id' })
      const { data: platformRow } = await supabase.from('platforms').select('id').eq('igdb_id', platform.id).single()
      if (platformRow) await supabase.from('game_platforms').upsert({ game_id: inserted.id, platform_id: platformRow.id }, { onConflict: 'game_id,platform_id' })
    }
    for (const ic of igdbGame.involved_companies ?? []) {
      if (!ic.company) continue
      await supabase.from('developers').upsert({ igdb_id: ic.company.id, name: ic.company.name, slug: ic.company.slug }, { onConflict: 'igdb_id' })
      const { data: devRow } = await supabase.from('developers').select('id').eq('igdb_id', ic.company.id).single()
      if (devRow) {
        const role = ic.developer ? 'developer' : ic.publisher ? 'publisher' : 'other'
        await supabase.from('game_companies').upsert({ game_id: inserted.id, company_id: devRow.id, role }, { onConflict: 'game_id,company_id' })
      }
    }
  }

  return Astro.redirect(`/games/${slug}`)
}

const { data: genres } = await supabase.from('genres').select('id, name').order('name')
const { data: platforms } = await supabase.from('platforms').select('id, name, slug').order('name')

if (tab === 'games') {
  let rawGames: any[] = []

  if (query.length > 1) {
    // search mode — trigram + FTS via RPC
    const rpcParams: any = { search_query: query, result_limit: 20 }
    if (genreFilter) rpcParams.genre_id = genreFilter
    if (platformFilter) rpcParams.platform_id = platformFilter

    const [rpcRes, profilesRes, companiesRes, igdbRes] = await Promise.all([
      supabase.rpc('search_games', rpcParams),
      supabase.from('profiles').select('id, username, avatar_url').ilike('username', `%${query}%`).limit(6),
      supabase.from('companies').select('id, name, slug').ilike('name', `%${query}%`).limit(6),
      igdbFetch('games', `fields id, name, slug, cover.url; search "${query}"; limit 8;`)
    ])

    const rawGameIds = (rpcRes.data ?? []).map((g: any) => g.id)

    if (rawGameIds.length > 0) {
      const { data: fullGames } = await supabase
        .from('games')
        .select(`
          id, title, slug, cover_img_url, date_released,
          game_genres(genres(id, name)),
          game_platforms(platforms(id, name)),
          reviews!reviews_game_id_fkey(score, play_time_hours)
        `)
        .in('id', rawGameIds)

      const orderMap = new Map<string, number>(rawGameIds.map((id: string, i: number) => [id, i]))
      rawGames = (fullGames ?? []).sort((a: any, b: any) =>
        (orderMap.get(a.id) ?? 99) - (orderMap.get(b.id) ?? 99)
      )
    }

    // ilike fallback
    if (rawGames.length === 0) {
      let fallbackQuery = supabase
        .from('games')
        .select(`
          id, title, slug, cover_img_url, date_released,
          game_genres(genres(id, name)),
          game_platforms(platforms(id, name)),
          reviews!reviews_game_id_fkey(score, play_time_hours)
        `)
        .ilike('title', `%${query}%`)
        .limit(24)

      if (genreFilter || platformFilter) {
        const filterIds: string[] = []
        if (genreFilter) {
          const { data: gRows } = await supabase.from('game_genres').select('game_id').eq('genre_id', genreFilter)
          filterIds.push(...(gRows ?? []).map((r: any) => r.game_id))
        }
        if (platformFilter) {
          const { data: pRows } = await supabase.from('game_platforms').select('game_id').eq('platform_id', platformFilter)
          const pIds = (pRows ?? []).map((r: any) => r.game_id)
          if (filterIds.length > 0) {
            const intersection = filterIds.filter(id => pIds.includes(id))
            filterIds.length = 0
            filterIds.push(...intersection)
          } else {
            filterIds.push(...pIds)
          }
        }
        if (filterIds.length > 0) fallbackQuery = fallbackQuery.in('id', filterIds)
      }

      const { data: fallback } = await fallbackQuery
      rawGames = fallback ?? []
    }

    profiles = profilesRes.data ?? []
    companies = companiesRes.data ?? []
    const existingIds = new Set(rawGames.map((g: any) => g.id))
    igdbGames = (igdbRes ?? []).filter((g: any) => !existingIds.has(g.igdb_id) && !existingIds.has(g.id))

  } else {
    // browse mode — count reviews per game first, then fetch top games in order
    const { data: allReviews } = await supabase
      .from('reviews')
      .select('game_id')
      .eq('status', 'published')
      .limit(2000)

    const reviewCountMap: Record<string, number> = {}
    for (const r of allReviews ?? []) {
      reviewCountMap[r.game_id] = (reviewCountMap[r.game_id] ?? 0) + 1
    }

    let topGameIds = Object.entries(reviewCountMap)
      .sort((a, b) => b[1] - a[1])
      .map(([id]) => id)

    // apply genre/platform filters
    if (genreFilter || platformFilter) {
      let genreIds: string[] | null = null
      let platformIds: string[] | null = null

      if (genreFilter) {
        const { data: gRows } = await supabase.from('game_genres').select('game_id').eq('genre_id', genreFilter)
        genreIds = (gRows ?? []).map((r: any) => r.game_id)
      }
      if (platformFilter) {
        const { data: pRows } = await supabase.from('game_platforms').select('game_id').eq('platform_id', platformFilter)
        platformIds = (pRows ?? []).map((r: any) => r.game_id)
      }

      if (genreIds && platformIds) {
        const intersection = new Set(genreIds.filter(id => platformIds!.includes(id)))
        topGameIds = topGameIds.filter(id => intersection.has(id))
      } else if (genreIds) {
        const set = new Set(genreIds)
        topGameIds = topGameIds.filter(id => set.has(id))
      } else if (platformIds) {
        const set = new Set(platformIds)
        topGameIds = topGameIds.filter(id => set.has(id))
      }
    }

    const pageIds = topGameIds.slice(0, 48)

    if (pageIds.length > 0) {
      const { data: browseGames } = await supabase
        .from('games')
        .select(`
          id, title, slug, cover_img_url, date_released,
          game_genres(genres(id, name)),
          game_platforms(platforms(id, name)),
          reviews!reviews_game_id_fkey(score, play_time_hours)
        `)
        .in('id', pageIds)

      // re-sort to preserve review count order (.in() doesn't guarantee order)
      const orderMap = new Map(pageIds.map((id, i) => [id, i]))
      rawGames = (browseGames ?? []).sort((a: any, b: any) =>
        (orderMap.get(a.id) ?? 99) - (orderMap.get(b.id) ?? 99)
      )
    }

    // fallback: no reviews yet — show recently released games
    if (rawGames.length === 0) {
      let fallback = supabase
        .from('games')
        .select(`
          id, title, slug, cover_img_url, date_released,
          game_genres(genres(id, name)),
          game_platforms(platforms(id, name)),
          reviews!reviews_game_id_fkey(score, play_time_hours)
        `)
        .order('date_released', { ascending: false })
        .limit(48)

      if (genreFilter || platformFilter) {
        const filterIds: string[] = []
        if (genreFilter) {
          const { data: gRows } = await supabase.from('game_genres').select('game_id').eq('genre_id', genreFilter)
          filterIds.push(...(gRows ?? []).map((r: any) => r.game_id))
        }
        if (platformFilter) {
          const { data: pRows } = await supabase.from('game_platforms').select('game_id').eq('platform_id', platformFilter)
          const pIds = (pRows ?? []).map((r: any) => r.game_id)
          if (filterIds.length > 0) {
            const intersection = filterIds.filter(id => pIds.includes(id))
            filterIds.length = 0
            filterIds.push(...intersection)
          } else {
            filterIds.push(...pIds)
          }
        }
        if (filterIds.length > 0) fallback = fallback.in('id', filterIds)
      }

      const { data: fallbackGames } = await fallback
      rawGames = fallbackGames ?? []
    }
  }

  let gamesRaw = rawGames.map((game: any) => {
    const scores = (game.reviews ?? []).map((r: any) => r.score).filter((s: any) => s != null)
    const hours = (game.reviews ?? []).map((r: any) => r.play_time_hours).filter((h: any) => h != null)
    return {
      ...game,
      avg_score: scores.length
        ? scores.reduce((a: number, b: number) => a + b, 0) / scores.length
        : null,
      total_hours: hours.reduce((a: number, b: number) => a + b, 0),
      review_count: scores.length
    }
  })

  if (sortBy === 'highest') gamesRaw.sort((a: any, b: any) => (b.avg_score ?? 0) - (a.avg_score ?? 0))
  else if (sortBy === 'lowest') gamesRaw.sort((a: any, b: any) => (a.avg_score ?? 0) - (b.avg_score ?? 0))
  else if (sortBy === 'most_played') gamesRaw.sort((a: any, b: any) => b.total_hours - a.total_hours)
  else if (sortBy === 'newest') gamesRaw.sort((a: any, b: any) => new Date(b.date_released ?? 0).getTime() - new Date(a.date_released ?? 0).getTime())
  else if (sortBy === 'oldest') gamesRaw.sort((a: any, b: any) => new Date(a.date_released ?? 0).getTime() - new Date(b.date_released ?? 0).getTime())
  else gamesRaw.sort((a: any, b: any) => b.review_count - a.review_count) // default: most reviewed

  games = gamesRaw
}

if (tab === 'reviewers' && query.length > 1) {
  const { data } = await supabase.from('profiles').select('id, username, avatar_url').ilike('username', `%${query}%`).limit(12)
  profiles = data ?? []
}

if (tab === 'studios') {
  if (query.length > 1) {
    const { data } = await supabase.from('developers').select('id, name, slug').ilike('name', `%${query}%`).limit(12)
    companies = data ?? []
  } else {
    // browse mode — get studios sorted by total reviews across all their games
    const { data: allDevGames } = await supabase
      .from('game_companies')
      .select('company_id, game_id')
      .eq('role', 'developer')

    // get all published review game_ids
    const { data: allReviewRows } = await supabase
      .from('reviews')
      .select('game_id')
      .eq('status', 'published')
      .limit(5000)

    const reviewGameSet = new Set((allReviewRows ?? []).map((r: any) => r.game_id))

    // count reviews per company
    const companyReviewCount: Record<string, number> = {}
    for (const row of allDevGames ?? []) {
      if (reviewGameSet.has(row.game_id)) {
        companyReviewCount[row.company_id] = (companyReviewCount[row.company_id] ?? 0) + 1
      }
    }

    // sort by review count, take top 24
    const topCompanyIds = Object.entries(companyReviewCount)
      .sort((a, b) => b[1] - a[1])
      .map(([id]) => id)
      .slice(0, 24)

    if (topCompanyIds.length > 0) {
      const { data: topDevs } = await supabase
        .from('developers')
        .select('id, name, slug')
        .in('id', topCompanyIds)

      // preserve sort order
      const orderMap = new Map(topCompanyIds.map((id, i) => [id, i]))
      companies = (topDevs ?? []).sort((a: any, b: any) =>
        (orderMap.get(a.id) ?? 99) - (orderMap.get(b.id) ?? 99)
      )
    } else {
      // no reviews yet — just show studios alphabetically
      const { data } = await supabase.from('developers').select('id, name, slug').order('name').limit(24)
      companies = data ?? []
    }
  }
}

function igdbImage(url: string | null, size = 't_cover_big') {
  if (!url) return null
  const clean = url.startsWith('//') ? `https:${url}` : url
  return clean.replace(/t_[a-z_]+/, size)
}

function getYear(dateStr: string | null) {
  if (!dateStr) return ''
  return new Date(dateStr).getFullYear()
}

function getInitials(username: string) {
  return username.slice(0, 2).toUpperCase()
}

function scoreClass(score: number | null) {
  if (!score) return ''
  if (score >= 9) return 'score-great'
  if (score >= 7) return 'score-good'
  if (score >= 5) return 'score-mid'
  return 'score-low'
}

const genreOrder = [
  'Puzzle','Adventure','Shooter','Role-playing (RPG)','Simulator',
  'Sport','MOBA','Racing','Strategy','Real Time Strategy (RTS)',
  'Fighting','Card & Board Game','Platform','Quiz/Trivia',
  "Hack and slash/Beat 'em up",'Point-and-click','Tactical',
  'Indie','Arcade','Music'
]
const sidebarGenres = (genres ?? [])
  .filter((g: any) => genreOrder.some(name => g.name.toLowerCase() === name.toLowerCase()))
  .sort((a: any, b: any) => {
    const ai = genreOrder.findIndex(n => n.toLowerCase() === a.name.toLowerCase())
    const bi = genreOrder.findIndex(n => n.toLowerCase() === b.name.toLowerCase())
    return ai - bi
  })

const platformOrder = ['android','ios','win','switch','ps5','series-x-s','switch-2','ps4--1','linux','meta-quest-3']
const platformLabels: { [key: string]: string } = {
  'win': 'PC / Steam', 'linux': 'Steam Deck', 'meta-quest-3': 'Meta Quest 3',
  'switch-2': 'Nintendo Switch 2', 'series-x-s': 'Xbox Series X|S',
  'ps4--1': 'PlayStation 4', 'ps5': 'PlayStation 5',
  'switch': 'Nintendo Switch', 'android': 'Android', 'ios': 'iOS',
}
const sidebarPlatforms = platformOrder
  .map(slug => (platforms ?? []).find((p: any) => p.slug === slug))
  .filter(Boolean)

const isBrowseMode = tab === 'games' && !query
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{query ? `Search: ${query}` : 'Browse Games'} — Cartridge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    :root[data-theme="light"] {
      --bg: #f9f8f6; --bg-card: #ffffff; --bg-hover: #f4f3f0; --bg-sidebar: #ffffff;
      --border: #e8e6e1; --border-subtle: #f0ede8;
      --text-primary: #141412; --text-secondary: #6b6860; --text-tertiary: #a09d98;
      --accent: #141412; --accent-text: #ffffff; --logo-color: #141412;
      --tag-bg: #f0ede8; --tag-text: #6b6860;
      --shadow: 0 1px 3px rgba(0,0,0,0.06); --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
      --score-great: #1a6b3c; --score-great-bg: #eaf5ee;
      --score-good: #1a4a6b; --score-good-bg: #eaf0f5;
      --score-mid: #6b5a1a; --score-mid-bg: #f5f0ea;
      --score-low: #6b1a1a; --score-low-bg: #f5eaea;
    }
    :root[data-theme="dark"] {
      --bg: #0f0f0e; --bg-card: #1a1a18; --bg-hover: #222220; --bg-sidebar: #141412;
      --border: #2a2a27; --border-subtle: #222220;
      --text-primary: #f0ede8; --text-secondary: #908d87; --text-tertiary: #5a5855;
      --accent: #f0ede8; --accent-text: #141412; --logo-color: #f0ede8;
      --tag-bg: #2a2a27; --tag-text: #908d87;
      --shadow: 0 1px 3px rgba(0,0,0,0.3); --shadow-md: 0 4px 12px rgba(0,0,0,0.4);
      --score-great: #4ade80; --score-great-bg: #0d2b1a;
      --score-good: #60a5fa; --score-good-bg: #0d1e2b;
      --score-mid: #fbbf24; --score-mid-bg: #2b1f0d;
      --score-low: #f87171; --score-low-bg: #2b0d0d;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text-primary); min-height: 100vh; -webkit-font-smoothing: antialiased; transition: background 0.2s, color 0.2s; }
    a { color: inherit; text-decoration: none; }

    .layout { display: grid; grid-template-columns: 240px 1fr 280px; max-width: 1140px; margin: 0 auto; min-height: 100vh; }
    @media (max-width: 1000px) { .layout { grid-template-columns: 200px 1fr; } .sidebar-right { display: none; } }
    @media (max-width: 680px) { .layout { grid-template-columns: 1fr; } .sidebar-left { display: none; } }

    .sidebar-left { position: sticky; top: 0; height: 100vh; padding: 28px 20px; display: flex; flex-direction: column; gap: 6px; border-right: 1px solid var(--border); background: var(--bg-sidebar); }
    .logo { font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--logo-color); padding: 8px 12px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .logo-dot { width: 8px; height: 8px; background: var(--text-primary); border-radius: 50%; }
    .nav-item { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 10px; font-size: 15px; color: var(--text-secondary); transition: background 0.15s, color 0.15s; }
    .nav-item:hover, .nav-item.active { background: var(--bg-hover); color: var(--text-primary); }
    .nav-item.active { font-weight: 500; }
    .nav-icon { width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .nav-divider { height: 1px; background: var(--border); margin: 10px 0; }
    .sidebar-bottom { margin-top: auto; }
    .theme-toggle { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 10px; cursor: pointer; font-size: 15px; color: var(--text-secondary); background: none; border: none; font-family: inherit; width: 100%; text-align: left; transition: background 0.15s, color 0.15s; }
    .theme-toggle:hover { background: var(--bg-hover); color: var(--text-primary); }

    .main { border-right: 1px solid var(--border); min-height: 100vh; }
    .search-header { position: sticky; top: 0; background: var(--bg-card); border-bottom: 1px solid var(--border); padding: 16px 20px; z-index: 10; backdrop-filter: blur(8px); }
    .search-bar { display: flex; gap: 8px; margin-bottom: 14px; }
    .search-input { flex: 1; background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 10px 14px; font-size: 15px; font-family: inherit; color: var(--text-primary); outline: none; transition: border-color 0.15s; }
    .search-input:focus { border-color: var(--text-secondary); }
    .search-btn { background: var(--accent); color: var(--accent-text); border: none; border-radius: 10px; padding: 10px 20px; font-size: 14px; font-weight: 500; font-family: inherit; cursor: pointer; transition: opacity 0.15s; }
    .search-btn:hover { opacity: 0.85; }

    .tabs { display: flex; gap: 4px; margin-bottom: 14px; }
    .tab { padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 500; color: var(--text-secondary); border: 1px solid transparent; background: none; font-family: inherit; transition: all 0.15s; text-decoration: none; display: inline-block; }
    .tab:hover { background: var(--bg-hover); color: var(--text-primary); }
    .tab.active { background: var(--accent); color: var(--accent-text); border-color: var(--accent); }

    .filters { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
    .filter-select { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 6px 28px 6px 10px; font-size: 13px; font-family: inherit; color: var(--text-secondary); outline: none; cursor: pointer; transition: border-color 0.15s; appearance: none; background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%23a09d98' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: right 8px center; }
    .filter-select:focus { border-color: var(--text-secondary); }
    .filter-select.active { border-color: var(--text-primary); color: var(--text-primary); }
    .clear-link { font-size: 12px; color: var(--text-tertiary); text-decoration: none; padding: 4px 8px; border-radius: 6px; transition: color 0.15s; }
    .clear-link:hover { color: var(--text-primary); }

    .results { padding: 20px; }
    .results-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 16px; flex-wrap: wrap; gap: 8px; }
    .results-title { font-family: 'DM Serif Display', serif; font-size: 20px; letter-spacing: -0.3px; }
    .results-count { font-size: 12px; color: var(--text-tertiary); }
    .section-title { font-size: 13px; font-weight: 500; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; margin-top: 24px; }
    .section-title:first-child { margin-top: 0; }

    .game-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 14px; margin-bottom: 8px; }
    .game-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: box-shadow 0.15s, transform 0.15s; cursor: pointer; display: block; }
    .game-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .game-cover { width: 100%; aspect-ratio: 3/4; background: var(--tag-bg); display: flex; align-items: center; justify-content: center; font-size: 32px; overflow: hidden; }
    .game-cover img { width: 100%; height: 100%; object-fit: cover; }
    .game-card-info { padding: 10px; }
    .game-card-title { font-size: 13px; font-weight: 500; line-height: 1.3; margin-bottom: 4px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .game-card-meta { display: flex; align-items: center; gap: 6px; margin-top: 4px; }
    .game-card-year { font-size: 12px; color: var(--text-tertiary); }
    .game-card-stats { font-size: 11px; color: var(--text-tertiary); margin-top: 3px; }
    .score-pill { margin-left: auto; font-size: 11px; font-weight: 600; padding: 2px 7px; border-radius: 6px; font-family: 'DM Serif Display', serif; white-space: nowrap; }
    .score-pill.score-great { color: var(--score-great); background: var(--score-great-bg); }
    .score-pill.score-good { color: var(--score-good); background: var(--score-good-bg); }
    .score-pill.score-mid { color: var(--score-mid); background: var(--score-mid-bg); }
    .score-pill.score-low { color: var(--score-low); background: var(--score-low-bg); }
    .game-card-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 6px; }
    .tag { background: var(--tag-bg); color: var(--tag-text); font-size: 11px; padding: 2px 7px; border-radius: 4px; }

    .igdb-label { display: inline-flex; align-items: center; gap: 4px; background: var(--tag-bg); color: var(--tag-text); font-size: 11px; font-weight: 500; padding: 2px 8px; border-radius: 20px; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.3px; }
    .add-pill { font-size: 11px; color: var(--text-tertiary); margin-top: 3px; }

    .profile-list { display: flex; flex-direction: column; gap: 2px; }
    .profile-item { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 10px; transition: background 0.15s; }
    .profile-item:hover { background: var(--bg-hover); }
    .avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--tag-bg); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 500; color: var(--text-secondary); overflow: hidden; flex-shrink: 0; }
    .avatar img { width: 100%; height: 100%; object-fit: cover; }
    .profile-username { font-size: 14px; font-weight: 500; }
    .profile-sub { font-size: 12px; color: var(--text-tertiary); margin-top: 1px; }

    .company-list { display: flex; flex-direction: column; gap: 2px; }
    .company-item { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 10px; transition: background 0.15s; }
    .company-item:hover { background: var(--bg-hover); }
    .company-icon { width: 40px; height: 40px; border-radius: 10px; background: var(--tag-bg); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
    .company-name { font-size: 14px; font-weight: 500; }
    .company-sub { font-size: 12px; color: var(--text-tertiary); margin-top: 1px; }

    .empty-state { padding: 60px 20px; text-align: center; color: var(--text-tertiary); }
    .empty-title { font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--text-secondary); margin-bottom: 8px; }
    .empty-sub { font-size: 14px; line-height: 1.6; }

    .sidebar-right { padding: 28px 20px; display: flex; flex-direction: column; gap: 24px; }
    .widget { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 16px; box-shadow: var(--shadow); }
    .widget-title { font-size: 14px; font-weight: 500; margin-bottom: 14px; }
    .genre-chip-list { display: flex; flex-wrap: wrap; gap: 6px; }
    .genre-chip { background: var(--tag-bg); color: var(--tag-text); font-size: 12px; padding: 4px 10px; border-radius: 20px; cursor: pointer; transition: all 0.15s; text-decoration: none; display: inline-block; }
    .genre-chip:hover { background: var(--bg-hover); color: var(--text-primary); }
    .genre-chip.active { background: var(--accent); color: var(--accent-text); }

    .active-filters { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; }
    .active-filter-pill { display: inline-flex; align-items: center; gap: 6px; background: var(--accent); color: var(--accent-text); font-size: 12px; font-weight: 500; padding: 4px 10px; border-radius: 20px; }
    .active-filter-pill a { color: inherit; opacity: 0.7; font-size: 14px; line-height: 1; }
    .active-filter-pill a:hover { opacity: 1; }
  </style>
</head>

<body>
<div class="layout">

  <aside class="sidebar-left">
    <div class="logo"><span class="logo-dot"></span>Cartridge</div>
    <a href="/" class="nav-item">
      <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7L9 2L16 7V16H11V11H7V16H2V7Z"/></svg></span>
      Home
    </a>
    <a href="/search" class="nav-item active">
      <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="5"/><path d="M13 13l3 3"/></svg></span>
      Search
    </a>
    <div class="nav-divider"></div>
    <a href="/profile" class="nav-item">
      <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="6" r="3"/><path d="M3 16c0-3.314 2.686-6 6-6s6 2.686 6 6"/></svg></span>
      Profile
    </a>
    <div class="sidebar-bottom">
      <button class="theme-toggle" onclick="toggleTheme()">
        <span class="nav-icon" id="themeIcon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="9" r="3.5"/><path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/></svg>
        </span>
        <span id="themeLabel">Light mode</span>
      </button>
    </div>
  </aside>

  <main class="main">
    <div class="search-header">
      <form method="GET" class="search-bar">
        <input type="hidden" name="tab" value={tab} />
        <input
          name="q"
          value={query}
          class="search-input"
          placeholder="Search games, reviewers, studios..."
          autofocus
        />
        <button type="submit" class="search-btn">Search</button>
      </form>

      <div class="tabs">
        {[
          { id: 'games', label: 'Games' },
          { id: 'reviewers', label: 'Reviewers' },
          { id: 'studios', label: 'Studios' },
        ].map((t) => (
          <a href={`/search?q=${encodeURIComponent(query)}&tab=${t.id}`} class={`tab ${tab === t.id ? 'active' : ''}`}>
            {t.label}
          </a>
        ))}
      </div>

      {tab === 'games' && (
        <form method="GET" class="filters">
          <input type="hidden" name="q" value={query} />
          <input type="hidden" name="tab" value="games" />
          <select name="genre" class={`filter-select ${genreFilter ? 'active' : ''}`} onchange="this.form.submit()">
            <option value="">All genres</option>
            {(genres ?? []).map((g: any) => (
              <option value={g.id} selected={genreFilter === String(g.id)}>{g.name}</option>
            ))}
          </select>
          <select name="platform" class={`filter-select ${platformFilter ? 'active' : ''}`} onchange="this.form.submit()">
            <option value="">All platforms</option>
            {(platforms ?? []).map((p: any) => (
              <option value={p.id} selected={platformFilter === String(p.id)}>{p.name}</option>
            ))}
          </select>
          <select name="sort" class="filter-select" onchange="this.form.submit()">
            <option value="relevant" selected={sortBy === 'relevant'}>Most reviewed</option>
            <option value="highest" selected={sortBy === 'highest'}>Highest rated</option>
            <option value="lowest" selected={sortBy === 'lowest'}>Lowest rated</option>
            <option value="most_played" selected={sortBy === 'most_played'}>Most played</option>
            <option value="newest" selected={sortBy === 'newest'}>Newest first</option>
            <option value="oldest" selected={sortBy === 'oldest'}>Oldest first</option>
          </select>
          {(genreFilter || platformFilter) && (
            <a href={`/search?q=${encodeURIComponent(query)}&tab=games`} class="clear-link">Clear filters ✕</a>
          )}
        </form>
      )}

      {tab === 'games' && (genreFilter || platformFilter) && (
        <div class="active-filters" style="margin-top:10px">
          {genreFilter && (() => {
            const g = (genres ?? []).find((g: any) => String(g.id) === genreFilter)
            return g ? (
              <span class="active-filter-pill">
                {g.name}
                <a href={`/search?q=${encodeURIComponent(query)}&tab=games&platform=${platformFilter}&sort=${sortBy}`}>×</a>
              </span>
            ) : null
          })()}
          {platformFilter && (() => {
            const p = (platforms ?? []).find((p: any) => String(p.id) === platformFilter)
            return p ? (
              <span class="active-filter-pill">
                {p.name}
                <a href={`/search?q=${encodeURIComponent(query)}&tab=games&genre=${genreFilter}&sort=${sortBy}`}>×</a>
              </span>
            ) : null
          })()}
        </div>
      )}
    </div>

    <div class="results">

      {tab === 'games' && (
        <div>
          <div class="results-header">
            <span class="results-title">
              {query
                ? `Results for "${query}"`
                : genreFilter || platformFilter
                ? 'Filtered games'
                : 'All games'
              }
            </span>
            <span class="results-count">{games.length} game{games.length !== 1 ? 's' : ''}</span>
          </div>

          {games.length > 0 && (
            <div class="game-grid">
              {games.map((game: any) => (
                <a href={`/games/${game.slug}`} class="game-card">
                  <div class="game-cover">
                    {game.cover_img_url
                      ? <img src={igdbImage(game.cover_img_url)} alt={game.title} loading="lazy" />
                      : '🎮'
                    }
                  </div>
                  <div class="game-card-info">
                    <div class="game-card-title">{game.title}</div>
                    <div class="game-card-meta">
                      <span class="game-card-year">{getYear(game.date_released)}</span>
                      {game.avg_score != null && (
                        <span class={`score-pill ${scoreClass(game.avg_score)}`}>
                          ★ {game.avg_score.toFixed(1)}
                        </span>
                      )}
                    </div>
                    {game.review_count > 0 && (
                      <div class="game-card-stats">
                        {game.review_count} review{game.review_count !== 1 ? 's' : ''}
                        {game.total_hours > 0 ? ` · ${game.total_hours.toLocaleString()}h played` : ''}
                      </div>
                    )}
                    <div class="game-card-tags">
                      {(game.game_genres ?? []).slice(0, 2).map((gg: any) => (
                        <span class="tag">{gg.genres?.name}</span>
                      ))}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          )}

          {query && igdbGames.length > 0 && (
            <div>
              <div class="section-title" style="margin-top:28px">More from IGDB</div>
              <span class="igdb-label">Not yet in Cartridge — click to add</span>
              <div class="game-grid">
                {igdbGames.map((game: any) => (
                  <form method="POST">
                    <input type="hidden" name="igdb_id" value={game.id} />
                    <button type="submit" style="width:100%;background:none;border:none;padding:0;cursor:pointer;text-align:left">
                      <div class="game-card">
                        <div class="game-cover">
                          {game.cover?.url
                            ? <img src={igdbImage(game.cover.url)} alt={game.name} loading="lazy" />
                            : '🎮'
                          }
                        </div>
                        <div class="game-card-info">
                          <div class="game-card-title">{game.name}</div>
                          <div class="add-pill">Click to add →</div>
                        </div>
                      </div>
                    </button>
                  </form>
                ))}
              </div>
            </div>
          )}

          {games.length === 0 && (genreFilter || platformFilter) && (
            <div class="empty-state">
              <div class="empty-title">No games found</div>
              <div class="empty-sub">Try different filters.</div>
            </div>
          )}
        </div>
      )}

      {tab === 'reviewers' && (
        <div>
          <div class="section-title">Reviewers</div>
          {!query ? (
            <div class="empty-state">
              <div class="empty-title">Search for reviewers</div>
              <div class="empty-sub">Enter a username above to find reviewers.</div>
            </div>
          ) : profiles.length === 0 ? (
            <div class="empty-state">
              <div class="empty-title">No reviewers found</div>
              <div class="empty-sub">Try a different search term.</div>
            </div>
          ) : (
            <div class="profile-list">
              {profiles.map((profile: any) => (
                <a href={`/reviewers/${profile.username}`} class="profile-item">
                  <div class="avatar">
                    {profile.avatar_url
                      ? <img src={profile.avatar_url} alt={profile.username} />
                      : getInitials(profile.username)
                    }
                  </div>
                  <div>
                    <div class="profile-username">@{profile.username}</div>
                    <div class="profile-sub">Reviewer</div>
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      )}

      {tab === 'studios' && (
        <div>
          <div class="results-header">
            <span class="results-title">
              {query ? `Studios matching "${query}"` : 'Top Studios'}
            </span>
            {companies.length > 0 && <span class="results-count">{companies.length} studio{companies.length !== 1 ? 's' : ''}</span>}
          </div>
          {companies.length === 0 && query ? (
            <div class="empty-state">
              <div class="empty-title">No studios found</div>
              <div class="empty-sub">Try a different search term.</div>
            </div>
          ) : companies.length === 0 ? (
            <div class="empty-state">
              <div class="empty-title">No studios yet</div>
              <div class="empty-sub">Studios appear here once games are added.</div>
            </div>
          ) : (
            <div class="company-list">
              {companies.map((company: any) => (
                <a href={`/studios/${company.slug}`} class="company-item">
                  <div class="company-icon">🏢</div>
                  <div>
                    <div class="company-name">{company.name}</div>
                    <div class="company-sub">Studio / Developer</div>
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      )}

    </div>
  </main>

  <aside class="sidebar-right">
    <div class="widget">
      <div class="widget-title">Browse by genre</div>
      <div class="genre-chip-list">
        {sidebarGenres.map((g: any) => (
          <a
            href={`/search?q=${encodeURIComponent(query)}&tab=games&genre=${g.id}&platform=${platformFilter}&sort=${sortBy}`}
            class={`genre-chip ${genreFilter === String(g.id) ? 'active' : ''}`}
          >
            {g.name}
          </a>
        ))}
      </div>
    </div>

    <div class="widget">
      <div class="widget-title">Browse by platform</div>
      <div class="genre-chip-list">
        {sidebarPlatforms.map((p: any) => (
          <a
            href={`/search?q=${encodeURIComponent(query)}&tab=games&platform=${p.id}&genre=${genreFilter}&sort=${sortBy}`}
            class={`genre-chip ${platformFilter === String(p.id) ? 'active' : ''}`}
          >
            {platformLabels[p.slug] ?? p.name}
          </a>
        ))}
      </div>
    </div>

    <div class="widget">
      <div class="widget-title">Quick sort</div>
      <div class="genre-chip-list">
        {[
          { val: 'relevant', label: '🔥 Most reviewed' },
          { val: 'highest', label: '⭐ Highest rated' },
          { val: 'lowest', label: '📉 Lowest rated' },
          { val: 'most_played', label: '🕹️ Most played' },
          { val: 'newest', label: '🆕 Newest' },
          { val: 'oldest', label: '📅 Oldest' },
        ].map((s) => (
          <a
            href={`/search?q=${encodeURIComponent(query)}&tab=games&sort=${s.val}&genre=${genreFilter}&platform=${platformFilter}`}
            class={`genre-chip ${sortBy === s.val ? 'active' : ''}`}
          >
            {s.label}
          </a>
        ))}
      </div>
    </div>
  </aside>

</div>

<script>
  function toggleTheme() {
    const html = document.documentElement
    const next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light'
    html.setAttribute('data-theme', next)
    localStorage.setItem('theme', next)
    updateThemeUI(next)
  }

  function updateThemeUI(theme: string) {
    const label = document.getElementById('themeLabel')
    const icon = document.getElementById('themeIcon')
    if (!label || !icon) return
    if (theme === 'dark') {
      label.textContent = 'Dark mode'
      icon.innerHTML = '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10.5A7 7 0 016.5 3a7 7 0 100 12 7 7 0 008.5-4.5z"/></svg>'
    } else {
      label.textContent = 'Light mode'
      icon.innerHTML = '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="9" r="3.5"/><path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/></svg>'
    }
  }

  const saved = localStorage.getItem('theme') ||
    (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
  document.documentElement.setAttribute('data-theme', saved)
  updateThemeUI(saved)
</script>
</body>
</html>
