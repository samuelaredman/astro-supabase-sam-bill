---
export const prerender = false;
import { getSupabase } from '../../utils/database'
import { igdbFetch } from '../../utils/igdb'

const supabase = getSupabase()

const { slug } = Astro.params;

const { data: studio } = await supabase
  .from('developers')
  .select(`
    id, name, slug, country, description,
    website_url, logo_url, founded_year, igdb_id
  `)
  .eq('slug', slug)
  .single()

if (!studio) return Astro.redirect('/404')

const { data: developedRaw } = await supabase
  .from('game_companies')
  .select(`
    role,
    games(id, title, slug, cover_img_url, date_released, igdb_id)
  `)
  .eq('company_id', studio.id)

const allEntries = developedRaw ?? []

const developedGames = allEntries
  .filter((e: any) => e.role === 'developer')
  .map((e: any) => e.games)
  .filter(Boolean)
  .sort((a: any, b: any) =>
    new Date(b.date_released ?? 0).getTime() - new Date(a.date_released ?? 0).getTime()
  )

const publishedGames = allEntries
  .filter((e: any) => e.role === 'publisher')
  .map((e: any) => e.games)
  .filter(Boolean)
  .sort((a: any, b: any) =>
    new Date(b.date_released ?? 0).getTime() - new Date(a.date_released ?? 0).getTime()
  )

const publishedOnly = publishedGames.filter(
  (pg: any) => !developedGames.find((dg: any) => dg.id === pg.id)
)

const allGameIds = [...new Set(allEntries.map((e: any) => e.games?.id).filter(Boolean))]

const { data: reviewScores } = await supabase
  .from('reviews')
  .select('game_id, score')
  .in('game_id', allGameIds)
  .eq('status', 'published')

const reviewsByGame: Record<string, number[]> = {}
for (const r of reviewScores ?? []) {
  if (!reviewsByGame[r.game_id]) reviewsByGame[r.game_id] = []
  reviewsByGame[r.game_id].push(r.score)
}

function gameAvgScore(gameId: string): string | null {
  const scores = reviewsByGame[gameId]
  if (!scores || scores.length === 0) return null
  return (scores.reduce((a, b) => a + b, 0) / scores.length).toFixed(1)
}

function gameReviewCount(gameId: string): number {
  return reviewsByGame[gameId]?.length ?? 0
}

// review-weighted avg across all games
const allScores = Object.values(reviewsByGame).flat()
const overallAvg = allScores.length > 0
  ? (allScores.reduce((a, b) => a + b, 0) / allScores.length).toFixed(1)
  : null

const totalReviews = allScores.length
const totalGames = new Set([
  ...developedGames.map((g: any) => g.id),
  ...publishedOnly.map((g: any) => g.id)
]).size

// fetch IGDB company details
let igdbData: any = null
if (studio.igdb_id) {
  const [igdbCompany] = await igdbFetch('companies',
    `fields name, description, country, start_date, logo.url, url;
     where id = ${studio.igdb_id};`)
  igdbData = igdbCompany ?? null
}

function igdbImage(url: string | null, size = 't_cover_big') {
  if (!url) return null
  return `https:${url.replace('t_thumb', size)}`
}

function scoreClass(score: number): string {
  if (score >= 9) return 'great'
  if (score >= 7) return 'good'
  if (score >= 5) return 'mid'
  return 'low'
}

function releaseYear(dateStr: string | null): string | null {
  if (!dateStr) return null
  return String(new Date(dateStr).getFullYear())
}

function countryName(code: number | null): string | null {
  if (!code) return null
  try {
    return new Intl.DisplayNames(['en'], { type: 'region' }).of(
      code.toString().padStart(2, '0')
    ) ?? null
  } catch { return null }
}

const overallScoreClass = overallAvg ? scoreClass(parseFloat(overallAvg)) : null
const coverUrls = developedGames
  .slice(0, 12)
  .map((g: any) => igdbImage(g.cover_img_url))
  .filter(Boolean)
const coverUrlsJson = JSON.stringify(coverUrls)
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{studio.name} — Cartridge</title>
  <meta name="description" content={studio.description?.slice(0, 160) ?? `${studio.name} games and reviews on Cartridge.`} />
  <meta property="og:title" content={`${studio.name} — Cartridge`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    :root[data-theme="light"] {
      --bg: #f5f4f2; --bg-card: #ffffff; --bg-hover: #f4f3f0;
      --border: #e8e6e1; --border-subtle: #f0ede8;
      --text-primary: #141412; --text-secondary: #6b6860; --text-tertiary: #a09d98;
      --tag-bg: #f0ede8; --tag-text: #6b6860;
      --shadow: 0 1px 3px rgba(0,0,0,0.06); --shadow-md: 0 4px 16px rgba(0,0,0,0.1);
      --score-great: #1a6b3c; --score-great-bg: #eaf5ee;
      --score-good: #1a4a6b;  --score-good-bg: #eaf0f5;
      --score-mid: #6b5a1a;   --score-mid-bg: #f5f0ea;
      --score-low: #6b1a1a;   --score-low-bg: #f5eaea;
      --game-accent: #4a3a8a; --game-accent-subtle: rgba(74,58,138,0.06);
      --hero-overlay: linear-gradient(to bottom, rgba(245,244,242,0.0) 0%, rgba(245,244,242,0.5) 60%, rgba(245,244,242,1) 100%);
    }
    :root[data-theme="dark"] {
      --bg: #09090a; --bg-card: #131314; --bg-hover: #1c1c1e;
      --border: #222224; --border-subtle: #191919;
      --text-primary: #f0ede8; --text-secondary: #908d87; --text-tertiary: #484644;
      --tag-bg: #1c1c1e; --tag-text: #6a6866;
      --shadow: 0 1px 3px rgba(0,0,0,0.5); --shadow-md: 0 4px 16px rgba(0,0,0,0.7);
      --score-great: #4ade80; --score-great-bg: #0b2016;
      --score-good: #60a5fa;  --score-good-bg: #0b1828;
      --score-mid: #fbbf24;   --score-mid-bg: #201808;
      --score-low: #f87171;   --score-low-bg: #200808;
      --game-accent: #6050c8; --game-accent-subtle: rgba(96,80,200,0.09);
      --hero-overlay: linear-gradient(to bottom, rgba(9,9,10,0.0) 0%, rgba(9,9,10,0.55) 60%, rgba(9,9,10,1) 100%);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text-primary); min-height: 100vh; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }

    .topnav { position: sticky; top: 0; z-index: 30; background: rgba(9,9,10,0.82); border-bottom: 1px solid var(--border); padding: 13px 28px; display: flex; align-items: center; gap: 16px; backdrop-filter: blur(20px); }
    [data-theme="light"] .topnav { background: rgba(245,244,242,0.82); }
    .back-btn { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--text-tertiary); transition: color 0.15s; }
    .back-btn:hover { color: var(--text-primary); }
    .logo { font-family: 'DM Serif Display', serif; font-size: 19px; letter-spacing: -0.3px; display: flex; align-items: center; gap: 7px; margin-left: auto; }
    .logo-dot { width: 6px; height: 6px; background: var(--game-accent); border-radius: 50%; box-shadow: 0 0 10px var(--game-accent); }
    .theme-btn { background: none; border: none; cursor: pointer; color: var(--text-tertiary); padding: 6px; display: flex; align-items: center; transition: color 0.15s; margin-left: 8px; }
    .theme-btn:hover { color: var(--text-primary); }

    .jump-nav { position: sticky; top: 53px; z-index: 20; background: rgba(9,9,10,0.72); border-bottom: 1px solid var(--border); backdrop-filter: blur(16px); display: flex; overflow-x: auto; scrollbar-width: none; }
    .jump-nav::-webkit-scrollbar { display: none; }
    [data-theme="light"] .jump-nav { background: rgba(245,244,242,0.82); }
    .jump-link { font-size: 11px; font-weight: 500; color: var(--text-tertiary); padding: 10px 20px; letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.15s, border-color 0.15s; border-bottom: 2px solid transparent; white-space: nowrap; flex-shrink: 0; }
    .jump-link:hover { color: var(--text-primary); }
    .jump-link.active { color: var(--text-primary); border-color: var(--game-accent); }

    .hero { position: relative; width: 100%; height: 320px; overflow: hidden; background: #04040a; }
    .hero-mosaic { position: absolute; inset: -20px; display: flex; flex-wrap: wrap; filter: blur(18px) saturate(1.5) brightness(0.38); transform: scale(1.08); }
    .hero-mosaic-tile { flex: 1 1 90px; min-width: 90px; min-height: 160px; background-size: cover; background-position: center; }
    .hero-overlay { position: absolute; inset: 0; background: var(--hero-overlay); }

    .page { max-width: 900px; margin: 0 auto; padding: 0 28px 100px; }

    .studio-header { display: flex; gap: 28px; align-items: flex-end; margin-top: -80px; margin-bottom: 32px; position: relative; z-index: 2; }
    .studio-logo-wrap { flex-shrink: 0; width: 120px; height: 120px; border-radius: 20px; background: var(--bg-card); border: 1px solid rgba(96,80,200,0.3); box-shadow: 0 12px 40px rgba(0,0,0,0.7), 0 0 30px rgba(96,80,200,0.15); display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .studio-logo { width: 100%; height: 100%; object-fit: contain; padding: 12px; }
    .studio-logo-placeholder { font-size: 52px; }
    .studio-info { flex: 1; min-width: 0; padding-bottom: 4px; }
    .studio-name { font-family: 'Cinzel', serif; font-size: 34px; line-height: 1.1; letter-spacing: 0.04em; margin-bottom: 8px; font-weight: 600; text-shadow: 0 2px 24px rgba(0,0,0,0.6); }
    .studio-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .studio-meta-item { font-size: 13px; color: var(--text-secondary); }
    .studio-meta-sep { color: var(--text-tertiary); font-size: 10px; }
    .studio-website { font-size: 13px; color: var(--game-accent); transition: opacity 0.15s; display: flex; align-items: center; gap: 4px; }
    .studio-website:hover { opacity: 0.7; }

    .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 28px; }
    .stat-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 22px 20px 18px; }
    .stat-card.score-card-great { border-bottom: 2px solid var(--score-great); }
    .stat-card.score-card-good  { border-bottom: 2px solid var(--score-good); }
    .stat-card.score-card-mid   { border-bottom: 2px solid var(--score-mid); }
    .stat-card.score-card-low   { border-bottom: 2px solid var(--score-low); }
    .stat-num { font-family: 'Century Schoolbook', 'New Century Schoolbook', Georgia, serif; font-size: 36px; font-weight: 400; line-height: 1; letter-spacing: -1px; margin-bottom: 6px; color: var(--text-primary); background: none; }
    .stat-num.great { color: var(--score-great); background: none; }
    .stat-num.good  { color: var(--score-good);  background: none; }
    .stat-num.mid   { color: var(--score-mid);   background: none; }
    .stat-num.low   { color: var(--score-low);   background: none; }
    .stat-label { font-size: 11px; font-weight: 500; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.08em; }
    .stat-sub { font-size: 11px; color: var(--text-tertiary); margin-top: 3px; }

    .about-grid { display: grid; grid-template-columns: 1fr 260px; gap: 24px; margin-bottom: 40px; }
    @media (max-width: 720px) { .about-grid { grid-template-columns: 1fr; } }
    .description { font-size: 14px; line-height: 1.8; color: var(--text-secondary); }
    .description.collapsed { display: -webkit-box; -webkit-line-clamp: 5; -webkit-box-orient: vertical; overflow: hidden; }
    .read-more-btn { background: none; border: none; font-family: inherit; font-size: 12px; color: var(--game-accent); cursor: pointer; padding: 8px 0 0; transition: opacity 0.15s; display: block; }
    .read-more-btn:hover { opacity: 0.7; }
    .details-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 4px 18px; height: fit-content; }
    .detail-row { display: flex; gap: 12px; padding: 11px 0; border-bottom: 1px solid var(--border-subtle); font-size: 12px; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { flex-shrink: 0; width: 80px; color: var(--text-tertiary); padding-top: 2px; text-transform: uppercase; letter-spacing: 0.06em; font-size: 10px; font-weight: 500; }
    .detail-value { color: var(--text-secondary); line-height: 1.5; }
    .detail-link { color: var(--game-accent); transition: opacity 0.15s; }
    .detail-link:hover { opacity: 0.7; }

    .section { margin-bottom: 48px; }
    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .section-title { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-tertiary); }
    .section-count { font-size: 12px; color: var(--text-tertiary); }

    .games-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 16px; }
    .game-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s; display: block; }
    .game-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: rgba(96,80,200,0.3); }
    .game-cover { aspect-ratio: 3/4; background: var(--tag-bg); overflow: hidden; position: relative; }
    .game-cover img { width: 100%; height: 100%; object-fit: cover; }
    .game-cover-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 36px; }
    .game-score-badge { position: absolute; top: 8px; right: 8px; width: 30px; height: 30px; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; font-family: 'Century Schoolbook', Georgia, serif; }
    .badge-great { color: var(--score-great); background: var(--score-great-bg); border: 1px solid rgba(74,222,128,0.3); }
    .badge-good  { color: var(--score-good);  background: var(--score-good-bg);  border: 1px solid rgba(96,165,250,0.3); }
    .badge-mid   { color: var(--score-mid);   background: var(--score-mid-bg);   border: 1px solid rgba(251,191,36,0.3); }
    .badge-low   { color: var(--score-low);   background: var(--score-low-bg);   border: 1px solid rgba(248,113,113,0.3); }
    .game-info { padding: 10px 12px 12px; }
    .game-title-text { font-size: 12px; font-weight: 500; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 3px; }
    .game-year { font-size: 11px; color: var(--text-tertiary); }
    .game-review-count { font-size: 10px; color: var(--text-tertiary); margin-top: 2px; }

    .empty-state { padding: 40px 0; text-align: center; color: var(--text-tertiary); }
    .empty-title { font-family: 'DM Serif Display', serif; font-size: 18px; color: var(--text-secondary); margin-bottom: 6px; }

    @media (max-width: 600px) {
      .studio-header { flex-direction: column; align-items: flex-start; margin-top: -50px; }
      .studio-name { font-size: 26px; }
      .hero { height: 220px; }
      .stats-row { gap: 8px; }
      .stat-num { font-size: 30px; }
      .games-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 12px; }
      .jump-nav { display: none; }
    }
  </style>
</head>

<body>
  <nav class="topnav">
    <a href="/" class="back-btn">
      <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8L10 4"/></svg>
      Back
    </a>
    <a href="/" class="logo"><span class="logo-dot"></span>Cartridge</a>
    <button class="theme-btn" onclick="toggleTheme()">
      <svg id="themeIcon" width="17" height="17" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="9" r="3.5"/>
        <path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>
      </svg>
    </button>
  </nav>

  <nav class="jump-nav">
    <a href="#overview" class="jump-link active">Overview</a>
    {developedGames.length > 0 && <a href="#developed" class="jump-link">Developed</a>}
    {publishedOnly.length > 0 && <a href="#published" class="jump-link">Published</a>}
  </nav>

  <div class="hero">
    <div class="hero-mosaic" id="heroMosaic"></div>
    <div class="hero-overlay"></div>
  </div>

  <div class="page">

    <div class="studio-header" id="overview">
      <div class="studio-logo-wrap">
        {studio.logo_url
          ? <img class="studio-logo" src={igdbImage(studio.logo_url, 't_logo_med') ?? ''} alt={studio.name} />
          : <span class="studio-logo-placeholder">🎮</span>
        }
      </div>
      <div class="studio-info">
        <h1 class="studio-name">{studio.name}</h1>
        <div class="studio-meta">
          {studio.founded_year && <span class="studio-meta-item">Est. {studio.founded_year}</span>}
          {studio.founded_year && studio.country && <span class="studio-meta-sep">•</span>}
          {studio.country && <span class="studio-meta-item">{countryName(studio.country) ?? String(studio.country)}</span>}
          {studio.website_url && (
            <>
              <span class="studio-meta-sep">•</span>
              <a href={studio.website_url} target="_blank" rel="noopener" class="studio-website">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="6"/><path d="M8 2c0 0-3 2-3 6s3 6 3 6M8 2c0 0 3 2 3 6s-3 6-3 6M2 8h12"/></svg>
                {studio.website_url.replace(/^https?:\/\//, '').replace(/\/$/, '')}
              </a>
            </>
          )}
        </div>
      </div>
    </div>

    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-num">{totalGames}</div>
        <div class="stat-label">Games</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{totalReviews.toLocaleString()}</div>
        <div class="stat-label">Reviews</div>
        <div class="stat-sub">across all games</div>
      </div>
      <div class={`stat-card ${overallScoreClass ? `score-card-${overallScoreClass}` : ''}`}>
        {overallAvg
          ? <div class={`stat-num ${overallScoreClass}`}>{overallAvg}</div>
          : <div class="stat-num" style="color:var(--text-tertiary)">—</div>
        }
        <div class="stat-label">Avg score</div>
      </div>
    </div>

    {(studio.description || studio.founded_year || studio.country || studio.website_url) && (
      <div class="about-grid">
        <div>
          {studio.description && (
            <>
              <p class="description collapsed" id="desc">{studio.description}</p>
              <button class="read-more-btn" id="readMoreBtn" onclick="toggleDesc()">Read more →</button>
            </>
          )}
        </div>
        <div class="details-card">
          {studio.founded_year && (
            <div class="detail-row">
              <span class="detail-label">Founded</span>
              <span class="detail-value">{studio.founded_year}</span>
            </div>
          )}
          {studio.country && (
            <div class="detail-row">
              <span class="detail-label">Country</span>
              <span class="detail-value">{countryName(studio.country) ?? String(studio.country)}</span>
            </div>
          )}
          {studio.website_url && (
            <div class="detail-row">
              <span class="detail-label">Website</span>
              <a href={studio.website_url} target="_blank" rel="noopener" class="detail-value detail-link">
                {studio.website_url.replace(/^https?:\/\//, '').replace(/\/$/, '')}
              </a>
            </div>
          )}
          <div class="detail-row">
            <span class="detail-label">Games</span>
            <span class="detail-value">{totalGames} total</span>
          </div>
          {totalReviews > 0 && (
            <div class="detail-row">
              <span class="detail-label">Reviews</span>
              <span class="detail-value">{totalReviews.toLocaleString()} across all games</span>
            </div>
          )}
        </div>
      </div>
    )}

    {developedGames.length > 0 && (
      <div class="section" id="developed">
        <div class="section-header">
          <span class="section-title">Developed</span>
          <span class="section-count">{developedGames.length} {developedGames.length === 1 ? 'game' : 'games'}</span>
        </div>
        <div class="games-grid">
          {developedGames.map((g: any) => {
            const avg = gameAvgScore(g.id)
            const count = gameReviewCount(g.id)
            const sc = avg ? scoreClass(parseFloat(avg)) : null
            return (
              <a href={`/games/${g.slug}`} class="game-card">
                <div class="game-cover">
                  {g.cover_img_url
                    ? <img src={igdbImage(g.cover_img_url) ?? ''} alt={g.title} loading="lazy" />
                    : <div class="game-cover-placeholder">🎮</div>
                  }
                  {avg && <div class={`game-score-badge badge-${sc}`}>{avg}</div>}
                </div>
                <div class="game-info">
                  <div class="game-title-text">{g.title}</div>
                  {releaseYear(g.date_released) && <div class="game-year">{releaseYear(g.date_released)}</div>}
                  {count > 0 && <div class="game-review-count">{count} {count === 1 ? 'review' : 'reviews'}</div>}
                </div>
              </a>
            )
          })}
        </div>
      </div>
    )}

    {publishedOnly.length > 0 && (
      <div class="section" id="published">
        <div class="section-header">
          <span class="section-title">Published</span>
          <span class="section-count">{publishedOnly.length} {publishedOnly.length === 1 ? 'game' : 'games'}</span>
        </div>
        <div class="games-grid">
          {publishedOnly.map((g: any) => {
            const avg = gameAvgScore(g.id)
            const count = gameReviewCount(g.id)
            const sc = avg ? scoreClass(parseFloat(avg)) : null
            return (
              <a href={`/games/${g.slug}`} class="game-card">
                <div class="game-cover">
                  {g.cover_img_url
                    ? <img src={igdbImage(g.cover_img_url) ?? ''} alt={g.title} loading="lazy" />
                    : <div class="game-cover-placeholder">🎮</div>
                  }
                  {avg && <div class={`game-score-badge badge-${sc}`}>{avg}</div>}
                </div>
                <div class="game-info">
                  <div class="game-title-text">{g.title}</div>
                  {releaseYear(g.date_released) && <div class="game-year">{releaseYear(g.date_released)}</div>}
                  {count > 0 && <div class="game-review-count">{count} {count === 1 ? 'review' : 'reviews'}</div>}
                </div>
              </a>
            )
          })}
        </div>
      </div>
    )}

    {totalGames === 0 && (
      <div class="empty-state">
        <div class="empty-title">No games yet</div>
        <p>We don't have any games listed for {studio.name} yet.</p>
      </div>
    )}

  </div>

  <script define:vars={{ coverUrlsJson }}>
    const coverUrls = JSON.parse(coverUrlsJson)

    const mosaic = document.getElementById('heroMosaic')
    if (mosaic && coverUrls.length > 0) {
      const tiles = [...coverUrls, ...coverUrls, ...coverUrls].slice(0, 24)
      tiles.forEach(url => {
        const tile = document.createElement('div')
        tile.className = 'hero-mosaic-tile'
        tile.style.backgroundImage = `url(${url})`
        mosaic.appendChild(tile)
      })
    }

    function toggleDesc() {
      const desc = document.getElementById('desc')
      const btn = document.getElementById('readMoreBtn')
      if (!desc || !btn) return
      desc.classList.toggle('collapsed')
      btn.textContent = desc.classList.contains('collapsed') ? 'Read more →' : 'Read less ↑'
    }
    window.toggleDesc = toggleDesc

    const sections = ['overview', 'developed', 'published']
    const jumpLinks = document.querySelectorAll('.jump-link')
    window.addEventListener('scroll', () => {
      let current = 'overview'
      sections.forEach(id => {
        const el = document.getElementById(id)
        if (el && window.scrollY >= el.offsetTop - 120) current = id
      })
      jumpLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === `#${current}`))
    })

    function toggleTheme() {
      const h = document.documentElement
      const n = h.getAttribute('data-theme') === 'light' ? 'dark' : 'light'
      h.setAttribute('data-theme', n)
      localStorage.setItem('theme', n)
      updateIcon(n)
    }
    function updateIcon(t) {
      const i = document.getElementById('themeIcon')
      if (!i) return
      i.innerHTML = t === 'dark'
        ? '<path d="M15 10.5A7 7 0 016.5 3a7 7 0 100 12 7 7 0 008.5-4.5z"/>'
        : '<circle cx="9" cy="9" r="3.5"/><path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M13.36 4.64l1.42-1.42M3.22 14.78l1.42-1.42"/>'
    }
    window.toggleTheme = toggleTheme

    const saved = localStorage.getItem('theme') ||
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
    document.documentElement.setAttribute('data-theme', saved)
    updateIcon(saved)
  </script>
</body>
</html>
